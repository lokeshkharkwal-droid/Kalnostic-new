meta {
  name: Get Medical History
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/patients/{{patientId}}/medical-history/{{medicalHistoryId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

docs {
  Fetch one medical-history record for the patient (scoped to the caller's
  tenant). 404 `MEDICAL_HISTORY_NOT_FOUND` if missing, soft-deleted, or not owned
  by this patient/tenant.

  Uses `patientId` + `medicalHistoryId` captured by the list/create requests.
}
