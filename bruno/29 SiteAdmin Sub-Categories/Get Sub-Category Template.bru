meta {
  name: Get Sub-Category Template
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/siteadmin/sub-categories/{{siteAdminSubCategoryTemplateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{siteAdminToken}}
}

docs {
  Fetch one SITE_ADMIN sub-category template by id. Auth: SiteAdmin token,
  requires `master-data:read`. 404 `SUB_CATEGORY_NOT_FOUND` if missing,
  soft-deleted, or not a template.
}
