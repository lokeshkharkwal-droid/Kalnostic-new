meta {
  name: Delete Sub-Category Template
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/siteadmin/sub-categories/{{siteAdminSubCategoryTemplateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{siteAdminToken}}
}

docs {
  Soft-delete a SITE_ADMIN sub-category template (sets `deletedAt`). Auth:
  SiteAdmin token, requires `master-data:write`. 404 `SUB_CATEGORY_NOT_FOUND` if
  not a live template.
}
