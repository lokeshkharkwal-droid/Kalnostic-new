meta {
  name: Get Order
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/orders/{{orderId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

docs {
  Fetch one order fully composed: patient ref, active `items` (with their resolved
  test/panel), the `diagnostics`/`opd`/`radiology` sections with resolved refs, and
  the active `payments` ledger. 404 `ORDER_NOT_FOUND` if missing, soft-deleted, or
  owned by another tenant.
}
