meta {
  name: List Referral Panel Options
  type: http
  seq: 30
}

get {
  url: {{baseUrl}}/referral-panels/options?page=1&limit=10
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 10
  ~search: apollo
  ~branchId: {{branchId}}
}

auth:bearer {
  token: {{businessAccessToken}}
}

docs {
  Lightweight `{ id, name }` options for the Referring Panel selector. Tenant-scoped,
  active (`isActive: true`), non-deleted panels ordered by name. `search` matches the
  panel name (case-insensitive). `branchId` restricts to a single branch (strict — records
  with no branch are excluded). Omit `page` for the full array; supply `page` for a
  `{ data, total, page, limit }` envelope (the "Load More" selector).
}
