meta {
  name: Get Lab Test Template
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/siteadmin/lab-tests/{{siteAdminLabTestId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{siteAdminToken}}
}

docs {
  Fetch one SITE_ADMIN lab-test template with all its children (samples, result
  params, and each param's reference ranges/values). Auth: SiteAdmin token,
  requires `master-data:read`. 404 `LAB_TEST_NOT_FOUND` if the id isn't a live
  template. Uses `siteAdminLabTestId` from Create Lab Test Template.
}
