meta {
  name: Get Branch Modules
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/branches/{{branchId}}/modules
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  branchId: 37e8cb33-9c10-4778-bc4c-20490e1c0f75
}

docs {
  List all 14 system modules with whether each is enabled at this branch
  (`{ moduleKey, label, isEnabled }`). Modules with no row are reported disabled.
}
