  token: {{businessAccessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Main Lab (Central)",
    "phone": "+919811111112"
  }
}

docs {
  Update a branch (scoped to the caller's tenant). All fields optional.
}
