meta {
  name: Update Branch
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/branches/{{branchId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  
  {
    "modules": [
      { "moduleKey": "accession", "isEnabled": true },
      { "moduleKey": "inventory", "isEnabled": true },
      { "moduleKey": "finance", "isEnabled": false }
    ]
  }
}

vars:pre-request {
  branchId: f3900c9e-ddca-48e1-a1d3-9d77215d7382
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..Yr6sJexCWb_6LL_RJOMe8aWsHLm7SkKcmGn0kcWb5wQ
}

docs {
  Update a branch (scoped to the caller's tenant). All fields optional.

  Optional `modules`: enable/disable system modules in the same request (only
  the keys you send are touched — omit a key to leave it unchanged). Each
  `moduleKey` must be a known system module (`accession`, `inventory`, `sales`,
  `finance`, `phlebotomist`, `assistant`, `operation`, `business_admin`,
  `branch_admin`). Equivalent to `PUT /branches/:id/modules`, which still exists.

  Optional `receivingBranchIds` (Collection Centers only): replaces the branch's
  whole sample-receiving-branch mapping set (equivalent to
  `PUT /branches/:id/collection-mappings`). Each id must be an existing,
  non-Collection-Center branch in the tenant. Sending it for a non-Collection-
  Center branch (with a non-empty list) is rejected.
}
