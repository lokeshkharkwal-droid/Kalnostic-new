meta {
  name: Set Main Branch
  type: http
  seq: 7
}

put {
  url: {{baseUrl}}/branches/main-branch
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "branchId": "{{branchId}}"
  }
}

vars:pre-request {
  branchId: 33f7c1db-3fd4-4e0b-b5ee-30c731535a05
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..SvHviOXq5XC3_5hZ30iX0nsg3McXaCySgbwwmZP3ujY
}

docs {
  Set (or change) the tenant's single main branch. Idempotent upsert — only one
  main branch exists per tenant at a time. The `branchId` must belong to the
  caller's tenant (validated server-side; 404 otherwise).
  
  Defaults to the `branchId` captured by **Create Branch**.
}
