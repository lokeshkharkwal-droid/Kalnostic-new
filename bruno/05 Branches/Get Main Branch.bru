meta {
  name: Get Main Branch
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/branches/main-branch
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..SvHviOXq5XC3_5hZ30iX0nsg3McXaCySgbwwmZP3ujY
}

docs {
  Get the tenant's current main branch (the full branch object).
  
  Returns 404 (`MAIN_BRANCH_NOT_SET`) if no main branch has been set yet — run
  **Set Main Branch** first.
}
