meta {
  name: Set Branch Modules
  type: http
  seq: 9
}

put {
  url: {{baseUrl}}/branches/{{branchId}}/modules
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "modules": [
      { "moduleKey": "registration", "isEnabled": true },
      { "moduleKey": "accession", "isEnabled": true },
      { "moduleKey": "lab_operations", "isEnabled": true },
      { "moduleKey": "sales", "isEnabled": true },
      { "moduleKey": "finance", "isEnabled": false },
          { "moduleKey": "branch_admin", "isEnabled": true }
    ]
  }
}

vars:pre-request {
  branchId: d3b91f75-b897-4c81-b216-48bde7d2aad1
}

docs {
  Enable / disable system modules at this branch (upsert per module; the client
  sends the desired set). This gates which work-area modules can be picked as a
  user's default module and which appear in the per-user permission modal for
  the branch. `isEnabled` defaults to true when omitted. `moduleKey` must be one
  of the 12 master modules (see Users → User Management v2 → List Modules).
}
