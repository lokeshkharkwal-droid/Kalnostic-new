meta {
  name: Create Branch
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/branches
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "name": "My Test Main Lab 2",
    "branchType": "DIAGNOSTIC",
    "phone": "+919811111111",
    "email": "main@acme.test",
    "addressLine": "12 Lab Street",
    "city": "Pune",
    "state": "Maharashtra",
    "pincode": "411001"
  }
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..SvHviOXq5XC3_5hZ30iX0nsg3McXaCySgbwwmZP3ujY
}

script:post-response {
  const data = res.getBody() && res.getBody().data;
  if (data && data.id) bru.setEnvVar("branchId", data.id);
}

docs {
  Create a branch in the caller's tenant (tenant id taken from the JWT).
  Captures `branchId`.
  
  `branchType` is one of: `DIAGNOSTIC`, `RADIOLOGY`, `OPD`, `IPD`, `PHARMACY`,
  `INVENTORY`, `BLOOD_BANK`, `FRANCHISE`, `COMBINED`. `name` 2-255 chars.
  
  NOTE: `code` is system-generated (per-tenant sequential, e.g. `BR-00001`) and
  immutable — do NOT send it in the body (it is rejected as an unknown field).
  `name` must be unique among active branches in the tenant (409 otherwise).
}
