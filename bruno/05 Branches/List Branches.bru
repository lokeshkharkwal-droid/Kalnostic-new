meta {
  name: List Branches
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/branches?page=1&limit=20
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  ~search: main
  ~status: ACTIVE
  ~branchType: COLLECTION_CENTER
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..Yr6sJexCWb_6LL_RJOMe8aWsHLm7SkKcmGn0kcWb5wQ
}

docs {
  Paginated list of branches in the caller's tenant. All query params optional:

  - `page` / `limit` — offset pagination (defaults 1 / 20, limit capped at 100).
  - `search` — case-insensitive match against branch `name` OR `code`.
  - `status` — filter by `BranchStatus` (`ACTIVE` | `INACTIVE` | `UNDER_MAINTENANCE`).
  - `branchType` — filter by `BranchType` (e.g. `COLLECTION_CENTER`, `DIAGNOSTIC`).
}
