meta {
  name: List Branches
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/branches?page=1&limit=20
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
}

auth:bearer {
  token: {{businessAccessToken}}
}

docs {
  Paginated list of branches in the caller's tenant. `page`/`limit` optional.
}
