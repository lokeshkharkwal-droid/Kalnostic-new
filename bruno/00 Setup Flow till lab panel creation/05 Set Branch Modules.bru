meta {
  name: 05 Set Branch Modules
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/branches/{{branchId}}/modules
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "modules": [
      { "moduleKey": "accession", "isEnabled": true },
      { "moduleKey": "sales", "isEnabled": true },
      { "moduleKey": "branch_admin", "isEnabled": true }
    ]
  }
}

vars:pre-request {
  branchId: 8b441c6b-8c9e-4729-a4fe-654b42a49d9b
}

docs {
  Step 5 (REQUIRED before users). Enable system modules at the branch. This gates
  which modules can be a user's default module and which appear in the per-user
  permission modal. Skipping this makes step 6 fail with
  `422 MODULE_NOT_ENABLED_FOR_BRANCH`.
}
