meta {
  name: List Global Templates
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/templates/global?page=1&limit=20&preference=SMS
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  preference: SMS
  ~feature: lab_order_report_published_inform_patient
  ~search: report
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Browse the SITE_ADMIN global (tenant-agnostic) messaging template catalogue so
  the business can pick one to import. Same filter set as `List Templates`
  (`preference` / `feature` / `messageType` / `level` / `applicableBranchType` /
  `search` / boolean flags). Read-only; pagination lands in `meta`.
}
