  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Partial, dropdown-optimised listing. Returns only `{ id, name }` per row (not
  the full template record), ordered by `name` ascending — ideal for select /
  lookup fields.

  Scope (`tenantId` + `branchId`) comes from the JWT, never the query
  (CLAUDE.md §4.7): a business_admin token returns tenant-level templates; a
  branch-admin token returns that branch's templates.

  ## Query params

  - `type` (optional) — restrict to one type: `SMS` | `EMAIL` | `WHATSAPP` | `CONSENT_FORM` | `REPORT_TEMPLATE`.
  - `page` / `limit` (optional) — offset pagination; pagination info lands in `meta`.
}
