meta {
  name: Lookup Templates (Dropdown)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/templates/lookup?page=1&limit=50&preference=SMS
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 50
  preference: SMS
  ~feature: lab_order_report_published_inform_patient
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Partial, dropdown-optimised listing. Returns only
  `{ id, displayTitle, preference, feature }` per row (not the full template
  record), ordered by `createdAt` descending — ideal for select / lookup fields.

  Scope (`tenantId` + `branchId`) comes from the JWT, never the query
  (CLAUDE.md §4.7): a business_admin token returns tenant-level templates; a
  branch-admin token returns that branch's templates.

  ## Query params

  - `preference` (optional) — restrict to one channel: `EMAIL` | `SMS` | `IAM` | `IAA` | `PBN` | `WHATSAPP` | `TEMPLATE`.
  - `feature` (optional) — restrict to one FEATURE_TYPES key.
  - `page` / `limit` (optional) — offset pagination; pagination info lands in `meta`.
}
