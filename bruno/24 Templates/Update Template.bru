meta {
  name: Update Template
  type: http
  seq: 9
}

patch {
  url: {{baseUrl}}/templates/{{templateId}}
  body: json
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "displayTitle": "Report Ready Alert (Revised)",
    "isActive": true,
    "isEnabled": true,
    "isDefault": true,
    "template": "Hi {patient_name}, your {test_name} report is ready. View: {report_link}"
  }
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Update a messaging template (partial). Every field is optional and only the
  fields present in the body are changed; `tenantId` / `branchId` are never
  accepted (scope is fixed). The accepted field set matches the Create request
  (preference / feature / displayTitle / messageType / flags / scope targeting /
  SMS settings / template / WhatsApp settings).
}
