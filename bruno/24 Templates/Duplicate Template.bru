meta {
  name: Duplicate Template
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/templates/{{templateId}}/duplicate
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Duplicate a template within the caller's scope. Deep-copies the source with a
  fresh `code`, " (Copy)" appended to the name, and the version reset to `v1.0`;
  all JSON config/blocks are copied verbatim. No request body. 404
  `TEMPLATE_NOT_FOUND` if the source is missing/soft-deleted.
}
