meta {
  name: Duplicate Template
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/templates/{{templateId}}/duplicate
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Duplicate a template within the caller's scope. Copies the source with
  " (Copy)" appended to the `displayTitle` and `isDefault` reset to `false`; all
  other fields are copied verbatim. No request body. 404 `TEMPLATE_NOT_FOUND` if
  the source is missing/soft-deleted.
}
