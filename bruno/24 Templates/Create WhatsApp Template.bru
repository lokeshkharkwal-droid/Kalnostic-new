meta {
  name: Create WhatsApp Template
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/templates
  body: json
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "type": "WHATSAPP",
    "name": "Appointment Reminder WA",
    "triggerEvent": "APPOINTMENT_REMINDER",
    "version": "v1.0",
    "isActive": true,
    "body": "*Reminder*: Hi {patient_name}, your appointment is on {appointment_date} at {appointment_time}.",
    "whatsapp": {
      "templateCategory": "UTILITY",
      "approvedTemplateId": "appt_reminder_en_v3"
    },
    "header": {
      "enabled": true,
      "type": "Image",
      "text": "",
      "imageFile": "wa-header.png",
      "alignment": "Center"
    },
    "footerBlock": {
      "enabled": false,
      "type": "Text",
      "text": "",
      "imageFile": "",
      "alignment": "Left"
    },
    "attachment": {
      "enabled": true,
      "type": "PDF",
      "files": ["appointment-card.pdf"],
      "position": "Media Header",
      "alignment": "Left",
      "sizeProfile": "Full Width"
    }
  }
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

script:post-response {
  const data = res.getBody() && res.getBody().data;
  if (data && data.id) bru.setEnvVar("templateId", data.id);
}

docs {
  WhatsApp template. Adds the `whatsapp` block (stored in `config.whatsapp`):
  `templateCategory` (`MARKETING` | `UTILITY` | `AUTHENTICATION`) and
  `approvedTemplateId` (the WhatsApp Business pre-approved template id).
  Attachment `position` for WhatsApp is `Media Header` / `Media Footer`. See
  "Create SMS Template" for the shared field reference.
}
