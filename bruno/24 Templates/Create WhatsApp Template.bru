meta {
  name: Create WhatsApp Template
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/templates
  body: json
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "preference": "WHATSAPP",
    "feature": "appointment_reminder_inform_patient",
    "displayTitle": "Appointment Reminder WA",
    "messageType": "TRANSACTIONAL",
    "isActive": true,
    "isEnabled": true,
    "level": "BUSINESS",
    "template": "*Reminder*: Hi {patient_name}, your appointment is on {appointment_date} at {appointment_time}.",
    "templateType": "DOCUMENT",
    "templateCategory": "UTILITY",
    "fileName": "appointment-card"
  }
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

script:post-response {
  const data = res.getBody() && res.getBody().data;
  if (data && data.id) bru.setEnvVar("templateId", data.id);
}

docs {
  WhatsApp messaging template. When `preference` is `WHATSAPP` the WhatsApp
  settings are **required**:

  - `templateType` (required): media type — `TEXT` | `IMAGE` | `VIDEO` | `DOCUMENT`.
  - `templateCategory` (required): WABA category — `UTILITY` | `MARKETING` | `AUTHENTICATION`.
  - `fileName` (optional): attachment file name — letters, digits, `_` and `-` only.

  See "Create SMS Template" for the shared core/scope fields.
}
