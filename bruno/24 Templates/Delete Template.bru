meta {
  name: Delete Template
  type: http
  seq: 11
}

delete {
  url: {{baseUrl}}/templates/{{templateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Soft-delete a template (sets `deletedAt`; the row is preserved and its name/code
  are freed for reuse among active rows). Scoped to the caller's tenant + scope
  branch. 404 `TEMPLATE_NOT_FOUND` if missing/already-deleted.
}
