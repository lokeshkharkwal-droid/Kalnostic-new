meta {
  name: Create Email Template
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/templates
  body: json
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "preference": "EMAIL",
    "feature": "lab_order_report_published_inform_patient",
    "displayTitle": "Report Dispatch Email",
    "messageType": "TRANSACTIONAL",
    "isActive": true,
    "isEnabled": true,
    "level": "BUSINESS",
    "template": "<p>Dear {patient_name},</p><p>Your report for {test_name} is now available at {report_link}.</p><p>Regards,<br/>{lab_name}</p>"
  }
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

script:post-response {
  const data = res.getBody() && res.getBody().data;
  if (data && data.id) bru.setEnvVar("templateId", data.id);
}

docs {
  Email messaging template. `preference` is `EMAIL`, so `template` holds rich
  HTML. See "Create SMS Template" for the full field reference shared by all
  channels (preference / feature / displayTitle / messageType / flags / scope
  targeting / template).
}
