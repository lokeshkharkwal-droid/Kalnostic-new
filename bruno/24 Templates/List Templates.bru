meta {
  name: List Templates
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/templates?page=1&limit=20&type=SMS&search=report
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  type: SMS
  search: report
  ~isActive: true
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Paginated list of templates in the caller's scope (tenant-level for
  business_admin, the active branch for branch-admin — scope comes from the JWT,
  never the query). Each row is the full template record. Pagination lands in
  `meta`. Ordered by `createdAt` descending.

  ## Search

  - `search` — case-insensitive match against `name`.

  ## Filters (toggle the `~` to enable a query param)

  - `type` — tab filter: `SMS` | `EMAIL` | `WHATSAPP` | `CONSENT_FORM` | `REPORT_TEMPLATE`.
  - `isActive` — `true` | `false` status filter.
}
