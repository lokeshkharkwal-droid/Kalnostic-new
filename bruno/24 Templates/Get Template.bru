meta {
  name: Get Template
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/templates/{{templateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Fetch one template by id, scoped to the caller's tenant + scope branch. Uses
  the `templateId` captured by a Create request. 404 `TEMPLATE_NOT_FOUND` if it
  is missing, soft-deleted, or outside the caller's scope.
}
