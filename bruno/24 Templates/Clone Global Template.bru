meta {
  name: Clone Global Template
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/templates/global/{{globalTemplateId}}/clone
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Clone a SITE_ADMIN global messaging template into the caller's scope (tenant +
  active branch from the JWT). Idempotent — re-cloning the same template into the
  same scope returns the existing copy (matched on `clonedFromId`). The clone
  keeps the source title (no " (Copy)") and is `level = BUSINESS`. No request
  body. 404 `TEMPLATE_NOT_FOUND` if the source isn't a live global template.
}
