meta {
  name: 12 Create Lab Test
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/master-data/{{masterDataId}}/lab-tests
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "testName": "Complete Blood Count",
    "testCode": "CBC",
    "processMethod": "SINGLE_STEP",
    "samplePriorityType": "ROUTINE",
    "priceMsrp": 700,
    "priceMaximum": 650,
    "priceMinimum": 400,
    "tatMinValue": 2,
    "tatMinUnit": "HOURS",
    "tatMaxValue": 24,
    "tatMaxUnit": "HOURS",
    "scheduleDays": ["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"],
    "samples": [
      {
        "containerType": "EDTA_TUBE_PURPLE_TOP",
        "sampleSize": "3 mL",
        "numberOfSamples": 1,
        "isFastingRequired": false,
        "isDefault": true
      }
    ],
    "resultParams": [
      {
        "parameterName": "Haemoglobin",
        "parameterCode": "HGB",
        "reportingUnit": "g/dL",
        "resultType": "QUANTITATIVE",
        "parameterType": "MEASURED",
        "decimalPlaces": 1,
        "sortOrder": 1,
        "referenceRanges": [
          {
            "gender": "MALE",
            "ageFrom": 18,
            "ageFromUnit": "YEARS",
            "ageTo": 99,
            "ageToUnit": "YEARS",
            "lowerLimit": 13.0,
            "upperLimit": 17.0,
            "criticalMin": 7.0,
            "criticalMax": 20.0
          }
        ]
      }
    ]
  }
}

script:post-response {
  const data = res.getBody() && res.getBody().data;
  if (data && data.id) bru.setEnvVar("labTestId", data.id);
}

docs {
  Step 12. Create a lab test inside the master data from step 11. `testName` /
  `testCode` unique per master data. Cross-field rules: `priceMaximum <= priceMsrp`,
  `priceMinimum <= priceMaximum`, per range `lowerLimit <= upperLimit`,
  `criticalMin <= lowerLimit`, `criticalMax >= upperLimit`. Captures `labTestId`.
}
