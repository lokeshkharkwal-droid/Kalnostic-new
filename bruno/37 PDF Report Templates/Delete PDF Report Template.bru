meta {
  name: Delete PDF Report Template
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/pdf-report-templates/{{pdfReportTemplateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

docs {
  Soft-delete a PDF report template (sets `deletedAt`; the row is preserved and
  its name is freed for reuse). 404 if missing or already soft-deleted.
}
