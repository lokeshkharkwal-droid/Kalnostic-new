meta {
  name: Save Template Config
  type: http
  seq: 14
}

put {
  url: {{baseUrl}}/pdf-report-templates/config
  body: json
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "assignments": [
      { "slotKey": "lab_report", "templateId": "{{pdfTemplateId}}" },
      { "slotKey": "invoice", "templateId": null }
    ]
  }
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Upsert the caller's slot -> template assignments for the active scope. Each
  `slotKey` must be a known slot (`GET config/slots`); a non-null `templateId`
  must be one of the caller's active templates. A null `templateId` clears the
  slot. Returns the resulting map. 400 `INVALID_PDF_TEMPLATE_CONFIG_SLOT` on an
  unknown slot; 404 `PDF_REPORT_TEMPLATE_NOT_FOUND` if a `templateId` isn't the
  tenant's.
}
