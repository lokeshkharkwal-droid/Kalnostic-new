meta {
  name: List Global PDF Templates
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/pdf-report-templates/global?page=1&limit=20
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  ~type: lab_report
  ~search: report
  ~status: ACTIVE
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Browse the SITE_ADMIN global PDF report template catalogue so the business can
  pick one to import. Optional `type` / `search` (name) / `status` filters.
  Read-only; pagination lands in `meta`.
}
