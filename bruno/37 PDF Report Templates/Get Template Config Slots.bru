meta {
  name: Get Template Config Slots
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/pdf-report-templates/config/slots
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  The grouped slot catalogue for the Configuration screen — an array of
  `{ label, slots: [{ key, label }] }`. Each slot `key` is a
  `PDF_REPORT_TEMPLATE_TYPES` key; the frontend filters the template dropdown by
  `type = key`.
}
