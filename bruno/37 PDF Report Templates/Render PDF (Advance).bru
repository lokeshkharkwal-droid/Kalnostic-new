meta {
  name: Render PDF (Advance)
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/pdf-report-templates/{{pdfTemplateId}}/render
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Render this tenant template's Advance block document (`doc`) to a PDF against
  SAMPLE data and stream it back (`application/pdf`). The block-designer
  counterpart of `Generate PDF` (classic HTML `meta`). No request body.
}
