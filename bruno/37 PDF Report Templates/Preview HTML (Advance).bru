meta {
  name: Preview HTML (Advance)
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/pdf-report-templates/{{pdfTemplateId}}/preview-html
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..J55wiEzB-FCqQGSFyaVmqeOfFIFJRrlK5d47mBUpMZ4
}

docs {
  Render this tenant template's Advance block document (`doc`) to preview HTML
  against SAMPLE data — feeds the Advance PDF editor's live iframe. Returns raw
  `text/html` (not the JSON envelope). 404 `PDF_REPORT_TEMPLATE_NOT_FOUND` if the
  template is missing/soft-deleted.
}
