meta {
  name: Get Icon Setting
  type: http
  seq: 18
}

get {
  url: {{baseUrl}}/business-admin/lab-test-settings/icon-settings/{{iconSettingId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("id matches", function () {
    expect(res.getBody().data.id).to.equal(bru.getEnvVar("iconSettingId"));
  });
}

docs {
  Fetch a single lab icon setting by id.
  Returns 404 LAB_ICON_SETTING_NOT_FOUND if missing or soft-deleted.
  Requires `iconSettingId` env var (set by Create Icon Setting).
}
