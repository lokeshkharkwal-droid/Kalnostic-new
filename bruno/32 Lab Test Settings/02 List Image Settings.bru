meta {
  name: List Image Settings
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/business-admin/lab-test-settings/image-settings
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("returns array", function () {
    expect(res.getBody().data).to.be.an("array");
  });
}

docs {
  List all lab image settings for the caller's tenant (tenant id from JWT).
  Soft-deleted records are excluded. Ordered newest first.
}
