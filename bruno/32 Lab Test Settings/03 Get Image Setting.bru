meta {
  name: Get Image Setting
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/business-admin/lab-test-settings/image-settings/{{imageSettingId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("id matches", function () {
    expect(res.getBody().data.id).to.equal(bru.getEnvVar("imageSettingId"));
  });
}

docs {
  Fetch a single lab image setting by id.
  Returns 404 LAB_IMAGE_SETTING_NOT_FOUND if missing or soft-deleted.
  Requires `imageSettingId` env var (set by Create Image Setting).
}
