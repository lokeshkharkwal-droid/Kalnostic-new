meta {
  name: Delete Pdf Setting
  type: http
  seq: 10
}

delete {
  url: {{baseUrl}}/business-admin/lab-test-settings/pdf-settings/{{pdfSettingId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
}

docs {
  Soft-delete a lab PDF setting. The record is preserved in the database
  (deletedAt is set) and will no longer appear in List or Get responses.
  Returns 404 LAB_PDF_SETTING_NOT_FOUND if already deleted or not found.
  Requires `pdfSettingId` env var (set by Create Pdf Setting).
}
