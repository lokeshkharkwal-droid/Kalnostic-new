meta {
  name: Update Image Setting
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/business-admin/lab-test-settings/image-settings/{{imageSettingId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "name": "Microscopy – Two Per Row (Updated)",
    "status": "Inactive"
  }
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("name updated", function () {
    expect(res.getBody().data.name).to.equal("Microscopy – Two Per Row (Updated)");
  });
  test("status updated", function () {
    expect(res.getBody().data.status).to.equal("Inactive");
  });
}

docs {
  Partially update a lab image setting. Only send the fields you want to change —
  all fields from CreateImageSetting are accepted but all are optional here.
  Returns 404 LAB_IMAGE_SETTING_NOT_FOUND if missing or soft-deleted.
  Requires `imageSettingId` env var (set by Create Image Setting).
}
