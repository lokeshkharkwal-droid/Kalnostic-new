meta {
  name: Delete Icon Setting
  type: http
  seq: 20
}

delete {
  url: {{baseUrl}}/business-admin/lab-test-settings/icon-settings/{{iconSettingId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
}

docs {
  Soft-delete a lab icon setting. The record is preserved in the database
  (deletedAt is set) and will no longer appear in List or Get responses.
  Returns 404 LAB_ICON_SETTING_NOT_FOUND if already deleted or not found.
  Requires `iconSettingId` env var (set by Create Icon Setting).
}
