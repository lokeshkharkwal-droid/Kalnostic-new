meta {
  name: Get Group Layout Setting
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/business-admin/lab-test-settings/group-layout-settings/{{groupLayoutSettingId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("id matches", function () {
    expect(res.getBody().data.id).to.equal(bru.getEnvVar("groupLayoutSettingId"));
  });
}

docs {
  Fetch a single lab group layout setting by id.
  Returns 404 LAB_GROUP_LAYOUT_SETTING_NOT_FOUND if missing or soft-deleted.
  Requires `groupLayoutSettingId` env var (set by Create Group Layout Setting).
}
