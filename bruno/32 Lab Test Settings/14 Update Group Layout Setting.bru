meta {
  name: Update Group Layout Setting
  type: http
  seq: 14
}

patch {
  url: {{baseUrl}}/business-admin/lab-test-settings/group-layout-settings/{{groupLayoutSettingId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "name": "Standard 2-Column (Updated)",
    "status": "Inactive"
  }
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("name updated", function () {
    expect(res.getBody().data.name).to.equal("Standard 2-Column (Updated)");
  });
  test("status updated", function () {
    expect(res.getBody().data.status).to.equal("Inactive");
  });
}

docs {
  Partially update a lab group layout setting. Only send the fields you want
  to change — all fields from Create Group Layout Setting are accepted but all
  are optional here.
  Returns 404 LAB_GROUP_LAYOUT_SETTING_NOT_FOUND if missing or soft-deleted.
  Requires `groupLayoutSettingId` env var (set by Create Group Layout Setting).
}
