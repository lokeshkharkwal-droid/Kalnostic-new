meta {
  name: 15 Resolve Branch Lab Test (option)
  type: http
  seq: 16
}

get {
  url: {{baseUrl}}/branch-lab-tests/options?search=Complete Blood Count&page=1&limit=10
  body: none
  auth: bearer
}

params:query {
  search: Complete Blood Count
  page: 1
  limit: 10
}

auth:bearer {
  token: {{operatorToken}}
}

script:post-response {
  const data = res.body && res.body.success && res.body.data;
  if (data && data.length && data[0].id) bru.setVar("branchLabTestId", data[0].id);
}

docs {
  **Prerequisite 4a — Resolve the branch lab-test id for the order.**

  The Create-Order lab-test picker uses this option endpoint (active branch from
  the JWT). `search` matches `testName`. Captures **`branchLabTestId`** from the
  first match — used as an order item's `branchLabTestId` in step 17.
}
