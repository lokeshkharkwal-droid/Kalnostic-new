meta {
  name: test
  type: http
  seq: 18
}

post {
  url: {{baseUrl}}/users/manage/{{manageUserId}}/branches
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "branches": [
      {
        "branchId": "{{branchId}}",
        "role": "reporting_doctor",
        "modules": ["assistant"],
        "defaultModule": "assistant",
        "defaultBranch": true,
        "status": "ACTIVE"
      }
    ]
  }
}

vars:pre-request {
  manageUserId: b0b8fb9d-7c16-4cd1-b527-5c6cb12508a1
  branchId: fc9e3c69-e871-423e-ad60-fa819ca7199e
  branchId2: b0b8fb9d-7c16-4cd1-b527-5c6cb12508a1
}

docs {
  Assign (or update) the user's branch assignments in bulk — an array of
  `{ branchId, role, modules?, defaultModule?, defaultBranch?, status? }`. The role
  is chosen **per branch** (one role per branch); a user can hold different roles at
  different branches. An existing assignment for a branch is re-roled in place.

  - `role` must be a branch-level role (validity from the role's allowed branch
    types — system: PROFILE_BRANCH_MATRIX).
  - Exactly one branch may be `defaultBranch: true` (else 422 MULTIPLE_DEFAULT_BRANCH).
  - `modules` must each be valid for the branch type (GET /modules?branchType) else
    422 MODULE_NOT_VALID_FOR_BRANCH_TYPE, and **enabled for that branch** (Branches →
    Set Branch Modules first) else 422 MODULE_NOT_ENABLED_FOR_BRANCH.
  - `defaultModule` must be one of `modules` (else 422 DEFAULT_MODULE_NOT_IN_MODULES)
    and, when the role template links specific modules, one of them else 422
    MODULE_NOT_IN_ROLE_TEMPLATE.
  - `status` ACTIVE|INACTIVE controls access to that branch only.
}
