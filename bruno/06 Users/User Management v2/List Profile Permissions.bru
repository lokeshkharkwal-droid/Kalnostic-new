meta {
  name: List Profile Permissions
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/users/manage/permissions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

docs {
  Permissions screen listing: one row per (globally-Active user + branch) — a
  user on 3 branches appears 3 times. Columns: `id` (assignment id), `userCode`,
  `username`, `role`, `branch`, `status` (always Active in this view; inactive
  users are excluded).
}
