meta {
  name: Assign Profile
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/users/{{staffPersonId}}/profiles
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "profileKey": "receptionist",
    "branchId": "{{branchId}}",
    "isDefault": false
  }
}

vars:pre-request {
  branchId: 0b866440-7552-4589-a867-161f3db63420
  staffPersonId: dc2cff08-eae0-4cbd-86bc-7530ed3bf76e
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..9-FgakTfsc0MFAvgBb_l4SEav9oCnP7YLFax92E2PVs
}

docs {
  Assign a profile to a person at a branch (omit `branchId` for tenant-level
  profiles like `business_admin`). `isDefault` marks the landing profile.
  `profileKey` from the registry: business_admin, branch_admin, doctor,
  lab_technician, receptionist, patient.
}
