meta {
  name: Revoke Profile
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/users/{{staffPersonId}}/profiles
  body: json
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "profileKey": "receptionist",
    "branchId": "{{branchId}}"
  }
}

docs {
  Revoke a profile assignment (soft delete). Omit `branchId` for tenant-level
  profiles. Body is required on this DELETE.
}
