meta {
  name: Bulk Import Lab Tests copy
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/master-data/{{masterDataId}}/lab-tests/import
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{businessAccessToken}}
}

