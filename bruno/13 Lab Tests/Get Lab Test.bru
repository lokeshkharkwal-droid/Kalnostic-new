meta {
  name: Get Lab Test
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/master-data/{{masterDataId}}/lab-tests/{{labTestId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  labTestId: 75ac4c6f-8a05-4a42-bf9a-d9ed7d01ec09
  masterDataId: a39403ae-6d44-4293-a7ba-61806f8b04f3
}

docs {
  Fetch one lab test composed with all of its children: `samples` and
  `resultParams` (each with its `referenceRanges` and `referenceValues`), plus
  `versionHistory`. 404 `LAB_TEST_NOT_FOUND` if missing, soft-deleted, or not in
  this master data / tenant. Uses `masterDataId` + `labTestId` from the earlier
  requests.
}
