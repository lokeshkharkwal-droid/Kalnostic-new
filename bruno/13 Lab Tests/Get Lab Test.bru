meta {
  name: Get Lab Test
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/master-data/{{masterDataId}}/lab-tests/{{labTestId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  labTestId: f5953a54-9eb3-4c01-b7e2-c50ee5fc9364
  masterDataId: cda51b46-948d-45bf-8368-00add42c2bfb
}

docs {
  Fetch one lab test composed with all of its children: `samples` and
  `resultParams` (each with its `referenceRanges` and `referenceValues`), plus
  `versionHistory`. 404 `LAB_TEST_NOT_FOUND` if missing, soft-deleted, or not in
  this master data / tenant. Uses `masterDataId` + `labTestId` from the earlier
  requests.

  Each result param also returns `criticalMin`/`criticalMax` (result-level) and
  `reflexTests: [{ id, name }]` — the JSON snapshot stored on create/update,
  returned verbatim.
}
