meta {
  name: Create Tenant
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/siteadmin/tenants
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{siteAdminToken}}
}

body:json {
  {
    "name": "For testing master data",
    "slug": "acme-diagnostics",
    "adminFirstName": "Alice",
    "adminLastName": "Admin",
    "adminPhone": "+919812345675",
    "adminEmail": "alice.admin5@acme.test",
    "email": "contact@acme.test",
    "phone": "+919800000000",
    "mrnPrefix": "AC",
    "address": {
      "line1": "12 Lab Street",
      "city": "Pune",
      "country": "IN"
    },
    "settings": {}
  }
}

vars:pre-request {
  siteAdminToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0eXBlIjoic2l0ZWFkbWluIiwic2l0ZWFkbWluX2lkIjoiMjM1ZmU0NjMtZTdiYS00Y2U4LTk4YmMtMzMwMzRiYWFmMmIyIiwiZW1haWwiOiJhZG1pbkBrYWxub3N0aWNzLmNvbSIsInJvbGUiOiJTVVBFUl9PV05FUiIsImlhdCI6MTc4MTEwOTI0OCwiZXhwIjoxNzgxMTM4MDQ4fQ.Y1q3YZYWxXDnMVeUkIdz8QFanXHDmId0FZ7eK494xrc
}

script:post-response {
  const data = res.getBody() && res.getBody().data;
  if (data) {
    if (data.id) bru.setEnvVar("tenantId", data.id);
    if (data.slug) bru.setEnvVar("tenantSlug", data.slug);
    // The first business-admin + one-time temp password are returned on create.
    const phone = data.adminPhone || (data.admin && data.admin.phone);
    const temp = data.tempPassword || (data.admin && data.admin.tempPassword);
    if (phone) bru.setEnvVar("adminPhone", phone);
    if (temp) bru.setEnvVar("adminTempPassword", temp);
  }
}

docs {
  Create a tenant (business) **and** its first business-admin user. Requires
  `business:create` (operations_admin and above).
  
  Returns the tenant plus a **one-time temp password** for the business-admin.
  The script captures `tenantId`, `tenantSlug`, `adminPhone`, and
  `adminTempPassword` — used by **Business Auth → Login**.
  
  - `slug`: lowercase alphanumeric + hyphens, not at start/end (subdomain).
  - `adminPhone`: globally-unique login identifier.
  - `mrnPrefix`: patient MRN prefix (e.g. "AC" -> "AC-00001").
  
  > If the captured temp password is empty, open the create response and copy
  > the temp password field into the `adminTempPassword` env var manually.
}
