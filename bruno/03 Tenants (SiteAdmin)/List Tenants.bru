meta {
  name: List Tenants
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/siteadmin/tenants?page=1&limit=20
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  ~search: acme
  ~status: ACTIVE
}

auth:bearer {
  token: {{siteAdminToken}}
}

vars:pre-request {
  siteAdminToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0eXBlIjoic2l0ZWFkbWluIiwic2l0ZWFkbWluX2lkIjoiMjM1ZmU0NjMtZTdiYS00Y2U4LTk4YmMtMzMwMzRiYWFmMmIyIiwiZW1haWwiOiJhZG1pbkBrYWxub3N0aWNzLmNvbSIsInJvbGUiOiJTVVBFUl9PV05FUiIsImlhdCI6MTc4MTEwOTA3OCwiZXhwIjoxNzgxMTM3ODc4fQ.ZVrV4BtqUSpVTIaE1PGht4xOA9gLmge4ZOsM-NRKIQE
}

docs {
  Paginated list of all tenants. Requires `business:read`. All query params
  optional; pagination info is returned in `meta`.

  - `page` (>=1) / `limit` (1-100) — offset pagination (defaults 1 / 20).
  - `search` — case-insensitive substring matched against name / slug / email.
  - `status` — exact `SubscriptionStatus` (accepted case-insensitively):
    `TRIALING` | `ACTIVE` | `GRACE_PERIOD` | `SUSPENDED` | `CANCELLED`.
}
