meta {
  name: List Schedules
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/branches/{{branchId}}/schedules?page=1&limit=20
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  ~search: Morning
  ~status: ACTIVE
}

auth:bearer {
  token: {{businessAccessToken}}
}

vars:pre-request {
  businessAccessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..3Ewemhs9iKWhkM-0Xn-s3je4jwUtpGkUDNyBZ6aHGZc
  branchId: 0b866440-7552-4589-a867-161f3db63420
}

docs {
  Paginated list of schedules for the branch in the URL (scoped to the caller's
  tenant). `page`/`limit` optional. Ordered by `effectiveFrom` descending.

  Optional filters (disabled query params above — enable as needed):
  - `search` — case-insensitive match against the schedule `planName`.
    Whitespace-only values are ignored.
  - `status` — lifecycle state. Allowed values: `ACTIVE`, `INACTIVE`, `DRAFT`.
}
