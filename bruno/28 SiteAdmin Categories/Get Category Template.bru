meta {
  name: Get Category Template
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/siteadmin/categories/{{siteAdminCategoryTemplateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{siteAdminToken}}
}

docs {
  Fetch one SITE_ADMIN category template by id. Auth: SiteAdmin token, requires
  `master-data:read`. 404 `CATEGORY_NOT_FOUND` if missing, soft-deleted, or not a
  template.
}
