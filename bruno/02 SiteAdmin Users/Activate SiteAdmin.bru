meta {
  name: Activate SiteAdmin
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/siteadmin/users/{{siteAdminUserId}}/activate
  body: none
  auth: bearer
}

auth:bearer {
  token: {{siteAdminToken}}
}

docs {
  Activate a (previously deactivated) SiteAdmin account. Requires
  `siteadmin:manage` (super_owner). The super_owner account cannot be toggled.
}
