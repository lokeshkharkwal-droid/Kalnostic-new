meta {
  name: Change SiteAdmin Password
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/siteadmin/users/{{siteAdminUserId}}/password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{siteAdminToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "newPassword": "NewOpsPass123"
  }
}

docs {
  Change a SiteAdmin's password. Requires `siteadmin:manage` (super_owner).
  Password policy: min 8 chars, >=1 uppercase, >=1 digit.
}
