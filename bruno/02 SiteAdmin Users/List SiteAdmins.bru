meta {
  name: List SiteAdmins
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/siteadmin/users?page=1&limit=20
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 20
  ~search: luke
  ~status: active
  ~role: OPERATIONS_ADMIN
}

auth:bearer {
  token: {{siteAdminToken}}
}

vars:pre-request {
  siteAdminToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0eXBlIjoic2l0ZWFkbWluIiwic2l0ZWFkbWluX2lkIjoiMjM1ZmU0NjMtZTdiYS00Y2U4LTk4YmMtMzMwMzRiYWFmMmIyIiwiZW1haWwiOiJhZG1pbkBrYWxub3N0aWNzLmNvbSIsInJvbGUiOiJTVVBFUl9PV05FUiIsImlhdCI6MTc4MDkxNzU3MywiZXhwIjoxNzgwOTQ2MzczfQ.MfMWYmrhqLI2hlgMwQkz-y_wcG2i4aiLinvTrDuXdCY
}

docs {
  Paginated list of SiteAdmin accounts. Requires `siteadmin:manage`
  (super_owner). All query params optional; pagination info is in `meta`.

  - `page` (>=1) / `limit` (1-100) — offset pagination (defaults 1 / 20).
  - `search` — case-insensitive substring matched against firstName /
    lastName / email.
  - `status` — `active` | `inactive` (maps to the `isActive` boolean).
  - `role` — exact `SiteAdminRole` (accepted case-insensitively):
    `CONTENT_ADMIN` | `OPERATIONS_ADMIN` | `FULL_ADMIN` | `SUPER_OWNER`.
}
