meta {
  name: Delete PDF Report Template
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/siteadmin/pdf-report-templates/{{siteAdminPdfReportTemplateId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{siteAdminToken}}
}

docs {
  Soft-delete a global SITE_ADMIN PDF report template (sets `deletedAt`; the row
  is preserved). Auth: SiteAdmin token, requires `master-data:write`. 404 if
  missing or already soft-deleted.
}
