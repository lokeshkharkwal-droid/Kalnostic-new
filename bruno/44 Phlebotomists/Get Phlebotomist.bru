meta {
  name: Get Phlebotomist
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/phlebotomists/{{phlebotomistId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{businessAccessToken}}
}

docs {
  Fetch one phlebotomist by id (scoped to the caller's tenant). 404
  `PHLEBOTOMIST_NOT_FOUND` if missing, soft-deleted, or owned by another tenant.
}
