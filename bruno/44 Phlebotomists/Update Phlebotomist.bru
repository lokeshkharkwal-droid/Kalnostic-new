}

auth:bearer {
  token: {{businessAccessToken}}
}

body:json {
  {
    "designation": "Lead Phlebotomist"
  }
}

tests {
  test("200 OK", function () {
    expect(res.getStatus()).to.equal(200);
  });
}

docs {
  Update a phlebotomist (scoped to the caller's tenant). All fields optional.
