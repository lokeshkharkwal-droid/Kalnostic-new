  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
  UNKNOWN
}

enum SiteAdminRole {
  CONTENT_ADMIN
  OPERATIONS_ADMIN
  FULL_ADMIN
  SUPER_OWNER
}

