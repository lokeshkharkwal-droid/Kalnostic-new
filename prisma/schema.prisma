enum SupportStatus {
  ACTIVE
  INACTIVE
}

/// The position a person holds within a department.
enum DepartmentPosition {
  HOD
  SPECIALIST
  CONSULTANT
  MANAGER
  TECHNICIAN
}

/// Whether a category stands alone or hangs off a department.
enum CategoryType {
