/// SiteAdmin-authored support/help information (platform-level, CLAUDE.md §4.2 —
/// no tenant_id, no RLS; it sits above the tenant boundary and is shared across
/// all businesses). `helpContent` stores the full HTML body. `title` is globally
/// unique among ACTIVE rows (partial unique index in prisma/rls.sql). `code` is
/// user-supplied and NOT unique. `tenantType` tags whether the content targets
/// business-level or branch-level screens. `createdBy`/`updatedBy` hold the
/// authoring SiteAdmin id (SiteAdmin routes are not covered by the business
/// AuditInterceptor, so authorship is tracked on the row instead).
model SupportInfo {
  id String @id @default(uuid())

  metaType    String            @map("meta_type")
  code        String?
  title       String
  tenantType  SupportTenantType @map("tenant_type")
  status      SupportStatus     @default(ACTIVE)
  requestUrl  String?           @map("request_url")
  helpContent String            @map("help_content")

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([metaType])
  @@index([code])
  @@index([status])
  @@index([deletedAt])
  @@map("support_infos")
}

/// A "Contact Us" form submission from the public marketing site. Platform-level
/// (CLAUDE.md §4.2 — no tenant_id, no RLS; it sits above the tenant boundary as a
/// global lead inbox). Captured unauthenticated via the public `POST /contact-us`
/// and reviewed by SiteAdmin. `companyName` is surfaced as "organization" in the
/// listing API. Submissions are anonymous, so there is no `createdBy`.
model ContactSubmission {
  id           String @id @default(uuid())
  name         String
  mobileNumber String @map("mobile_number")
  companyName  String @map("company_name")
  email        String
  message      String @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_submissions")
}

/// A patient registered by a tenant. Tenant-scoped (RLS) and branch-level:
/// `branchId` records the branch where the patient was registered (nullable),
/// while the patient remains visible tenant-wide. Only `firstName` and `mobile`
/// are required; everything else is optional. Per-tenant uniqueness on `mobile`
/// among active rows is enforced by a partial unique index in prisma/rls.sql.
model Patient {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  // ── Identity ──
  salutation   Salutation?
  firstName    String        @map("first_name")
  middleName   String?       @map("middle_name")
  lastName     String?       @map("last_name")
  gender       Gender?
  bloodGroup   BloodGroup?   @map("blood_group")
  relationship Relationship?
  dateOfBirth  DateTime?     @map("date_of_birth") @db.Date
  age          Int?
  ageType      AgeType?      @map("age_type")

  // ── Contact ──
  mobile                String // required
  whatsappNumber        String? @map("whatsapp_number")
  email                 String?
  alternateEmail        String? @map("alternate_email")
  alternateMobileNumber String? @map("alternate_mobile_number")

  // ── Address ──
  country      String?
  addressLine1 String? @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  area         String?
  city         String?
  state        String?
  pincode      String?

  // ── Privilege / category ──
  hasPrivilegeCard Boolean          @default(false) @map("has_privilege_card")
  privilegeNumber  String?          @map("privilege_number")
  patientCategory  PatientCategory? @map("patient_category")
  maritalStatus    MaritalStatus?   @map("marital_status")

  // ── Identity documents ──
  umId           String? @map("um_id")
  aadhaarNumber  String? @map("aadhaar_number")
  panNumber      String? @map("pan_number")
  passportNumber String? @map("passport_number")

  // ── Guardian ──
  guardianName         String?       @map("guardian_name")
  guardianRelationship Relationship? @map("guardian_relationship")
  guardianEmail        String?       @map("guardian_email")
  guardianMobileNumber String?       @map("guardian_mobile_number")

  // ── Emergency contact ──
  emergencyContactName         String? @map("emergency_contact_name")
  emergencyContactMobileNumber String? @map("emergency_contact_mobile_number")

  // ── Lifecycle ──
  status   PatientStatus @default(CREATED)
  isActive Boolean       @default(true) @map("is_active")

  // One-to-many: a patient can have multiple medical-history records.
  medicalHistories MedicalHistory[]

  // Orders placed for this patient.
  orders Order[]

  // Family links: rows where this patient is the anchor / the linked member.
  familyLinks    PatientFamilyLink[] @relation("FamilyAnchor")
  familyMemberOf PatientFamilyLink[] @relation("FamilyMember")

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("patients")
}

/// Directional family relationship between two patients within a tenant. Each
/// family member is an independent `Patient`; this mapping row links an anchor
/// patient to a member patient with a `relationship`. Tenant-scoped (RLS) and
/// branch-aware; soft-deleted (`deletedAt`) to unlink without touching either
/// patient record.
model PatientFamilyLink {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  patientId    String       @map("patient_id") // anchor patient
  memberId     String       @map("member_id") // linked (family member) patient
  relationship Relationship

  patient Patient @relation("FamilyAnchor", fields: [patientId], references: [id])
  member  Patient @relation("FamilyMember", fields: [memberId], references: [id])

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([patientId])
  @@index([memberId])
  @@map("patient_family_links")
}

/// A medical-history record for a patient (one-to-many). Tenant-scoped (RLS) and
/// branch-level. All clinical flags are booleans defaulting to false; free-text
/// notes (`otherMedications`, `surgicalHistory`, `remarks`) are optional.
model MedicalHistory {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  branchId  String? @map("branch_id")
  patientId String  @map("patient_id")

  patient Patient @relation(fields: [patientId], references: [id])

  // ── Smoking & alcohol status ──
  isCurrentSmoker    Boolean @default(false) @map("is_current_smoker")
  isFormerSmoker     Boolean @default(false) @map("is_former_smoker")
  isCurrentAlcoholic Boolean @default(false) @map("is_current_alcoholic")
  isFormerAlcoholic  Boolean @default(false) @map("is_former_alcoholic")

  // ── Symptoms ──
  hasCough             Boolean @default(false) @map("has_cough")
  hasFever             Boolean @default(false) @map("has_fever")
  hasShortnessOfBreath Boolean @default(false) @map("has_shortness_of_breath")
  hasChestPain         Boolean @default(false) @map("has_chest_pain")
  hasAbdominalPain     Boolean @default(false) @map("has_abdominal_pain")
  hasHeadache          Boolean @default(false) @map("has_headache")
  hasVomiting          Boolean @default(false) @map("has_vomiting")
  hasDiarrhea          Boolean @default(false) @map("has_diarrhea")
  hasFatigue           Boolean @default(false) @map("has_fatigue")
  hasWeightLoss        Boolean @default(false) @map("has_weight_loss")
  hasBodyPains         Boolean @default(false) @map("has_body_pains")
  hasDizziness         Boolean @default(false) @map("has_dizziness")

  // ── Medical conditions ──
  hasDiabetes       Boolean @default(false) @map("has_diabetes")
  hasHypertension   Boolean @default(false) @map("has_hypertension")
  hasCardiacDisease Boolean @default(false) @map("has_cardiac_disease")
  hasThyroidDisease Boolean @default(false) @map("has_thyroid_disease")
  hasKidneyDisease  Boolean @default(false) @map("has_kidney_disease")

  // ── Medications ──
  hasAntiDiabeticDrugs     Boolean @default(false) @map("has_anti_diabetic_drugs")
  hasAntiHypertensionDrugs Boolean @default(false) @map("has_anti_hypertension_drugs")
  hasBloodThinners         Boolean @default(false) @map("has_blood_thinners")
  hasVitaminSupplements    Boolean @default(false) @map("has_vitamin_supplements")
  otherMedications         String? @map("other_medications")

  // ── Allergies ──
  hasLatexAllergy Boolean @default(false) @map("has_latex_allergy")
  hasFoodAllergy  Boolean @default(false) @map("has_food_allergy")
  hasDrugAllergy  Boolean @default(false) @map("has_drug_allergy")

  // ── Additional information ──
  surgicalHistory String? @map("surgical_history")
  remarks         String?

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([patientId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("medical_histories")
}

// ── Order Management ────────────────────────────────────────────────────────────

/// Lifecycle stage of an order (Draft → Quote → Appointment → Order). CANCELLED is
/// a terminal state set from the billing page (no refund handling this phase).
enum OrderStatus {
  DRAFT
  QUOTE
  APPOINTMENT
  ORDER
  CANCELLED
}

/// Lifecycle of a quotation (an order with `status = QUOTE`). `DRAFT` is an open
/// quote; `CONVERTED` is stored when a quote becomes an order (no convert flow
/// yet — reserved); `EXPIRED` is derived at query time when `quotationValidTill`
/// has passed, and may also be stored explicitly.
enum QuotationStatus {
  DRAFT
  CONVERTED
  EXPIRED
}

/// Channel the order originated from.
enum OrderType {
  WALK_IN
  APP
  WEBSITE
}

/// Derived payment status of an order, computed from its payment ledger
/// (sum of `paidAmount` vs `netAmount` across active PaymentDetails rows).
/// Stored on `Order` so the orders/appointments lists can filter + paginate by
/// it server-side; recomputed whenever payments change.
enum PaymentStatus {
  NOT_PAID
  PARTIALLY_PAID
  PAID
}

/// How the order is billed.
enum BillingType {
  CASH_CLIENT
  INSURANCE
  CORPORATE
  GOVERNMENT_SCHEME
  TPA
}

/// Where the diagnostic sample comes from.
enum SampleSource {
  IN_HOUSE
  SUPPLIED
}

/// OPD consultation type.
enum ConsultantType {
  INITIAL
  FIRST
  FOLLOW_UP
}

/// OPD visit type.
enum OpdVisitType {
  WALK_IN
  TELECONSULTATION
  HOME_VISIT
}

/// Mode a payment was made in.
enum PaymentMode {
  CASH
  CREDIT
  UPI
  CARD
  WALLET
  BANK_TRANSFER
}

/// B2B client billing type on an order.
enum B2bClientType {
  CASH
  CREDIT
  WALLET
}

/// Which service section an order-level appointment was created for. Currently
/// only DIAGNOSTIC is produced by the create/appointment flow; OPD/RADIOLOGY are
/// reserved for when their appointment flows are implemented.
enum AppointmentType {
  DIAGNOSTIC
  OPD
  RADIOLOGY
}

/// Lifecycle status of an appointment. Held as the CURRENT status on
/// `Appointment` and appended to `AppointmentStatusHistory` on every change so a
/// full update history is preserved.
enum AppointmentStatus {
  NEW
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

/// The central order record a lab/clinic creates for a patient. Tenant-scoped
/// (RLS) + branch-level (CLAUDE.md §4.5). Carries basic billing info plus up to
/// three optional 1:1 service sections (diagnostics / OPD / radiology), a set of
/// selected catalogue items (`OrderItem` junction), and a payment ledger
/// (`PaymentDetails`). `orderCode` is a per-tenant sequential value
/// (`ORD-00001`…) generated from `Tenant.orderCounter`, unique per tenant among
/// active rows (partial unique index in prisma/rls.sql).
model Order {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Identity & basic info
  orderCode       String      @map("order_code")
  // Per-tenant sequential bill id for a diagnostic order (DIG-001…), generated
  // from Tenant.diagnosticBillCounter at creation. Null for non-diagnostic orders.
  billId          String?     @map("bill_id")
  status          OrderStatus @default(DRAFT)
  orderDate       DateTime    @map("order_date") @db.Date
  orderType       OrderType   @map("order_type")
  billingType     BillingType @map("billing_type")
  isUrgentBill    Boolean     @default(false) @map("is_urgent_bill")
  isBillGenerated Boolean     @default(false) @map("is_bill_generated")
  orderNotes      String?     @map("order_notes")

  // Order time-of-day ("HH:mm"), captured separately from the DATE-only
  // `orderDate` so the form's Order Time field round-trips on edit.
  orderTime String? @map("order_time")

  // Billing-type-specific sub-form (insurance / corporate / govt-scheme / TPA
  // details), stored as-is so the whole billing sub-section round-trips on edit.
  // Shape mirrors the FE `useOrderMeta` billing fields (see BillingDetailsDto).
  billingDetails Json? @map("billing_details")

  // Derived from the payment ledger (recomputed on every payment write). Stored
  // so the orders/appointments lists can filter + paginate by payment status
  // server-side (a summed comparison Prisma can't express in a `where`).
  paymentStatus PaymentStatus @default(NOT_PAID) @map("payment_status")

  // Quotation lifecycle (only meaningful when status = QUOTE). EXPIRED is also
  // derived at query time from quotationValidTill.
  quotationStatus    QuotationStatus? @map("quotation_status")
  quotationValidTill DateTime?        @map("quotation_valid_till") @db.Date

  // Patient (required) + appointment. `appointmentType` is server-derived when an
  // order is saved with status = APPOINTMENT (see OrderService) from whichever
  // service section is present (DIAGNOSTIC / OPD / RADIOLOGY).
  patientId       String           @map("patient_id")
  patient         Patient          @relation(fields: [patientId], references: [id])
  appointmentAt   DateTime?        @map("appointment_at")
  appointmentType AppointmentType? @map("appointment_type")

  // Lifecycle link (1:1) — set when the order is saved with status = APPOINTMENT.
  // The linked `Appointment` carries the lifecycle status (NEW → CONFIRMED → …)
  // and its append-only status history. Nullable: DRAFT/QUOTE/ORDER rows have none.
  appointmentId String?      @unique @map("appointment_id")
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  // Referral & B2B billing (all optional)
  referredByDoctorId String?         @map("referred_by_doctor_id")
  referredByDoctor   ReferralDoctor? @relation(fields: [referredByDoctorId], references: [id])

  referralPanelId String?        @map("referral_panel_id")
  referralPanel   ReferralPanel? @relation(fields: [referralPanelId], references: [id])

  b2bClient B2bClientType? @map("b2b_client")

  internalReferralId String?           @map("internal_referral_id")
  internalReferral   InternalReferral? @relation(fields: [internalReferralId], references: [id])

  externalReferralId String?           @map("external_referral_id")
  externalReferral   ExternalReferral? @relation(fields: [externalReferralId], references: [id])

  // Sections & children
  items       OrderItem[]
  diagnostics OrderDiagnostics?
  opd         OrderOpd?
  radiology   OrderRadiology?
  payments    PaymentDetails[]

  // Accession samples generated for this order (one per required sample/tube).
  accessionSamples AccessionSample[]

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([patientId])
  @@index([status])
  @@index([quotationStatus])
  @@index([referredByDoctorId])
  @@index([referralPanelId])
  @@index([internalReferralId])
  @@index([externalReferralId])
  @@index([appointmentId])
  @@index([paymentStatus])
  @@index([billId])
  @@index([deletedAt])
  @@map("orders")
}

/// Junction linking an order to its selected catalogue entries, so one order can
/// hold any combination of multiple branch lab tests and panels. Exactly one of
/// `branchLabTestId` / `branchLabPanelId` / `direct` is set per row (a catalogue
/// test, a catalogue panel, or a free-text direct entry) — enforced in
/// OrderService + a CHECK constraint in prisma/rls.sql. Tenant-scoped +
/// branch-level.
model OrderItem {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  branchLabTestId  String?         @map("branch_lab_test_id")
  branchLabTest    BranchLabTest?  @relation(fields: [branchLabTestId], references: [id])
  branchLabPanelId String?         @map("branch_lab_panel_id")
  branchLabPanel   BranchLabPanel? @relation(fields: [branchLabPanelId], references: [id])

  /// Free-text catalogue entry passed directly from the frontend (mutually
  /// exclusive with the test/panel refs).
  direct String?

  /// Per-line discount in minor units (0 = none). Captured at order/quotation
  /// time so item-level discounts round-trip on edit; the order-level aggregate
  /// still lives on PaymentDetails.orderDiscount for list rollups.
  discount Int @default(0) @map("discount")

  /// Sample collection tracking. `collectedAt` NULL = not collected yet; once set
  /// the sample is considered collected (`collectedBy` records the acting person).
  collectedAt DateTime? @map("collected_at")
  collectedBy String?   @map("collected_by")

  // Accession sample links (which generated sample/tube carries this order item).
  accessionSampleTests AccessionSampleTest[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([orderId])
  @@index([branchLabTestId])
  @@index([branchLabPanelId])
  @@index([deletedAt])
  @@map("order_items")
}

/// The Diagnostics section of an order (1:1). Tenant-scoped + branch-level.
model OrderDiagnostics {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  prescriptionUrl String? @map("prescription_url")

  diagnosticPanelId String?   @map("diagnostic_panel_id")
  diagnosticPanel   LabPanel? @relation(fields: [diagnosticPanelId], references: [id])

  sampleSource            SampleSource @default(IN_HOUSE) @map("sample_source")
  sampleCollectionCharges Int          @default(0) @map("sample_collection_charges")
  logisticsSuppliedBy     String?      @map("logistics_supplied_by")
  isFasting               Boolean      @default(false) @map("is_fasting")
  isHomeVisit             Boolean      @default(false) @map("is_home_visit")
  collectionAddress       String?      @map("collection_address")

  phlebotomistId String? @map("phlebotomist_id")
  phlebotomist   Person? @relation("OrderPhlebotomist", fields: [phlebotomistId], references: [id])

  visitCharges  Int       @default(0) @map("visit_charges")
  collectionAt  DateTime? @map("collection_at")
  appointmentAt DateTime? @map("appointment_at")
  geoLocation   String?   @map("geo_location")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([diagnosticPanelId])
  @@index([phlebotomistId])
  @@index([deletedAt])
  @@map("order_diagnostics")
}

/// The OPD section of an order (1:1). `doctorId` references a CONSULTANT doctor
/// (validated in OrderService). Tenant-scoped + branch-level.
model OrderOpd {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  doctorId String @map("doctor_id")
  doctor   Doctor @relation(fields: [doctorId], references: [id])

  consultantType ConsultantType? @map("consultant_type")
  visitType      OpdVisitType?   @map("visit_type")
  consultationAt DateTime?       @map("consultation_at")
  appointmentAt  DateTime?       @map("appointment_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([doctorId])
  @@index([deletedAt])
  @@map("order_opd")
}

/// The Radiology section of an order (1:1). References the radiologist (a staff
/// `Person`), a department, and a radiology technician (a `Person`).
/// Tenant-scoped + branch-level.
model OrderRadiology {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  radiologistId String @map("radiologist_id")
  radiologist   Person @relation("OrderRadiologist", fields: [radiologistId], references: [id])

  radiologistDepartmentId String?     @map("radiologist_department_id")
  radiologistDepartment   Department? @relation(fields: [radiologistDepartmentId], references: [id])

  radiologistCategoryId String?   @map("radiologist_category_id")
  radiologistCategory   Category? @relation(fields: [radiologistCategoryId], references: [id])

  radiologyTechnicianId String? @map("radiology_technician_id")
  radiologyTechnician   Person? @relation("OrderRadiologyTechnician", fields: [radiologyTechnicianId], references: [id])

  appointmentAt DateTime? @map("appointment_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([radiologistId])
  @@index([radiologistDepartmentId])
  @@index([radiologistCategoryId])
  @@index([radiologyTechnicianId])
  @@index([deletedAt])
  @@map("order_radiology")
}

/// Per-branch customization of which fields show on the Create Order form.
/// One config per branch (`config` is the `{ section: { field: boolean } }` map
/// the frontend's "Customize Fields" drawer manages). Tenant-scoped + branch-level.
model OrderFieldConfig {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  config Json @default("{}")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, branchId])
  @@index([tenantId])
  @@index([branchId])
  @@map("order_field_configs")
}

/// A payment/ledger entry against an order (1:many). Amounts are integer minor
/// units. Wallet/Points/Previous-Dues columns exist per spec but are NOT computed
/// this phase (deferred). Tenant-scoped + branch-level.
model PaymentDetails {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  totalAmount            Int         @default(0) @map("total_amount")
  orderDiscount          Int         @default(0) @map("order_discount")
  visitingCharges        Int         @default(0) @map("visiting_charges")
  netAmount              Int         @default(0) @map("net_amount")
  deductFromWallet       Int         @default(0) @map("deduct_from_wallet")
  deductFromPoints       Int         @default(0) @map("deduct_from_points")
  hasClearedPreviousDues Boolean     @default(false) @map("has_cleared_previous_dues")
  tdsDeduction           Int         @default(0) @map("tds_deduction")
  payableAmount          Int         @default(0) @map("payable_amount")
  paidAmount             Int         @default(0) @map("paid_amount")
  remainingBalance       Int         @default(0) @map("remaining_balance")
  paymentMode            PaymentMode @default(CASH) @map("payment_mode")
  paymentDate            DateTime?   @map("payment_date")
  reference              String?     @map("reference")
  notes                  String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([orderId])
  @@index([deletedAt])
  @@map("payment_details")
}

// ── Appointment Status Tracking ─────────────────────────────────────────────────

/// Tracks the current status of an appointment. Tenant-scoped (RLS) + branch-level
/// (CLAUDE.md §4.5) — an appointment happens at a location, so `branchId` is set
/// from the active-branch context (nullable for tenant-level rows). `code` is a
/// per-tenant sequential value (`APT-00001`…) generated from
/// `Tenant.appointmentCounter`, unique per tenant among active rows (partial
/// unique index in prisma/rls.sql). `status` holds the CURRENT lifecycle stage;
/// every change is appended to `AppointmentStatusHistory` so the update history is
/// preserved. Linked 1:1 to the `Order` that owns it (the FK lives on `Order`);
/// created when an order is saved with `status = APPOINTMENT`. `updatedBy` records
/// the person who last changed the record. RLS policy in prisma/rls.sql.
model Appointment {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  code            String            @map("code")
  appointmentType AppointmentType   @map("appointment_type")
  status          AppointmentStatus @default(NEW)

  statusHistory AppointmentStatusHistory[]

  /// Back-relation to the order that owns this appointment (1:1). Set when an
  /// order is saved with status = APPOINTMENT; the FK lives on `Order`.
  order Order?

  createdBy String? @map("created_by") // person who created the record
  updatedBy String? @map("updated_by") // person who last updated the record

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([appointmentType])
  @@index([deletedAt])
  @@map("appointments")
}

/// Append-only history of appointment status changes — one row per change, never
/// mutated. Written alongside every update to `Appointment.status` (and the
/// initial status on create) so the full audit trail of an appointment's
/// lifecycle is preserved. Tenant-scoped (RLS) + branch-level, mirroring its
/// parent. `changedBy` records the person who made the change. RLS policy in
/// prisma/rls.sql.
model AppointmentStatusHistory {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  appointmentId String      @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  status    AppointmentStatus
  notes     String? // optional reason/context for this status change
  changedBy String?           @map("changed_by") // person who made this change

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([appointmentId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("appointment_status_history")
}

// ── Accession Module ────────────────────────────────────────────────────────────

/// Lifecycle status of an accession sample/tube (PDF §A.5). Held as the CURRENT
/// status on `AccessionSample`; every change is appended to
/// `AccessionStatusHistory`. `previousStatus` supports the universal Retrieve/undo
/// action (PDF §A.10.19). Reason/condition/tube dropdowns are tenant-configurable
/// strings (PDF §G) — only the status set itself is a hard enum.
enum SampleStatus {
  NEW
  COLLECTED
  ACCEPTED
  ACQUIRED
  HALT
  ERROR
  HOLD
  REPEAT
  SENT_INTERNAL
  FORWARD_EXTERNAL
  STORED
  DISCARDED
  RETURNED
  CANCELLED
  OUTSOURCED
}

/// Kind of sample transfer (PDF Parts B/C/D). INTERNAL = branch↔branch within the
/// tenant; EXTERNAL = to a Kalnostic partner lab (another tenant); OUTSOURCE = to a
/// third-party `OutsourceCenter`.
enum TransferKind {
  INTERNAL
  EXTERNAL
  OUTSOURCE
}

/// Lifecycle status of a `SampleTransfer` (PDF §B.5).
enum TransferStatus {
  IN_TRANSIT
  PICKED_UP
  RECEIVED
  ACCEPTED
  REPEAT
  REJECTED
}

/// The core accession entity — one row per required sample/tube of an order (one
/// accession list row = one sample). Tenant-scoped (RLS) + branch-level
/// (CLAUDE.md §4.5/§4.7). Generated when a diagnostic order reaches
/// `status ∈ {ORDER, APPOINTMENT}` (see AccessionSampleService.generateForOrderInTx):
/// the order's items are grouped by required sample from
/// `BranchLabTest.configSnapshot.samples`, one sample per group. `accessionNo`
/// (`ACC-00001`…) is a per-tenant sequential value from `Tenant.accessionCounter`,
/// unique per tenant among active rows (partial unique index in prisma/rls.sql).
/// `barcode` (`BAR-00001-A`…) is nullable until assigned (unique per tenant among
/// active rows). `status` holds the CURRENT lifecycle stage; `previousStatus`
/// backs the universal Retrieve/undo. `reportStatus` is display-only here (the
/// Finance/Reports module owns report creation). Branch ids (`originBranchId`/
/// `processingBranchId`) are logical refs validated in the service via
/// `BranchService.findById`. RLS policy in prisma/rls.sql.
model AccessionSample {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  accessionNo String  @map("accession_no")
  barcode     String? @map("barcode")

  // Sample identity (snapshotted from the source test's configSnapshot.samples).
  sampleType       String?        @map("sample_type")
  containerType    ContainerType? @map("container_type")
  sampleGroupLabel String?        @map("sample_group_label") // e.g. "EDTA ×2"

  status         SampleStatus   @default(NEW)
  previousStatus SampleStatus?  @map("previous_status") // for Retrieve/undo (PDF §A.10.19)
  priority       SamplePriority @default(ROUTINE)

  // Display-only; the Finance/Reports module owns actual report creation.
  reportStatus String? @map("report_status")

  // Collection (PDF §A.10.1)
  collectedAt DateTime? @map("collected_at")
  collectedBy String?   @map("collected_by")
  tubeType    String?   @map("tube_type")

  // Acceptance (PDF §A.10.x)
  receivedAt      DateTime? @map("received_at")
  acceptedAt      DateTime? @map("accepted_at")
  sampleCondition String?   @map("sample_condition")

  // Storage & logistics
  storeLocation   String?   @map("store_location")
  logisticsType   String?   @map("logistics_type")
  logisticsPerson String?   @map("logistics_person")
  dispatchedAt    DateTime? @map("dispatched_at")

  // Branch context (logical refs — validated in the service).
  originBranchId     String? @map("origin_branch_id")
  processingBranchId String? @map("processing_branch_id")

  tests         AccessionSampleTest[]
  statusHistory AccessionStatusHistory[]
  transfers     SampleTransfer[]

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([orderId])
  @@index([status])
  @@index([barcode])
  @@index([originBranchId])
  @@index([processingBranchId])
  @@index([deletedAt])
  @@map("accession_samples")
}

/// Junction linking an accession sample to the order items (tests) it carries, so
/// one sample/tube can hold several tests. Snapshots `testName` for the Sample
/// Overview "Test Details" table (PDF §A.10.4). Tenant-scoped + branch-level.
model AccessionSampleTest {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  sampleId String          @map("sample_id")
  sample   AccessionSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  testName String? @map("test_name") // snapshot for display

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([sampleId])
  @@index([orderItemId])
  @@index([deletedAt])
  @@map("accession_sample_tests")
}

/// Append-only history of accession sample status changes — one row per action,
/// never mutated (mirrors `AppointmentStatusHistory`). Powers the Sample History
/// panel (PDF §A.10.5). `attachmentUrl` stores a URL only (no upload endpoint —
/// plan decision #4). Tenant-scoped (RLS) + branch-level. RLS policy in
/// prisma/rls.sql.
model AccessionStatusHistory {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  sampleId String          @map("sample_id")
  sample   AccessionSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  action     String // the action that triggered this change (e.g. "collect")
  toStatus   SampleStatus  @map("to_status")
  fromStatus SampleStatus? @map("from_status")

  reason        String?
  notes         String?
  attachmentUrl String? @map("attachment_url")
  changedBy     String? @map("changed_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([sampleId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("accession_status_history")
}

/// A sample transfer/referral (PDF Parts B/C/D). Distinct from the commission
/// `InternalReferral`/`ExternalReferral` models (plan decision #2). `kind` selects
/// the destination: INTERNAL → `destinationBranchId` (nullable → "Assign Center");
/// EXTERNAL → partner lab (`externalPartnerRef`/`externalPartnerName`; cross-tenant
/// sync is an open decision resolved in Phase 3); OUTSOURCE → `outsourceCenterId`
/// (existing `OutsourceCenter` master). Branch ids are logical refs validated in
/// the service. Tenant-scoped (RLS) + branch-level. RLS policy in prisma/rls.sql.
model SampleTransfer {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  sampleId String          @map("sample_id")
  sample   AccessionSample @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  kind           TransferKind
  transferStatus TransferStatus @default(IN_TRANSIT) @map("transfer_status")

  // Destinations (exactly one meaningful per `kind`).
  originBranchId      String? @map("origin_branch_id")
  destinationBranchId String? @map("destination_branch_id") // INTERNAL
  outsourceCenterId   String? @map("outsource_center_id") // OUTSOURCE (logical ref)
  externalPartnerRef  String? @map("external_partner_ref") // EXTERNAL
  externalPartnerName String? @map("external_partner_name") // EXTERNAL

  // Dispatch
  sendDate        DateTime? @map("send_date")
  sendTime        String?   @map("send_time") // "HH:mm"
  sampleForm      String?   @map("sample_form")
  logisticsType   String?   @map("logistics_type")
  logisticsPerson String?   @map("logistics_person")

  // Receipt / acceptance
  pickedUpBy       String?   @map("picked_up_by")
  pickedUpAt       DateTime? @map("picked_up_at")
  receivedAt       DateTime? @map("received_at")
  receiveCondition String?   @map("receive_condition")
  acceptedAt       DateTime? @map("accepted_at")
  rejectionReason  String?   @map("rejection_reason")
  repeatReason     String?   @map("repeat_reason")

  // Manual outsource tracking (PDF §D.3 / CR-3 — no sync).
  outsourceStatus String? @map("outsource_status")

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([sampleId])
  @@index([kind])
  @@index([transferStatus])
  @@index([destinationBranchId])
  @@index([outsourceCenterId])
  @@index([deletedAt])
  @@map("sample_transfers")
}

/// Per-branch configurable accession dropdowns/thresholds (PDF §G). Mirrors
/// `OrderFieldConfig`: one row per branch (`@@unique([tenantId, branchId])`),
/// payload held as JSON (`AccessionSettingsMap`). Holds tube types, sample
/// conditions, repeat/rejection reasons, discard methods, logistics types,
/// notification templates and TAT thresholds. Read falls back to
/// `DEFAULT_ACCESSION_SETTINGS` when a branch has no row yet. Tenant-scoped +
/// branch-level. RLS policy in prisma/rls.sql.
model AccessionSetting {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  config Json @default("{}")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, branchId])
  @@index([tenantId])
  @@index([branchId])
  @@map("accession_settings")
}

/// Per-branch Registration › Appointment Settings (slot/capacity, working
/// hours, reminder toggles, no-show/cancellation rules). Mirrors
/// `AccessionSetting`: one row per branch (`@@unique([tenantId, branchId])`),
/// payload held as JSON (`AppointmentSettingsMap`). Read falls back to
/// `DEFAULT_APPOINTMENT_SETTINGS` when a branch has no row yet. Tenant-scoped +
/// branch-level. RLS policy in prisma/rls.sql.
model AppointmentSetting {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  config Json @default("{}")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, branchId])
  @@index([tenantId])
  @@index([branchId])
  @@map("appointment_settings")
}
