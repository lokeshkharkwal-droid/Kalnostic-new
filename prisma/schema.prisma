// ── Machine Management enums ─────────────────────────────────────────────────────

/// A machine's connectivity/operational state. Default OFFLINE.
enum MachineStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  ERROR
}

/// Severity/category of an adapter communication log line.
enum AdapterLogType {
  ERROR
  INFO
  WARNING
}

/// A lab machine/analyzer. Tenant-scoped, tenant-level (CLAUDE.md §4.6): a machine
/// is owned by the business and assigned to one-or-more branches via the
/// `MachineBranch` junction (it carries no `branchId` of its own). `departmentId`
/// is a logical ref to a Department in the tenant (no Prisma relation), validated
/// in MachineService.
model Machine {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  machineName  String        @map("machine_name")
  code         String?
  manufacturer String?
  model        String?
  serialNo     String?       @map("serial_no")
  departmentId String?       @map("department_id")
  status       MachineStatus @default(OFFLINE)

  lastCalibrationDate DateTime? @map("last_calibration_date")
  lastMaintenanceDate DateTime? @map("last_maintenance_date")
  nextCalibrationDate DateTime? @map("next_calibration_date")
  nextMaintenanceDue  DateTime? @map("next_maintenance_due")

  analyserImage String? @map("analyser_image")
  machineNotes  String? @map("machine_notes")

  interfaceType     String?  @map("interface_type")
  tokenNumber       String?  @map("token_number")
  connectionType    String?  @map("connection_type")
  hostPcIpAddress   String?  @map("host_pc_ip_address")
  analyserIpAddress String?  @map("analyser_ip_address")
  port              Int?
  isAdapterServer   Boolean? @map("is_adapter_server")
  adapterSupports   String[] @map("adapter_supports")
  referenceImages   String[] @map("reference_images")
  interfaceNote     String?  @map("interface_note")

  isBidirectionalInterface Boolean @default(false) @map("is_bidirectional_interface")
  isAutoValidateResults    Boolean @default(false) @map("is_auto_validate_results")
  isAutoFlagCritical       Boolean @default(false) @map("is_auto_flag_critical")

  interfaceConfigurationNotes String? @map("interface_configuration_notes")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([deletedAt])
  @@map("machines")
}

/// A reagent kit used by a machine (one machine → many kits). `machineId` is a
/// logical ref to a Machine in the tenant; cascade soft-delete is done in
/// MachineService (no DB-level ON DELETE CASCADE — CLAUDE.md §4.1).
model MachineReagentKit {
  id             String  @id @default(uuid())
  tenantId       String  @map("tenant_id")
  machineId      String  @map("machine_id")
  reagentKitName String  @map("reagent_kit_name")
  manufacturer   String
  details        String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([machineId])
  @@index([deletedAt])
  @@map("machine_reagent_kits")
}

/// A LIS↔analyzer test mapping for a machine (one machine → many mappings).
/// `isActive` enables/disables the mapping. `machineId` is a logical ref.
model MachineTestMapping {
  id            String  @id @default(uuid())
  tenantId      String  @map("tenant_id")
  machineId     String  @map("machine_id")
  lisCode       String  @map("lis_code")
  lisTestName   String  @map("lis_test_name")
  analyzerCode  String  @map("analyzer_code")
  analyzerName  String  @map("analyzer_name")
  unit          String?
  decimalPlaces Int     @default(2) @map("decimal_places")
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([machineId])
  @@index([deletedAt])
  @@map("machine_test_mappings")
}

/// An adapter communication log line for a machine (append-only; one machine →
/// many logs). `srNo` (a client-supplied running number) and `loggedAt` (the
/// device/event time, distinct from the DB `createdAt`) are both supplied by the
/// adapter/integration layer. `isViewed` tracks whether an operator has seen the
/// line. `sourceIp` is stored as text (Prisma has no native INET). `machineId` is
/// a logical ref.
model MachineAdapterLog {
  id        String          @id @default(uuid())
  tenantId  String          @map("tenant_id")
  machineId String          @map("machine_id")
  srNo      Int?            @map("sr_no")
  loggedAt  DateTime?       @map("logged_at")
  logType   AdapterLogType? @map("log_type")
  status    String?
  sourceIp  String?         @map("source_ip")
  isViewed  Boolean         @default(false) @map("is_viewed")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([machineId])
  @@index([deletedAt])
  @@map("machine_adapter_logs")
}

/// Junction mapping a machine to the branches it serves (many-to-many).
/// `branchId` arrives from the request body and is validated against the caller's
/// tenant via BranchService.findById (the §4.7 exception to "branchId from JWT").
/// One active row per (machine, branch) — partial unique index in prisma/rls.sql.
model MachineBranch {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  machineId String @map("machine_id")
  branchId  String @map("branch_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([machineId])
  @@index([branchId])
  @@map("machine_branches")
}

// ── Payment Rules (SiteAdmin, platform-level) ────────────────────────────────
// Commission/tax rules managed by SiteAdmin across all tenants. Platform-level
// (no `tenant_id` RLS policy — SiteAdmin operates cross-tenant, like
// `siteadmin_users`). `tenantId`/`branchId`/`contextType`/`contextId` are
// optional scope/target references stored as plain Int scalars (no FK relation).

/** The payment gateway / tax family a rule belongs to. */
enum PaymentRuleType {
  CITRUS_COMMISSION
  PAYU_COMMISSION
  PINELAB_COMMISSION
  EZ_COMMISSION
  PHARMACY_TAXES
}

/** How a rule's `calculationValue` is applied. */
enum PaymentCalculationType {
  FIXED
  PERCENT
  RULE
}

model PaymentRule {
  id String @id @default(uuid())

  ruleType    PaymentRuleType @map("rule_type")
  name        String
  code        String
  description String?

  // Optional scope/target references (Int per spec; NOT FK relations).
  tenantId Int? @map("tenant_id")
  branchId Int? @map("branch_id")

  rank        Int
  contextType Int? @map("context_type")
  contextId   Int? @map("context_id")

  class1 String? @map("class_1")
  class2 String? @map("class_2")

  calculationType  PaymentCalculationType @map("calculation_type")
  calculationValue String                 @map("calculation_value")

  taxType       String? @map("tax_type")
  taxPercentage Int?    @map("tax_percentage")

  effectivePeriodStartDate DateTime? @map("effective_period_start_date")
  effectivePeriodEndDate   DateTime? @map("effective_period_end_date")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([ruleType])
  @@index([tenantId])
  @@index([code])
  @@index([deletedAt])
  @@map("payment_rules")
}

