///   USER              → persons (platform Person)
///   CONSULTANT_DOCTOR → doctors (Doctor.doctorType = CONSULTANT)
///   REPORTING_DOCTOR  → doctors (Doctor.doctorType = REPORTING)
///   EXTERNAL_REFERRAL → external_referrals (ExternalReferral)
enum PersonMappingType {
  USER
  CONSULTANT_DOCTOR
  REPORTING_DOCTOR
  EXTERNAL_REFERRAL
}

enum ShiftName {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

/// Which functional area an audit event belongs to (the "Module" column).
enum AuditModule {
  USER
  BRANCH
  SCHEDULE
  TENANT
  DEPARTMENT
  CATEGORY
  SUB_CATEGORY
  MASTER_DATA
  LAB_TEST
  LAB_PANEL
  OUTSOURCE_CENTER
  DOCTOR
  REFERRAL_PANEL
  REFERRAL_PANEL_SETTINGS
  REFERRAL_DOCTOR
  EXTERNAL_REFERRAL
  INTERNAL_REFERRAL
  MACHINE
  DOCUMENT
  TEMPLATE
  PDF_REPORT_TEMPLATE
  AUTH
  SITEADMIN // reserved; not written to in this phase (business audit only)
  LAB_TEST_SETTINGS
}

/// Type of controlled document managed by the document module.
enum DocumentType {
  SOP
  POLICY
  FORM
  CERTIFICATE
  ACCREDITATION
  QC_DOCUMENT
  WORK_INSTRUCTION
  OTHER
}

