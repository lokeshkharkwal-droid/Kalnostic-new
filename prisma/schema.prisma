  directorMobile           String? @map("director_mobile")
  directorEmail            String? @map("director_email")
  accessionPersonName      String? @map("accession_person_name")
  accessionPersonMobile    String? @map("accession_person_mobile")
  accessionPersonEmail     String? @map("accession_person_email")
  registrationPersonName   String? @map("registration_person_name")
  registrationPersonMobile String? @map("registration_person_mobile")
  registrationPersonEmail  String? @map("registration_person_email")
  logisticsPersonName      String? @map("logistics_person_name")
  logisticsPersonMobile    String? @map("logistics_person_mobile")
  logisticsPersonEmail     String? @map("logistics_person_email")
  accountsPersonName       String? @map("accounts_person_name")
  accountsPersonMobile     String? @map("accounts_person_mobile")
  accountsPersonEmail      String? @map("accounts_person_email")

  // ── Commission & TDS ──
  isCommissionApplicable Boolean               @default(false) @map("is_commission_applicable")
  commissionType         CommissionType?       @map("commission_type")
  commissionPctLabTest   Decimal?              @map("commission_pct_lab_test") @db.Decimal(5, 2)
  commissionPctLabPanel  Decimal?              @map("commission_pct_lab_panel") @db.Decimal(5, 2)
  commissionSlabs        Json                  @default("[]") @map("commission_slabs")
  fixedCommissionCycle   FixedCommissionCycle? @map("fixed_commission_cycle")
  fixedAmount            Decimal?              @map("fixed_amount") @db.Decimal(10, 2)
  isTdsApplicable        Boolean               @default(false) @map("is_tds_applicable")
  tds                    Int?                  @map("tds")

  // ── Payment & incentive ──
  paymentCycle               PaymentCycle        @default(NA) @map("payment_cycle")
  paymentMode                ReferralPaymentMode @default(BANK_TRANSFER) @map("payment_mode")
  monthlyTargetAmount        Int                 @default(0) @map("monthly_target_amount")
  isIncentiveBonusApplicable Boolean             @default(false) @map("is_incentive_bonus_applicable")
  bonusSlabs                 Json                @default("[]") @map("bonus_slabs")

  // ── Attachment & remarks ──
  fileName String? @map("file_name")
  fileUrl  String? @map("file_url")
  remarks  String?

  labTests  ReferralPanelLabTest[]
  labPanels ReferralPanelLabPanel[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([referralPanelSettingsId])
  @@index([deletedAt])
  @@map("referral_panels")
