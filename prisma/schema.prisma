// Prisma schema for Kalnostics New.
//
// Conventions (CLAUDE.md §3 + §4):
//   - model = PascalCase singular; table = snake_case plural (@@map)
//   - columns = snake_case (@map)
//   - primary keys = Prisma-default UUID v4
//   - every model: created_at / updated_at / deleted_at (plain soft delete)
//
// Two tiers (CLAUDE.md §4.2):
//   - PLATFORM models (no tenant_id): Tenant, Person, PersonCredentials,
//     SiteAdminUser, RefreshToken, PersonTenantEnrollment
//   - TENANT-SCOPED models (tenant_id + RLS): Branch, UserBranchProfile,
//     UserProfilePermissionOverride, ReceptionistDoctorMapping,
//     TenantMainBranch, Schedule
//
// RLS policies for tenant-scoped tables live in prisma/rls.sql (CLAUDE.md §4.3).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  GRACE_PERIOD // payment overdue, still operational
  SUSPENDED // fully blocked
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
  UNKNOWN
}

enum SiteAdminRole {
  CONTENT_ADMIN
  OPERATIONS_ADMIN
  FULL_ADMIN
  SUPER_OWNER
}

enum BranchType {
  DIAGNOSTIC
  RADIOLOGY
  OPD
  IPD
  PHARMACY
  INVENTORY
  BLOOD_BANK
  FRANCHISE
  COMBINED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ScheduleStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum ShiftName {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

// ── Platform-level models (NO tenant_id) ────────────────────────────────────────

/// One row per registered business. "Business info" = the fields here.
model Tenant {
  id   String @id @default(uuid())
  name String

  /// URL-safe subdomain slug ({slug}.kalnostics.com). Unique, immutable after create.
  slug         String  @unique
  customDomain String? @unique @map("custom_domain")

  email   String? // primary contact email (billing/notifications)
  phone   String?
  address Json? // registered business address

  // ── Subscription ──
  subscriptionStatus SubscriptionStatus @default(TRIALING) @map("subscription_status")
  subscriptionPlanId String?            @map("subscription_plan_id")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  subscriptionEndsAt DateTime?          @map("subscription_ends_at")
  gracePeriodEndsAt  DateTime?          @map("grace_period_ends_at")

  // ── Locale & branding (timezone/currency/date_format/language/logo/colors) ──
  settings Json?

  isActive      Boolean @default(true) @map("is_active")
  mrnCounter    Int     @default(0) @map("mrn_counter") // per-tenant sequential patient MRN
  mrnPrefix     String? @map("mrn_prefix")
  branchCounter Int     @default(0) @map("branch_counter") // per-tenant sequential branch code
  createdBy     String? @map("created_by") // SiteAdmin user id

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("tenants")
}

/// Platform-level identity for ALL humans (patients AND staff). No tenant_id.
model Person {
  id String @id @default(uuid())

  /// Globally-unique Medical Record Number across all businesses. Read-only after creation.
  platformMrn String @unique @map("platform_mrn")

  salutation  String?
  firstName   String      @map("first_name")
  lastName    String?     @map("last_name")
  dateOfBirth DateTime?   @map("date_of_birth") @db.Date
  gender      Gender?
  bloodGroup  BloodGroup? @map("blood_group")

  /// Phone/email are global de-duplication keys; locked after first use.
  phone String? @unique
  email String? @unique

  address  Json?
  photoUrl String? @map("photo_url")
  idType   String? @map("id_type")
  idNumber String? @map("id_number") // encrypted at rest (deferred)

  /// First business to register this person owns their basic details. NULL = self-registered.
  ownerTenantId String? @map("owner_tenant_id")

  isPatient Boolean @default(false) @map("is_patient")
  isStaff   Boolean @default(false) @map("is_staff")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([ownerTenantId])
  @@index([deletedAt])
  @@map("persons")
}

/// Login credentials — one row per person.
model PersonCredentials {
  id       String @id @default(uuid())
  personId String @unique @map("person_id")

  // Login identifiers (precedence: phone → email → system_username)
  phone                     String?  @unique
  email                     String?  @unique
  systemUsername            String?  @unique @map("system_username")
  isSystemGeneratedUsername Boolean  @default(false) @map("is_system_generated_username")

  passwordHash   String  @map("password_hash") // bcrypt cost 12
  isTempPassword Boolean @default(false) @map("is_temp_password")

  // Security
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("person_credentials")
}

/// SiteAdmin users — separate auth system, separate table, separate JWT.
model SiteAdminUser {
  id           String        @id @default(uuid())
  firstName    String        @map("first_name")
  lastName     String?       @map("last_name")
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         SiteAdminRole @default(CONTENT_ADMIN)
  isActive     Boolean       @default(true) @map("is_active")

  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  createdBy      String?   @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("siteadmin_users")
}

/// Refresh tokens — server-side, single-use rotation, SHA-256 hashed at rest.
model RefreshToken {
  id         String  @id @default(uuid())
  personId   String  @map("person_id")
  tokenHash  String  @unique @map("token_hash")
  branchId   String? @map("branch_id")
  profileKey String? @map("profile_key")
  issuedToIp String? @map("issued_to_ip")
  userAgent  String? @map("user_agent")

  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  isRevoked Boolean  @default(false) @map("is_revoked")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([personId])
  @@map("refresh_tokens")
}

/// Cross-business patient linkage (each business keeps its own tenant_mrn).
model PersonTenantEnrollment {
  id        String  @id @default(uuid())
  personId  String  @map("person_id")
  tenantId  String  @map("tenant_id")
  branchId  String  @map("branch_id")
  tenantMrn String? @map("tenant_mrn")

  enrolledAt DateTime @default(now()) @map("enrolled_at")
  enrolledBy String?  @map("enrolled_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([personId, tenantId])
  @@map("person_tenant_enrollments")
}

// ── Tenant-scoped models (tenant_id + RLS) ──────────────────────────────────────

/// A physical location belonging to a tenant.
model Branch {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  name       String
  branchType BranchType @map("branch_type")
  // System-generated, immutable. Per-tenant sequential code (e.g. "BR-00001")
  // derived from Tenant.branchCounter. Unique per tenant among active rows
  // (partial unique index in prisma/rls.sql); never client-supplied.
  code       String

  status          BranchStatus @default(ACTIVE)
  establishedDate DateTime?    @map("established_date")

  // Location
  addressLine String? @map("address_line")
  city        String?
  state       String?
  pincode     String?

  // Contact
  phone        String?
  email        String?
  managerName  String? @map("manager_name")
  managerPhone String? @map("manager_phone")
  labDirector  String? @map("lab_director")

  // Operations
  openingTime     String?     @map("opening_time") // "HH:mm" (24h, branch-local)
  closingTime     String?     @map("closing_time") // "HH:mm" (24h, branch-local)
  dailyCapacity   Int?        @map("daily_capacity") // max orders processable per day
  operationalDays DayOfWeek[] @map("operational_days")

  // Compliance / misc
  gstNo     String? @map("gst_no")
  licenseNo String? @map("license_no")
  remarks   String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([deletedAt])
  @@map("branches")
}

/// Assigns a person a profile (role) at a branch (or tenant-level when branch is null).
model UserBranchProfile {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  personId   String  @map("person_id")
  branchId   String? @map("branch_id") // null = tenant-level profile (e.g. business_admin)
  profileKey String  @map("profile_key")

  isDefault  Boolean   @default(false) @map("is_default")
  isActive   Boolean   @default(true) @map("is_active")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by")
  revokedAt  DateTime? @map("revoked_at")
  revokedBy  String?   @map("revoked_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([personId])
  @@index([branchId])
  @@map("user_branch_profiles")
}

/// Per-assignment permission overrides (allow/deny; inherit = no row).
model UserProfilePermissionOverride {
  id             String  @id @default(uuid())
  tenantId       String  @map("tenant_id")
  personId       String  @map("person_id")
  branchId       String? @map("branch_id")
  profileKey     String  @map("profile_key")
  permissionCode String  @map("permission_code")
  override       String // 'allow' | 'deny'

  setBy String? @map("set_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId, personId, profileKey])
  @@map("user_profile_permission_overrides")
}

/// Maps a receptionist to the doctors they handle at a branch.
model ReceptionistDoctorMapping {
  id                   String @id @default(uuid())
  tenantId             String @map("tenant_id")
  branchId             String @map("branch_id")
  receptionistPersonId String @map("receptionist_person_id")
  doctorPersonId       String @map("doctor_person_id")
  assignedBy           String? @map("assigned_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId, branchId, receptionistPersonId])
  @@map("receptionist_doctor_mappings")
}

/// The single main branch per tenant (one row per tenant; changed via upsert).
/// Tenant-scoped: `tenant_id` is UNIQUE, so a tenant can have at most one main
/// branch at a time. RLS policy in prisma/rls.sql.
model TenantMainBranch {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  branchId String @map("branch_id")

  setBy String? @map("set_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([branchId])
  @@map("tenant_main_branch")
}

/// A working schedule (shift plan) for a branch. Tenant-scoped + branch-level.
///
/// `shifts` is stored as JSON (validated by the schedule DTOs):
///   - shifts: Array<{ shiftName: ShiftName, startTime, endTime,
///                      breakStartTime, breakEndTime, activeDays: DayOfWeek[] }>
///             (times "HH:mm", 24h, branch-local; activeDays = the days the
///              shift runs on)
///
/// At most one ACTIVE schedule per branch may cover any given date — enforced in
/// the service (see ScheduleService.create/update). NIGHT shifts may cross
/// midnight (endTime <= startTime); overlap checks are midnight-aware and only
/// flag shifts that overlap on a shared active day.
model Schedule {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  planName String         @map("plan_name")
  status   ScheduleStatus @default(DRAFT)

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date // null = open-ended (+∞)

  shifts Json

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("schedules")
}
