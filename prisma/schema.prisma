  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  OTHER
}

// ── Messaging template enums ──────────────────────────────────────────────────

/// Delivery channel for a messaging template (the `preference` field). Filtered
/// in list queries, so it earns enum status + an index on Template.
enum MessagingChannel {
  EMAIL
  SMS
  IAM // Internal App Messaging
  IAA // Internal App Alert
  PBN // Push-Based Notification
  WHATSAPP
  TEMPLATE
}

/// Purpose classification for a messaging template.
enum MessageType {
  OTP
  TRANSACTIONAL
  MARKETING
}

/// DLT SMS route type.
enum SmsType {
  TRANSACTIONAL
  PROMOTIONAL
}

/// WhatsApp media message type (used when preference = WHATSAPP).
enum WhatsappMessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
}

/// WhatsApp Business template category (used when preference = WHATSAPP), kept
/// as an enum because it is a small, closed set.
enum WhatsappTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

/// Branch type a template applies to. NULL = applies to all branch types.
enum ApplicableBranchType {
  LAB
  CLINIC
  HOSPITAL
  BLOOD_BANK
  RADIOLOGY
}

/// Delivery scope level — admin-facing vs business/end-user-facing.
enum MessagingLevel {
  ADMIN
  BUSINESS
}

/// Application a template is restricted to. NULL = all applications.
enum ApplicationScope {
  KALNOSTIC
}

// ── Lab-test enums (UPPERCASE per project convention; values map to the raw
//    snake_case spec, e.g. SINGLE_STEP ↔ 'single_step') ──────────────────────────

/// Whether a test is processed in one step or several.
/// Origin of a lab-test / lab-panel record. `TENANT` rows belong to a business
/// (tenant-scoped, branch-level, inside a master data — the default). `SITE_ADMIN`
/// rows are global templates authored by Site Admin with no tenant/branch/master
/// data; a business adopts one by cloning it into its own catalogue as TENANT.
enum DataSource {
  TENANT
  SITE_ADMIN
}

enum ProcessMethod {
  SINGLE_STEP
  MULTI_STEP
}

/// How urgently a sample/test is processed.
enum SamplePriority {
  ROUTINE
  URGENT
  STAT
}

/// Unit for turnaround / processing time windows.
enum TatUnit {
  MINUTES
  HOURS
  DAYS
}

/// Unit for the repeat-interval restriction between orders of a test.
enum RepeatIntervalUnit {
  HOURS
  DAYS
  MONTHS
  YEARS
}

/// Age-group applicability for a lab panel (CMS filtering + age-appropriate
/// package suggestions). Distinct from the per-range `AgeUnit` bounds on a test.
enum AgeGroup {
  ALL
  ADULT
  PEDIATRIC
  SENIOR
}

/// How a lab panel's results are reported. COMBINED merges every test result
/// into one report; SEPARATE generates an individual report per test.
enum ReportType {
  COMBINED
  SEPARATE
}

/// How a result parameter's value is produced/expressed.
enum ResultType {
  QUANTITATIVE
  QUALITATIVE
  CALCULATED
}

/// Whether a parameter is measured directly or computed from a formula.
enum ParameterType {
  MEASURED
  CALCULATED
}

/// Whether a parameter's result is entered by hand or pulled automatically.
enum ResultEntryMode {
  MANUAL
  AUTO
}

/// Rounding applied to a numeric result.
enum ResultRounding {
  NO_ROUNDING
  ONE_DECIMAL
  TWO_DECIMAL
  THREE_DECIMAL
  WHOLE_NUMBER
}

/// Gender applicability for a reference range/value. Distinct from the
/// person-level `Gender` (which lacks `ALL` and carries OTHER/PREFER_NOT_TO_SAY).
enum ReferenceGender {
  ALL
  MALE
  FEMALE
}

/// Unit for age bounds on a reference range/value.
enum AgeUnit {
  DAYS
  MONTHS
  YEARS
}

/// How an out-of-range result is visually flagged on the report.
enum AbnormalFlag {
  BOLD_AND_RED
  BOLD_ONLY
  ITALIC
  UNDERLINE
  COLOUR_HIGHLIGHT
}

/// Sample container type (tube/colour or receptacle).
enum ContainerType {
  EDTA_TUBE_PURPLE_TOP
  PLAIN_TUBE_RED_TOP
  FLUORIDE_TUBE_GREY_TOP
  URINE_CONTAINER
  STERILE_CONTAINER
}

// ── Doctor enums (UPPERCASE per project convention) ─────────────────────────────

/// Whether a doctor reports on tests (signs reports) or consults patients.
enum DoctorType {
  REPORTING
  CONSULTANT
}

/// Honorific prefix. Display labels ("Dr.", "Prof.") are resolved on the frontend.
enum Salutation {
  DR
  MR
  MRS
  MS
  PROF
}

/// How a doctor is paid out.
enum DoctorPaymentMode {
  BANK_TRANSFER
  CASH
  CHEQUE
}

/// Active/inactive lifecycle for a doctor record (distinct from soft delete;
/// NULL deletedAt = not deleted).
enum DoctorStatus {
  ACTIVE
  INACTIVE
}

enum ReferralDoctorStatus {
  ACTIVE
  INACTIVE
}

/// Active/inactive lifecycle for an external referral record (distinct from soft
/// delete; NULL deletedAt = not deleted).
enum ExternalReferralStatus {
  ACTIVE
  INACTIVE
}

/// Active/inactive lifecycle for an internal referral (employee) record (distinct
/// from soft delete; NULL deletedAt = not deleted).
enum InternalReferralStatus {
  ACTIVE
  INACTIVE
}

/// How an internal referral's commission is paid out — unique to internal
/// referrals (employees): either folded into salary or paid as a separate payout.
enum CommissionMode {
  INCLUDED_IN_SALARY
  SEPARATE_PAYOUT
}

/// Billing relationship of a referring panel with the tenant.
enum ReferralClientType {
  CASH
  PREPAID
  POSTPAID
}

/// How a referring panel's commission is computed (only when commission applies).
enum CommissionType {
  PERCENTAGE
  SLAB_BASED
  FIXED_AMOUNT
}

/// Payout cadence for a FIXED_AMOUNT commission. `ORDER_WISE` pays per order (no
/// fixed amount); the rest pay the configured fixed amount on that cadence.
enum FixedCommissionCycle {
  ORDER_WISE
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUALLY
}

/// Settlement cadence for a referring panel (`NA` = not applicable / on demand).
enum PaymentCycle {
  NA
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUALLY
}

/// How a referring panel is paid out. Mirrors DoctorPaymentMode but kept separate
/// so the referral module can evolve independently (CLAUDE.md rule #3 spirit).
enum ReferralPaymentMode {
  BANK_TRANSFER
  CASH
  CHEQUE
}

/// Active/inactive lifecycle for a referral panel settings template (distinct from
/// soft delete; NULL deletedAt = not deleted).
enum ReferralPanelSettingsStatus {
  ACTIVE
  INACTIVE
}

/// How a prepaid wallet bonus is computed for a referral panel settings template.
enum ReferralBonusType {
  PERCENTAGE
  FIXED_AMOUNT
}

/// UI theme for a business's Site Admin experience (TenantConfiguration.theme).
enum Theme {
  LIGHT
  DARK
}

/// Whether a payment-gateway commission is added on top of the amount
/// (EXCLUSIVE — customer pays more) or absorbed within it (INCLUSIVE — the
/// business receives less). Mirrors kaltros-master's `exclusive | inclusive`.
/// Distinct from `CommissionType` above, which sizes referral commissions.
enum PgCommissionType {
  EXCLUSIVE
  INCLUSIVE
}

// ── Platform-level models (NO tenant_id) ────────────────────────────────────────

/// One row per registered business. "Business info" = the fields here.
model Tenant {
  id   String @id @default(uuid())
  name String

  /// URL-safe subdomain slug ({slug}.kalnostics.com). Unique, immutable after create.
  slug         String  @unique
  customDomain String? @unique @map("custom_domain")

  email     String? // primary contact email (billing/notifications)
  phone     String?
  shortName String? @map("short_name") // business abbreviation

  // ── Registered address ──
  address     Json?   // registered business address (free-form; legacy/back-compat)
  addressLine String? @map("address_line") // street address
  pincode     String? // zip / pin code
  countryId   String? @map("country_id")
  stateId     String? @map("state_id")
  cityId      String? @map("city_id")
  areaId      String? @map("area_id")
  country     Country? @relation(fields: [countryId], references: [id])
  state       State?   @relation(fields: [stateId], references: [id])
  city        City?    @relation(fields: [cityId], references: [id])
  area        Area?    @relation(fields: [areaId], references: [id])

  // ── Media (URL strings; no upload pipeline yet) ──
  logoUrl  String? @map("logo_url")
  photoUrl String? @map("photo_url")

  // ── Subscription ──
  subscriptionStatus SubscriptionStatus @default(TRIALING) @map("subscription_status")
  subscriptionPlanId String?            @map("subscription_plan_id")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  subscriptionEndsAt DateTime?          @map("subscription_ends_at")
  gracePeriodEndsAt  DateTime?          @map("grace_period_ends_at")

  // ── Locale & branding (timezone/currency/date_format/language/logo/colors) ──
  settings Json?

  // ── SiteAdmin-managed extensions (1:1) ──
  configuration TenantConfiguration? // site URLs / branding / limits / theme
  setting       TenantSetting? // referral / payment / commission / wallet rules

  isActive               Boolean @default(true) @map("is_active")
  mrnCounter             Int     @default(0) @map("mrn_counter") // per-tenant sequential patient MRN
  mrnPrefix              String? @map("mrn_prefix")
  branchCounter          Int     @default(0) @map("branch_counter") // per-tenant sequential branch code
  staffCounter           Int     @default(0) @map("staff_counter") // per-tenant sequential staff user code (USR-00001)
  departmentCounter      Int     @default(0) @map("department_counter") // per-tenant sequential department code
  categoryCounter        Int     @default(0) @map("category_counter") // per-tenant sequential category code
  subCategoryCounter     Int     @default(0) @map("sub_category_counter") // per-tenant sequential sub-category code
  outsourceCenterCounter Int     @default(0) @map("outsource_center_counter") // per-tenant sequential outsource-center code
  referralPanelCounter   Int     @default(0) @map("referral_panel_counter") // per-tenant sequential referral-panel code
  createdBy              String? @map("created_by") // SiteAdmin user id (creator)
  updatedBy              String? @map("updated_by") // SiteAdmin user id (last editor)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([countryId])
  @@index([stateId])
  @@index([cityId])
  @@index([areaId])
  @@index([deletedAt])
  @@map("tenants")
}

/// Business Configuration — a 1:1 platform-level extension of a Tenant holding
/// SiteAdmin-managed site/branding/limit settings. No tenant_id RLS policy: like
/// Tenant itself it sits above per-request tenant context and is managed only via
/// SiteAdmin routes. Created on first read/write via upsert (theme defaults LIGHT).
model TenantConfiguration {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  siteAdminUrl    String? @map("site_admin_url")
  siteTitle       String? @map("site_title")
  logoPath        String? @map("logo_path")
  logoLink        String? @map("logo_link")
  template        String?
  theme           Theme   @default(LIGHT)
  patientOrderUrl String? @map("patient_order_url")

  maxOrdersPerDayPerBranch Int? @map("max_orders_per_day_per_branch")
  maxUsersAllowed          Int? @map("max_users_allowed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenant_configurations")
}

/// Business Settings — a 1:1 platform-level extension of a Tenant holding
/// SiteAdmin-managed referral / payment / commission / wallet rules. Same tier
/// rationale as TenantConfiguration (no RLS; SiteAdmin-only). Booleans carry the
/// mandated is/can prefix (CLAUDE.md §3); created on first access via upsert.
model TenantSetting {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // ── Referral settings ──
  isExternalDoctorOutReferralAllowed   Boolean @default(false) @map("is_external_doctor_out_referral_allowed")
  isExternalDoctorInReferralAllowed    Boolean @default(false) @map("is_external_doctor_in_referral_allowed")
  isExternalHospitalOutReferralAllowed Boolean @default(false) @map("is_external_hospital_out_referral_allowed")
  isExternalHospitalInReferralAllowed  Boolean @default(false) @map("is_external_hospital_in_referral_allowed")

  // ── Payment settings ──
  isPatientOrderPaymentAllowed    Boolean @default(false) @map("is_patient_order_payment_allowed")
  isCmsOrderBillGenerationEnabled Boolean @default(false) @map("is_cms_order_bill_generation_enabled")

  // ── Commission types (payment gateway) ──
  referralPgCommissionType        PgCommissionType @default(EXCLUSIVE) @map("referral_pg_commission_type")
  patientPgCommissionType         PgCommissionType @default(EXCLUSIVE) @map("patient_pg_commission_type")
  franchiseBranchPgCommissionType PgCommissionType @default(EXCLUSIVE) @map("franchise_branch_pg_commission_type")

  // ── Wallet settings ──
  canPatientWalletGoNegative Boolean @default(false) @map("can_patient_wallet_go_negative")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

/// Platform-level, single-row sequence source for Site Admin global template
/// codes (`SA-Dep-{n}`, `SA-Cat-{n}`, `SA-SubCat-{n}`). No tenant_id — templates
/// sit above any business. Upserted on first use; counters are post-incremented
/// inside the template-create transaction (0-based sequence, mirroring the
/// per-tenant counters on Tenant).
model SiteAdminCounter {
  id                 String   @id @default("global")
  departmentCounter  Int      @default(0) @map("department_counter")
  categoryCounter    Int      @default(0) @map("category_counter")
  subCategoryCounter Int      @default(0) @map("sub_category_counter")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("siteadmin_counters")
}

/// Platform-level identity for ALL humans (patients AND staff). No tenant_id.
model Person {
  id String @id @default(uuid())

  /// Globally-unique Medical Record Number across all businesses. Read-only after creation.
  platformMrn String @unique @map("platform_mrn")

  salutation  String?
  firstName   String      @map("first_name")
  middleName  String?     @map("middle_name")
  lastName    String?     @map("last_name")
  dateOfBirth DateTime?   @map("date_of_birth") @db.Date
  gender      Gender?
  bloodGroup  BloodGroup? @map("blood_group")

  /// Phone/email are global de-duplication keys; locked after first use.
  phone String? @unique
  email String? @unique

  address  Json?
  photoUrl String? @map("photo_url")
  idType   String? @map("id_type")
  idNumber String? @map("id_number") // encrypted at rest (deferred)

  // ── Extended identity (User Management v2.0) ──
  nationality            String? @default("Indian")
  fatherName             String? @map("father_name")
  motherName             String? @map("mother_name")
  aadhaarNumber          String? @map("aadhaar_number") // 12 digits, ENCRYPTED at rest (AES-256-GCM)
  panNumber              String? @map("pan_number") // ^[A-Z]{5}[0-9]{4}[A-Z]$, stored uppercase
  emergencyContactName   String? @map("emergency_contact_name")
  emergencyContactNumber String? @map("emergency_contact_number")

  /// First business to register this person owns their basic details. NULL = self-registered.
  ownerTenantId String? @map("owner_tenant_id")

  isPatient Boolean @default(false) @map("is_patient")
  isStaff   Boolean @default(false) @map("is_staff")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([ownerTenantId])
  @@index([deletedAt])
  @@map("persons")
}

/// Login credentials — one row per person.
model PersonCredentials {
  id       String @id @default(uuid())
  personId String @unique @map("person_id")

  // Login identifiers (precedence: phone → email → system_username)
  phone                     String? @unique
  email                     String? @unique
  systemUsername            String? @unique @map("system_username")
  isSystemGeneratedUsername Boolean @default(false) @map("is_system_generated_username")

  passwordHash   String  @map("password_hash") // bcrypt cost 12
  isTempPassword Boolean @default(false) @map("is_temp_password")

  // Security
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("person_credentials")
}

/// SiteAdmin users — separate auth system, separate table, separate JWT.
model SiteAdminUser {
  id           String        @id @default(uuid())
  firstName    String        @map("first_name")
  lastName     String?       @map("last_name")
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         SiteAdminRole @default(CONTENT_ADMIN)
  isActive     Boolean       @default(true) @map("is_active")

  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  createdBy      String?   @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("siteadmin_users")
}

/// Refresh tokens — server-side, single-use rotation, SHA-256 hashed at rest.
model RefreshToken {
  id         String    @id @default(uuid())
  personId   String    @map("person_id")
  tokenHash  String    @unique @map("token_hash")
  branchId   String?   @map("branch_id")
  // Snapshot of the active role, used to restore the switched context on refresh.
  authRoleId String?   @map("auth_role_id")
  authRole   AuthRole? @relation(fields: [authRoleId], references: [id])
  issuedToIp String?   @map("issued_to_ip")
  userAgent  String?   @map("user_agent")

  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  isRevoked Boolean  @default(false) @map("is_revoked")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([personId])
  @@index([authRoleId])
  @@map("refresh_tokens")
}

/// Cross-business patient linkage (each business keeps its own tenant_mrn).
model PersonTenantEnrollment {
  id        String  @id @default(uuid())
  personId  String  @map("person_id")
  tenantId  String  @map("tenant_id")
  branchId  String  @map("branch_id")
  tenantMrn String? @map("tenant_mrn")

  enrolledAt DateTime @default(now()) @map("enrolled_at")
  enrolledBy String?  @map("enrolled_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([personId, tenantId])
  @@map("person_tenant_enrollments")
}

// ── Location master (platform-level geographic reference data) ───────────────────
// Global Country → State → City → Area/Locality hierarchy owned and maintained by
// SiteAdmin (no tenant_id, no RLS — shared by every tenant). Businesses consume it
// read-only to populate cascading location dropdowns. Denormalized ancestor FKs on
// City/Area (per spec) are kept mutually consistent in the services.

/// A country (e.g. India / "IN"). Top of the location hierarchy.
model Country {
  id   String @id @default(uuid())
  name String
  code String

  isActive Boolean @default(true) @map("is_active")

  states  State[]
  cities  City[]
  areas   Area[]
  tenants Tenant[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("countries")
}

/// A state/province belonging to one country.
model State {
  id   String @id @default(uuid())
  name String
  code String

  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])

  isActive Boolean @default(true) @map("is_active")

  cities  City[]
  areas   Area[]
  tenants Tenant[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([countryId])
  @@index([deletedAt])
  @@map("states")
}

/// A city belonging to one state (and, denormalized, one country).
model City {
  id      String @id @default(uuid())
  name    String
  pinCode String @map("pin_code")

  stateId   String @map("state_id")
  countryId String @map("country_id")
  state     State   @relation(fields: [stateId], references: [id])
  country   Country @relation(fields: [countryId], references: [id])

  isActive Boolean @default(true) @map("is_active")

  areas   Area[]
  tenants Tenant[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([stateId])
  @@index([countryId])
  @@index([deletedAt])
  @@map("cities")
}

/// An area/locality belonging to one city (and, denormalized, one state + country).
model Area {
  id       String @id @default(uuid())
  name     String
  locality String

  cityId    String @map("city_id")
  stateId   String @map("state_id")
  countryId String @map("country_id")
  city      City    @relation(fields: [cityId], references: [id])
  state     State   @relation(fields: [stateId], references: [id])
  country   Country @relation(fields: [countryId], references: [id])

  isActive Boolean @default(true) @map("is_active")

  tenants Tenant[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([cityId])
  @@index([stateId])
  @@index([countryId])
  @@index([deletedAt])
  @@map("areas")
}

// ── Tenant-scoped models (tenant_id + RLS) ──────────────────────────────────────

/// A physical location belonging to a tenant.
model Branch {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  name       String
  branchType BranchType @map("branch_type")
  // System-generated, immutable. Per-tenant sequential code (e.g. "BR-00001")
  // derived from Tenant.branchCounter. Unique per tenant among active rows
  // (partial unique index in prisma/rls.sql); never client-supplied.
  code       String

  status          BranchStatus @default(ACTIVE)
  establishedDate DateTime?    @map("established_date")

  // Location
  addressLine String? @map("address_line")
  city        String?
  state       String?
  pincode     String?

  // Contact
  phone        String?
  email        String?
  managerName  String? @map("manager_name")
  managerPhone String? @map("manager_phone")
  labDirector  String? @map("lab_director")

  // Operations
  openingTime     String?     @map("opening_time") // "HH:mm" (24h, branch-local)
  closingTime     String?     @map("closing_time") // "HH:mm" (24h, branch-local)
  dailyCapacity   Int?        @map("daily_capacity") // max orders processable per day
  operationalDays DayOfWeek[] @map("operational_days")

  // Compliance / misc
  gstNo     String? @map("gst_no")
  licenseNo String? @map("license_no")
  remarks   String?

  // Doctors scoped to this branch (managed via DoctorsService).
  doctors Doctor[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([deletedAt])
  @@map("branches")
}

/// A business-user role. System roles (tenant_id = NULL) are seeded from
/// PROFILE_REGISTRY, immutable, and shared by every tenant (readable across
/// tenants via the same RLS "template" pattern as departments/lab tests). Rows
/// with a tenant_id are custom roles a tenant defines through the /roles CRUD.
///
/// `key` is the stable identifier carried in the JWT (== the old profileKey);
/// for system roles it must equal the PROFILE_REGISTRY value so the token stays
/// byte-identical. `name` is the human-readable label (== old PROFILE_LABELS).
/// `allowedBranchTypes` is only consulted for custom roles — system roles derive
/// their branch validity from PROFILE_BRANCH_MATRIX in code.
model AuthRole {
  id                 String       @id @default(uuid())
  tenantId           String?      @map("tenant_id") // null = global system role
  key                String
  name               String
  description        String?
  allowedBranchTypes BranchType[] @map("allowed_branch_types")
  isSystem           Boolean      @default(false) @map("is_system")
  isActive           Boolean      @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Uniqueness (key/name, scoped per tenant for custom roles and globally for
  // system roles) is enforced by partial unique indexes in prisma/rls.sql.
  profiles            UserBranchProfile[]
  staffMemberships    TenantStaffMembership[]
  permissionOverrides UserProfilePermissionOverride[]
  refreshTokens       RefreshToken[]

  @@index([tenantId])
  @@index([deletedAt])
  @@map("auth_roles")
}

/// Assigns a person a profile (role) at a branch (or tenant-level when branch is null).
model UserBranchProfile {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  personId   String    @map("person_id")
  branchId   String?   @map("branch_id") // null = tenant-level profile (e.g. business_admin)
  // The assigned role. A restrict FK (Prisma default) — a role still referenced
  // here can't be hard-deleted; the /roles CRUD blocks it and soft-deletes.
  authRoleId String   @map("auth_role_id")
  authRole   AuthRole @relation(fields: [authRoleId], references: [id])

  // ── User Management v2.0 ──
  // Per-branch activation: INACTIVE blocks access to THIS branch only (the
  // tenant-global TenantStaffMembership.status overrides all branches).
  branchStatus    StaffStatus @default(ACTIVE) @map("branch_status")
  // The module (key from SYSTEM_MODULES) this assignment lands on by default;
  // must be enabled for the branch (branch_modules). Null = none chosen.
  defaultModuleId String?     @map("default_module_id")

  isDefault  Boolean   @default(false) @map("is_default")
  isActive   Boolean   @default(true) @map("is_active")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by")
  revokedAt  DateTime? @map("revoked_at")
  revokedBy  String?   @map("revoked_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([personId])
  @@index([branchId])
  @@index([authRoleId])
  @@map("user_branch_profiles")
}

/// Per-assignment permission overrides (allow/deny; inherit = no row).
model UserProfilePermissionOverride {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  personId       String    @map("person_id")
  branchId       String?  @map("branch_id")
  authRoleId     String   @map("auth_role_id")
  authRole       AuthRole @relation(fields: [authRoleId], references: [id])
  permissionCode String   @map("permission_code")
  override       String // 'allow' | 'deny'

  setBy String? @map("set_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId, personId, authRoleId])
  @@map("user_profile_permission_overrides")
}

/// A person's employment with a tenant (one row per tenant+person). Holds the
/// per-employer facts that must NOT live on the cross-tenant Person: the
/// sequential user code (USR-00001), internal/external classification, the role,
/// and the tenant-global active/inactive status. Cross-tenant safe: deactivating
/// here never affects the same person at another tenant.
model TenantStaffMembership {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  personId String @map("person_id")

  // System-generated, immutable, per-tenant sequential code ("USR-00001")
  // derived from Tenant.staffCounter. Unique per tenant among active rows
  // (partial unique index in prisma/rls.sql); never client-supplied.
  userCode String      @map("user_code")
  userType UserType    @default(INTERNAL) @map("user_type")
  // Optional primary/default role. The authoritative role lives per-branch on
  // UserBranchProfile.authRoleId; a user can be a tenant member with no role yet.
  authRoleId String?   @map("auth_role_id")
  authRole   AuthRole? @relation(fields: [authRoleId], references: [id])
  status   StaffStatus @default(ACTIVE) // tenant-global account status

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, personId])
  @@index([tenantId])
  @@index([personId])
  @@index([authRoleId])
  @@map("tenant_staff_memberships")
}

/// Which system modules (keys from SYSTEM_MODULES) are enabled at a branch.
/// Drives the module dropdowns and gates the per-user permission modal.
model BranchModule {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  branchId  String  @map("branch_id")
  moduleKey String  @map("module_key")
  isEnabled Boolean @default(true) @map("is_enabled")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([branchId, moduleKey])
  @@index([tenantId])
  @@index([branchId])
  @@map("branch_modules")
}

/// Maps a Collection Center branch to a branch that receives its samples for
/// processing. Tenant-scoped (CLAUDE.md §4.6). Both ids are logical FKs to
/// `branches` (validated in BranchService, mirroring BranchModule). One active
/// mapping per (collection_center, receiving_branch) — partial unique index in
/// prisma/rls.sql. RLS policy in prisma/rls.sql.
model CollectionCenterMapping {
  id                 String @id @default(uuid())
  tenantId           String @map("tenant_id")
  collectionCenterId String @map("collection_center_id")
  receivingBranchId  String @map("receiving_branch_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([collectionCenterId])
  @@index([receivingBranchId])
  @@index([deletedAt])
  @@map("collection_center_mappings")
}

/// Module-grouped, per-(user + branch) permission grants (User Management v2.0).
/// `allowed` is the effective grant for a permission key; absence of a row means
/// "inherit the role baseline". Distinct from UserProfilePermissionOverride,
/// which is keyed on profileKey and retained for backward compatibility.
model UserBranchPermission {
  id            String  @id @default(uuid())
  tenantId      String  @map("tenant_id")
  personId      String  @map("person_id")
  branchId      String  @map("branch_id")
  moduleKey     String  @map("module_key")
  permissionKey String  @map("permission_key")
  allowed       Boolean

  setBy String? @map("set_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, personId, branchId, permissionKey])
  @@index([tenantId, personId])
  @@index([branchId])
  @@map("user_branch_permissions")
}

/// Maps a receptionist to the doctors they handle at a branch.
model ReceptionistDoctorMapping {
  id                   String  @id @default(uuid())
  tenantId             String  @map("tenant_id")
  branchId             String  @map("branch_id")
  receptionistPersonId String  @map("receptionist_person_id")
  doctorPersonId       String  @map("doctor_person_id")
  assignedBy           String? @map("assigned_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId, branchId, receptionistPersonId])
  @@map("receptionist_doctor_mappings")
}

/// The single main branch per tenant (one row per tenant; changed via upsert).
/// Tenant-scoped: `tenant_id` is UNIQUE, so a tenant can have at most one main
/// branch at a time. RLS policy in prisma/rls.sql.
model TenantMainBranch {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  branchId String @map("branch_id")

  setBy String? @map("set_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([branchId])
  @@map("tenant_main_branch")
}

/// A working schedule (shift plan) for a branch. Tenant-scoped + branch-level.
///
/// `shifts` is stored as JSON (validated by the schedule DTOs):
///   - shifts: Array<{ shiftName: ShiftName, startTime, endTime,
///                      breakStartTime, breakEndTime, activeDays: DayOfWeek[] }>
///             (times "HH:mm", 24h, branch-local; activeDays = the days the
///              shift runs on)
///
/// At most one ACTIVE schedule per branch may cover any given date — enforced in
/// the service (see ScheduleService.create/update). NIGHT shifts may cross
/// midnight (endTime <= startTime); overlap checks are midnight-aware and only
/// flag shifts that overlap on a shared active day.
model Schedule {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  planName String         @map("plan_name")
  status   ScheduleStatus @default(DRAFT)

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date // null = open-ended (+∞)

  shifts Json

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("schedules")
}

/// A messaging/document template (SMS, Email, WhatsApp, Consent Form, Report).
/// A messaging template (Email / SMS / WhatsApp / IAM / IAA / PBN). A flat
/// record keyed on a delivery `preference` (channel) and a `feature` (the ~88
/// business events, validated app-side against FEATURE_TYPES).
///
/// Tenant-scoped + branch-level (CLAUDE.md §4.6): `tenant_id` NULL = a SITE_ADMIN
/// global master template shared across tenants; `branch_id` NULL = a
/// tenant-level template, set = a branch-level template. The scopes are
/// independent — neither sees the other's rows. RLS policy in prisma/rls.sql.
///
/// Multiple templates may exist per (feature, preference, level); `is_default`
/// marks the fallback among them, so there is no name/feature uniqueness.
model Template {
  id       String  @id @default(uuid())
  tenantId String? @map("tenant_id") // null = SITE_ADMIN global master template (shared across tenants)
  branchId String? @map("branch_id") // null = tenant-level (business-admin)

  // ── Core settings ──
  preference   MessagingChannel // delivery channel
  feature      String // business event key, validated against FEATURE_TYPES
  displayTitle String?          @map("display_title")
  messageType  MessageType?     @map("message_type")
  isActive     Boolean          @default(true) @map("is_active")
  isDefault    Boolean          @default(false) @map("is_default")
  isEnabled    Boolean          @default(false) @map("is_enabled")

  // ── Scope & targeting ──
  specificApplication  ApplicationScope?     @map("specific_application") // null = all applications
  applicableBranchType ApplicableBranchType? @map("applicable_branch_type") // null = all branch types
  level                MessagingLevel        @default(BUSINESS)
  entityId             String?               @map("entity_id")
  entityType           String?               @map("entity_type")

  // ── SMS settings ──
  smsTemplateId String?  @map("sms_template_id") // DLT template id
  smsSenderId   String?  @map("sms_sender_id")
  smsType       SmsType? @map("sms_type")

  /// Template body — rich HTML when preference = EMAIL, otherwise plain text with
  /// `{variable_name}` placeholders.
  template String @db.Text

  // ── WhatsApp settings (used when preference = WHATSAPP) ──
  templateType     WhatsappMessageType?      @map("template_type")
  templateCategory WhatsappTemplateCategory? @map("template_category")
  fileName         String?                   @map("file_name")

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([preference])
  @@index([feature])
  @@index([deletedAt])
  @@map("templates")
}

/// A PDF report template (CLAUDE.md §4.6 tenant-scoped, branch-level). Defines a
/// named, typed report layout — page settings, header/body/footer HTML and CSS —
/// used to render PDFs (lab reports, invoices, prescriptions, …). `type` is one
/// of ~49 supported keys validated app-side against `PDF_REPORT_TEMPLATE_TYPES`
/// (not a Prisma enum, so the list can grow without a migration). All page +
/// section settings live in the `meta` JSON blob (general/header/body/footer),
/// validated via `PdfTemplateMetaDto`. `branchId` is nullable: null = a
/// tenant-wide template; set = scoped to one branch (validated against the
/// tenant). Status is the boolean `isActive` (the frontend maps 1/0 ⇄
/// true/false).
model PdfReportTemplate {
  id       String  @id @default(uuid())
  tenantId String? @map("tenant_id") // null = SITE_ADMIN global template (shared across tenants)
  branchId String? @map("branch_id") // null = tenant-wide

  type     String // validated app-side against PDF_REPORT_TEMPLATE_TYPES
  name     String
  isActive Boolean @default(true) @map("is_active")

  /// General/header/body/footer settings (shape validated by PdfTemplateMetaDto).
  meta Json @default("{}")

  /// Block-based Advance PDF document (AdvanceDocument JSON) for templates
  /// edited in the visual block designer. NULL for classic HTML-`meta`
  /// templates; the two engines are independent.
  doc Json?

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([type])
  @@index([deletedAt])
  @@map("pdf_report_templates")
}

/// A department within a tenant (business-wide; NOT branch-scoped — CLAUDE.md
/// §4.6 tenant-level tier). The `code` is system-generated and immutable:
/// `{INITIALS}-Dep-{n}`, where INITIALS are derived from the tenant name and `n`
/// is a per-tenant sequential counter (Tenant.departmentCounter), e.g.
/// `ABC-Dep-0`, `ABC-Dep-1`. Unique per tenant among active rows (partial unique
/// index in prisma/rls.sql). RLS policy in prisma/rls.sql.
model Department {
  id String @id @default(uuid())

  /// NULL for SITE_ADMIN global templates; set for TENANT rows (CLAUDE.md §4.2).
  tenantId    String? @map("tenant_id")
  name        String
  description String?
  code        String

  /// Origin: TENANT (default, tenant-scoped) or SITE_ADMIN (global template).
  source DataSource @default(TENANT)

  /// For a TENANT row cloned from a SITE_ADMIN template, the template's id (lets
  /// a repeat clone reuse the existing copy instead of duplicating). Null for
  /// hand-created tenant rows and for templates themselves.
  clonedFromId String? @map("cloned_from_id")

  /// User-set short prefix for space-constrained dropdowns (2-6 chars, uppercase
  /// A-Z/0-9). Mandatory and editable. Unique per tenant among active rows
  /// (partial unique index in prisma/rls.sql).
  shortName String @map("short_name")

  isActive Boolean @default(true) @map("is_active")

  /// "Module mapping" — reuses the same enum as Branch.branchType, so the valid
  /// values stay identical to branch creation. A department may cover several.
  moduleMapping BranchType[] @map("module_mapping")

  personMappings DepartmentPersonMapping[]

  /// Categories that hang off this department (CategoryType.UNDER_DEPARTMENT).
  categories Category[]

  /// Sub-categories that hang off this department (SubCategoryType.UNDER_DEPARTMENT).
  subCategories SubCategory[]

  /// Doctors whose specialization links to this department (logical via relation).
  doctors Doctor[]

  /// Referral doctors whose department links here.
  referralDoctors ReferralDoctor[]

  /// Controlled documents filed under this department.
  documents Document[]

  /// Lab tests classified under this department.
  labTests LabTest[] @relation("LabTestDept")

  /// Lab tests that name this department as their mandatory-test department.
  mandatoryLabTests LabTest[] @relation("LabTestMandatoryDept")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([shortName])
  @@index([source])
  @@index([clonedFromId])
  @@index([deletedAt])
  @@map("departments")
}

/// Links a mapped party to a Department with a position plus signing authority
/// and ordering metadata. Tenant-scoped (mirrors UserBranchProfile). `person_id`
/// is a polymorphic logical FK resolved by `type`: USER → persons,
/// CONSULTANT_DOCTOR/REPORTING_DOCTOR → doctors, EXTERNAL_REFERRAL →
/// external_referrals. `branch_id` is null for a tenant-level mapping (applies to
/// all branches) or set to scope the mapping to one branch. `priority` is
/// validated in DepartmentService per branch against the tenant's mapping count.
model DepartmentPersonMapping {
  id           String             @id @default(uuid())
  tenantId     String             @map("tenant_id")
  departmentId String             @map("department_id")
  personId     String             @map("person_id")
  type         PersonMappingType  @default(USER)
  branchId     String?            @map("branch_id")
  position     DepartmentPosition
  isSignatory  Boolean            @default(false) @map("is_signatory")
  priority     Int
  isDefault    Boolean            @default(false) @map("is_default")

  department Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([personId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("department_person_mappings")
}

/// A category, the same shape as a Department plus a type dimension: INDEPENDENT
/// categories stand alone (department_id NULL); UNDER_DEPARTMENT categories link
/// to an active department of the same tenant (department_id set). The
/// type↔link invariant is enforced in CategoryService + a CHECK in
/// prisma/rls.sql (Prisma can't express conditional constraints).
///
/// Tenant-scoped, tenant-level (CLAUDE.md §4.6). `code` is system-generated &
/// immutable: `{INITIALS}-Cat-{n}`, INITIALS from the tenant name, `n` a 0-based
/// per-tenant sequence from Tenant.categoryCounter. Unique per tenant among
/// active rows (partial unique index in prisma/rls.sql). RLS policy in rls.sql.
model Category {
  id String @id @default(uuid())

  /// NULL for SITE_ADMIN global templates; set for TENANT rows (CLAUDE.md §4.2).
  tenantId    String? @map("tenant_id")
  name        String
  description String?
  code        String

  /// Origin: TENANT (default, tenant-scoped) or SITE_ADMIN (global template).
  source DataSource @default(TENANT)

  /// For a TENANT row cloned from a SITE_ADMIN template, the template's id (lets
  /// a repeat clone reuse the existing copy instead of duplicating). Null for
  /// hand-created tenant rows and for templates themselves.
  clonedFromId String? @map("cloned_from_id")

  /// User-set short prefix for space-constrained dropdowns (2-6 chars, uppercase
  /// A-Z/0-9). Mandatory and editable. Unique within the parent department among
  /// active rows; INDEPENDENT categories are unique per tenant (partial unique
  /// indexes in prisma/rls.sql).
  shortName String @map("short_name")

  isActive     Boolean      @default(true) @map("is_active")
  categoryType CategoryType @map("category_type")

  /// INDEPENDENT → null; UNDER_DEPARTMENT → an active department of this tenant.
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  /// "Module mapping" — reuses the same enum as Branch.branchType, exactly like
  /// Department. A category may cover several.
  moduleMapping BranchType[] @map("module_mapping")

  personMappings CategoryPersonMapping[]

  /// Sub-categories that hang off this category (SubCategoryType.UNDER_CATEGORY).
  subCategories SubCategory[]

  /// Doctors whose specialization links to this category (logical via relation).
  doctors Doctor[]

  /// Referral doctors whose specialty links to this category.
  referralDoctors ReferralDoctor[]

  /// Controlled documents filed under this category.
  documents Document[]

  /// Lab tests classified under this category.
  labTests LabTest[] @relation("LabTestCat")

  /// Lab tests that name this category as their mandatory-test category.
  mandatoryLabTests LabTest[] @relation("LabTestMandatoryCat")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([shortName])
  @@index([source])
  @@index([clonedFromId])
  @@index([deletedAt])
  @@map("categories")
}

/// A controlled document (SOP, policy, certificate, etc.). Tenant-scoped +
/// branch-level (CLAUDE.md §4.6). This row is the **current/active** version —
/// it is updated in place on every edit to mirror the newest version, while an
/// immutable snapshot of every version (including the current one) is preserved
/// in `DocumentVersion`. Catalogue links (`category`, `department`) are Prisma
/// relations; `authorId`/`approvedById` are logical FKs to `persons` validated
/// against the tenant's staff in `DocumentService`.
model Document {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  /// Required human-facing document number. Unique per branch among active rows
  /// (partial unique index in prisma/rls.sql).
  documentNumber String       @map("document_number")
  documentType   DocumentType @map("document_type")
  title          String

  categoryId   String?     @map("category_id")
  category     Category?   @relation(fields: [categoryId], references: [id])
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  /// Logical FK to `persons` (author / approver). Validated against tenant staff.
  authorId     String? @map("author_id")
  approvedById String? @map("approved_by_id")

  status DocumentStatus @default(DRAFT)

  /// Current version string (unique per document among its versions).
  version String

  effectiveDate DateTime? @map("effective_date")
  expiryDate    DateTime? @map("expiry_date")
  reviewDate    DateTime? @map("review_date")

  /// Uploaded file reference (name + URL); the upload itself is handled elsewhere.
  fileName String? @map("file_name")
  fileUrl  String? @map("file_url")

  description String?

  /// Sequential counter for the latest version (1-based); drives `versionNo`.
  latestVersionNo Int @default(1) @map("latest_version_no")

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  versions DocumentVersion[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@index([deletedAt])
  @@map("documents")
}

/// An immutable snapshot of one document version. One row is written at create
/// (v1) and one on every edit (v2, v3, …). These rows are **never updated or
/// deleted** — they are the preserved, read-only history (no `updatedAt` /
/// `deletedAt`). The newest `versionNo` mirrors the parent `Document` row.
model DocumentVersion {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  /// 1-based sequential version index (for ordering).
  versionNo Int @map("version_no")

  /// The version string captured for this snapshot. Unique per document.
  version String

  // ── Full snapshot of every editable field at this version ──────────────────
  documentNumber String         @map("document_number")
  documentType   DocumentType   @map("document_type")
  title          String
  categoryId     String?        @map("category_id")
  departmentId   String?        @map("department_id")
  authorId       String?        @map("author_id")
  approvedById   String?        @map("approved_by_id")
  status         DocumentStatus
  effectiveDate  DateTime?      @map("effective_date")
  expiryDate     DateTime?      @map("expiry_date")
  reviewDate     DateTime?      @map("review_date")
  fileName       String?        @map("file_name")
  fileUrl        String?        @map("file_url")
  description    String?

  /// Person id of the actor who created this version (from the JWT).
  changedBy String? @map("changed_by")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([documentId, version])
  @@index([tenantId])
  @@index([documentId])
  @@index([versionNo])
  @@map("document_versions")
}

/// Links a mapped party to a Category with a position plus signing authority and
/// ordering metadata. Tenant-scoped (mirrors DepartmentPersonMapping). `person_id`
/// is a polymorphic logical FK resolved by `type`: USER → persons,
/// CONSULTANT_DOCTOR/REPORTING_DOCTOR → doctors, EXTERNAL_REFERRAL →
/// external_referrals. `branch_id` is null for a tenant-level mapping (all
/// branches) or set to scope it to one branch. `priority` is validated in
/// CategoryService per branch against the tenant's mapping count.
model CategoryPersonMapping {
  id          String            @id @default(uuid())
  tenantId    String            @map("tenant_id")
  categoryId  String            @map("category_id")
  personId    String            @map("person_id")
  type        PersonMappingType @default(USER)
  branchId    String?           @map("branch_id")
  position    CategoryPosition
  isSignatory Boolean           @default(false) @map("is_signatory")
  priority    Int
  isDefault   Boolean           @default(false) @map("is_default")

  category Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([categoryId])
  @@index([personId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("category_person_mappings")
}

/// A sub-category, the same shape as a Category plus a third type option. Its
/// type dimension picks the parent: INDEPENDENT stands alone (both FKs NULL);
/// UNDER_DEPARTMENT links to an active department of the same tenant
/// (department_id set); UNDER_CATEGORY links to an active category of the same
/// tenant (category_id set). The type↔link invariant is enforced in
/// SubCategoryService + a CHECK in prisma/rls.sql (Prisma can't express
/// conditional constraints).
///
/// Tenant-scoped, tenant-level (CLAUDE.md §4.6). `code` is system-generated &
/// immutable: `{INITIALS}-SubCat-{n}`, INITIALS from the tenant name, `n` a
/// 0-based per-tenant sequence from Tenant.subCategoryCounter. Unique per tenant
/// among active rows (partial unique index in prisma/rls.sql). RLS in rls.sql.
model SubCategory {
  id String @id @default(uuid())

  /// NULL for SITE_ADMIN global templates; set for TENANT rows (CLAUDE.md §4.2).
  tenantId    String? @map("tenant_id")
  name        String
  description String?
  code        String

  /// Origin: TENANT (default, tenant-scoped) or SITE_ADMIN (global template).
  source DataSource @default(TENANT)

  /// For a TENANT row cloned from a SITE_ADMIN template, the template's id (lets
  /// a repeat clone reuse the existing copy instead of duplicating). Null for
  /// hand-created tenant rows and for templates themselves.
  clonedFromId String? @map("cloned_from_id")

  /// User-set short prefix for space-constrained dropdowns (2-6 chars, uppercase
  /// A-Z/0-9). Mandatory and editable. Unique within the parent category
  /// (UNDER_CATEGORY) or parent department (UNDER_DEPARTMENT) among active rows;
  /// INDEPENDENT sub-categories are unique per tenant (partial unique indexes in
  /// prisma/rls.sql).
  shortName String @map("short_name")

  isActive        Boolean         @default(true) @map("is_active")
  subCategoryType SubCategoryType @map("sub_category_type")

  /// UNDER_DEPARTMENT → an active department of this tenant; else null.
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  /// UNDER_CATEGORY → an active category of this tenant; else null.
  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  /// "Module mapping" — reuses the same enum as Branch.branchType, exactly like
  /// Category. A sub-category may cover several.
  moduleMapping BranchType[] @map("module_mapping")

  personMappings SubCategoryPersonMapping[]

  /// Referral doctors whose super specialty links to this sub-category.
  referralDoctors ReferralDoctor[]

  /// Doctors whose super specialization links to this sub-category.
  doctors Doctor[]

  /// Lab tests classified under this sub-category.
  labTests LabTest[] @relation("LabTestSubcat")

  /// Lab tests that name this sub-category as their mandatory-test sub-category.
  mandatoryLabTests LabTest[] @relation("LabTestMandatorySubcat")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([shortName])
  @@index([source])
  @@index([clonedFromId])
  @@index([deletedAt])
  @@map("sub_categories")
}

/// Links a mapped party to a SubCategory with a position plus signing authority
/// and ordering metadata. Tenant-scoped (mirrors CategoryPersonMapping).
/// `person_id` is a polymorphic logical FK resolved by `type`: USER → persons,
/// CONSULTANT_DOCTOR/REPORTING_DOCTOR → doctors, EXTERNAL_REFERRAL →
/// external_referrals. `branch_id` is null for a tenant-level mapping (all
/// branches) or set to scope it to one branch. `priority` is validated in
/// SubCategoryService per branch against the tenant's mapping count.
model SubCategoryPersonMapping {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  subCategoryId String              @map("sub_category_id")
  personId      String              @map("person_id")
  type          PersonMappingType   @default(USER)
  branchId      String?             @map("branch_id")
  position      SubCategoryPosition
  isSignatory   Boolean             @default(false) @map("is_signatory")
  priority      Int
  isDefault     Boolean             @default(false) @map("is_default")

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([subCategoryId])
  @@index([personId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("sub_category_person_mappings")
}

/// An audit-trail entry: who did what, in which module, from where, and when.
/// Tenant-scoped + branch-level (CLAUDE.md §4.6 default tier). Rows are written
/// by the global AuditInterceptor (from `@Audit(...)` route metadata) or by
/// AuditService.record directly; they are effectively append-only.
///
/// Actor fields are snapshotted from the business JWT at write time so the log
/// stays readable even if the person's profile later changes.
model AuditLog {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id") // null = tenant-level action

  module      AuditModule
  action      AuditAction @default(OTHER)
  description String // human-readable "what the user performed"

  actorPersonId  String  @map("actor_person_id") // the User
  actorRoleKey   String? @map("actor_role_key") // Role = active_profile_key
  actorRoleLabel String? @map("actor_role_label") // human-readable role label
  ipAddress      String? @map("ip_address") // caller IP

  resourceId String? @map("resource_id") // optional id of the affected resource
  metadata   Json? // optional extra structured detail

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([module])
  @@index([actorPersonId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("audit_logs")
}

/// A master-data container for a branch. Tenant-scoped + branch-level. A non-main
/// branch may have several; the main branch is capped at one (its auto-created
/// default). The first master data is auto-created on branch creation (named after
/// the branch). Updatable; rows belonging to the tenant's main branch cannot be
/// deleted. Name is unique per branch among active rows (partial unique index in
/// prisma/rls.sql). RLS policy in prisma/rls.sql.
model MasterData {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  branchId    String  @map("branch_id")
  name        String
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("master_data")
}

/// A lab-test configuration inside a master data (tenant-scoped + branch-level;
/// `branchId` denormalised from the parent master data). Covers basic details,
/// pricing, TAT/schedule, flags, and notes. Child rows (samples, result params,
/// reference ranges/values) hang off this via `labTestId`. `testName`/`testCode`
/// are unique per master data among active rows (partial unique indexes in
/// prisma/rls.sql). CHECK constraints (price ordering, conditional-required
/// fields) also live in prisma/rls.sql. Cross-entity ids (department, category,
/// report template, pdf/image settings, approval workflow, mandatory dept/cat) are
/// nullable logical references (no Prisma relation) until those modules exist.
model LabTest {
  id           String  @id @default(uuid())
  // NULL for SITE_ADMIN global templates; set for TENANT rows (CLAUDE.md §4.2).
  tenantId     String? @map("tenant_id")
  branchId     String? @map("branch_id")
  masterDataId String? @map("master_data_id")

  // Origin: TENANT (default, tenant-scoped) or SITE_ADMIN (global template).
  source DataSource @default(TENANT)

  // Identity
  testName        String  @map("test_name")
  testDisplayName String? @map("test_display_name")
  testCode        String  @map("test_code")
  aka             String?

  // Classification — real relations to the catalogue tables (FK to
  // departments / categories / sub_categories).
  departmentId  String?      @map("department_id")
  department    Department?  @relation("LabTestDept", fields: [departmentId], references: [id])
  categoryId    String?      @map("category_id")
  category      Category?    @relation("LabTestCat", fields: [categoryId], references: [id])
  subCategoryId String?      @map("sub_category_id")
  subCategory   SubCategory? @relation("LabTestSubcat", fields: [subCategoryId], references: [id])

  // Basic config
  processMethod      ProcessMethod  @default(SINGLE_STEP) @map("process_method")
  icdCode            String?        @map("icd_code")
  loincCode          String?        @map("loinc_code")
  clinicalTags       String[]       @map("clinical_tags")
  reportTemplateId   String?        @map("report_template_id")
  samplePriorityType SamplePriority @default(ROUTINE) @map("sample_priority_type")
  pdfSettingsId      String?        @map("pdf_settings_id")
  imageSettingsId    String?        @map("image_settings_id")
  isEnableCms        Boolean        @default(true) @map("is_enable_cms")
  approvalWorkflowId String?        @map("approval_workflow_id")

  // Pricing (integer minor units)
  priceMsrp            Int     @default(0) @map("price_msrp")
  priceMaximum         Int     @default(0) @map("price_maximum")
  priceMinimum         Int     @default(0) @map("price_minimum")
  priceOriginal        Int     @default(0) @map("price_original")
  franchisePrice       Int     @default(0) @map("franchise_price")
  emergencyPrice       Int     @default(0) @map("emergency_price")
  commissionPrice      Int     @default(0) @map("commission_price")
  discountCapPct       Int     @default(0) @map("discount_cap_pct")
  isAllowPriceOverride Boolean @default(false) @map("is_allow_price_override")
  isAllowDiscounts     Boolean @default(true) @map("is_allow_discounts")

  // TAT
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @map("tat_max_unit")

  // Schedule (times stored as "HH:mm" strings, like Branch.openingTime)
  scheduleDays DayOfWeek[] @map("schedule_days")
  scheduleFrom String?     @map("schedule_from")
  scheduleTo   String?     @map("schedule_to")

  // Processing time
  procTimeMinValue Int?     @map("proc_time_min_value")
  procTimeMinUnit  TatUnit? @map("proc_time_min_unit")
  procTimeMaxValue Int?     @map("proc_time_max_value")
  procTimeMaxUnit  TatUnit? @map("proc_time_max_unit")

  // Approval window
  approvalTimeFrom String? @map("approval_time_from")
  approvalTimeTo   String? @map("approval_time_to")

  // Flags
  isHideInOrderScreen Boolean @default(false) @map("is_hide_in_order_screen")
  isPreferenceTest    Boolean @default(false) @map("is_preference_test")
  isMandatoryTest     Boolean @default(false) @map("is_mandatory_test")

  // Mandatory-test classification — real relations to the catalogue tables
  // (FK to departments / categories / sub_categories). Distinct from the
  // logical-ref classification fields above.
  mandatoryDeptId             String?             @map("mandatory_dept_id")
  mandatoryDept               Department?         @relation("LabTestMandatoryDept", fields: [mandatoryDeptId], references: [id])
  mandatoryCatId              String?             @map("mandatory_cat_id")
  mandatoryCat                Category?           @relation("LabTestMandatoryCat", fields: [mandatoryCatId], references: [id])
  mandatorySubcatId           String?             @map("mandatory_subcat_id")
  mandatorySubcat             SubCategory?        @relation("LabTestMandatorySubcat", fields: [mandatorySubcatId], references: [id])
  isRepeatIntervalRestriction Boolean             @default(false) @map("is_repeat_interval_restriction")
  repeatIntervalValue         Int?                @map("repeat_interval_value")
  repeatIntervalUnit          RepeatIntervalUnit? @map("repeat_interval_unit")

  // Active/inactive status (distinct from soft delete; NULL deletedAt = not deleted)
  isActive Boolean @default(true) @map("is_active")

  // Notes
  usefulFor               String? @map("useful_for")
  interpretationOfResults String? @map("interpretation_of_results")
  limitations             String?
  remarks                 String?
  references              String?

  // Version control: JSON array of
  // { version, effectiveFrom, effectiveTo, modifiedBy, approvedBy } (no snapshot).
  versionHistory Json @default("[]") @map("version_history")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([masterDataId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([mandatoryDeptId])
  @@index([mandatoryCatId])
  @@index([mandatorySubcatId])
  @@index([isActive])
  @@index([source])
  @@index([deletedAt])
  @@map("lab_test")
}

/// A sample requirement for a lab test. Many per test; at most one `isDefault`
/// per test (partial unique index in prisma/rls.sql). `sampleNameId` is a nullable
/// logical ref to the (not-yet-built) sample-types catalogue.
model LabTestSample {
  id        String  @id @default(uuid())
  // NULL when the parent lab test is a SITE_ADMIN template.
  tenantId  String? @map("tenant_id")
  branchId  String? @map("branch_id")
  labTestId String  @map("lab_test_id")

  sampleNameId               String?        @map("sample_name_id")
  sampleType                 String?        @map("sample_type")
  containerType              ContainerType? @map("container_type")
  sampleSize                 String?        @map("sample_size")
  collectionMethod           String?        @map("collection_method")
  numberOfSamples            Int            @default(1) @map("number_of_samples")
  stability                  String?
  transportTemperature       String?        @map("transport_temperature")
  preservative               String?
  sampleHandlingInstructions String?        @map("sample_handling_instructions")
  isFastingRequired          Boolean        @default(false) @map("is_fasting_required")
  isLightProtection          Boolean        @default(false) @map("is_light_protection")
  isDefault                  Boolean        @default(false) @map("is_default")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("lab_test_samples")
}

/// A result parameter for a lab test. `parameterCode` is unique per test among
/// active rows (partial unique index in prisma/rls.sql). `reflexTests` is a JSON
/// snapshot of { id, name } objects. Settings/layout/icon ids are nullable logical refs.
model LabTestResultParam {
  id        String  @id @default(uuid())
  // NULL when the parent lab test is a SITE_ADMIN template.
  tenantId  String? @map("tenant_id")
  branchId  String? @map("branch_id")
  labTestId String  @map("lab_test_id")

  // Group display
  groupName       String? @map("group_name")
  groupLayoutId   String? @map("group_layout_id")
  groupSettingsId String? @map("group_settings_id")

  // Parameter identity
  parameterName  String  @map("parameter_name")
  parameterCode  String  @map("parameter_code")
  method         String?
  attachFileUrl  String? @map("attach_file_url")
  iconSettingsId String? @map("icon_settings_id")
  reportingUnit  String? @map("reporting_unit")

  // Result behaviour
  resultType         ResultType      @map("result_type")
  parameterType      ParameterType   @default(MEASURED) @map("parameter_type")
  resultEntryMode    ResultEntryMode @default(MANUAL) @map("result_entry_mode")
  calculationFormula String?         @map("calculation_formula")
  resultRoundingType ResultRounding  @default(TWO_DECIMAL) @map("result_rounding_type")
  allowableUnits     String?         @map("allowable_units")
  decimalPlaces      Int             @default(2) @map("decimal_places")

  // Result-level critical bounds (separate from per-reference-range criticals)
  criticalMin Decimal? @map("critical_min") @db.Decimal(10, 4)
  criticalMax Decimal? @map("critical_max") @db.Decimal(10, 4)

  // Reflex tests — JSON snapshot of { id, name } objects (the FE sends and the
  // API returns this verbatim; not a relational/FK list).
  reflexTests Json @default("[]") @map("reflex_tests")

  // Meta
  notes     String?
  isNabl    Boolean @default(false) @map("is_nabl")
  isCap     Boolean @default(false) @map("is_cap")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([labTestId, sortOrder])
  @@index([deletedAt])
  @@map("lab_test_result_params")
}

/// A numeric reference range for a result parameter (`paramId` is a logical ref to
/// LabTestResultParam). CHECK constraints (lower≤upper, critical bounds,
/// age_from≤age_to) live in prisma/rls.sql.
model LabTestReferenceRange {
  id        String  @id @default(uuid())
  // NULL when the parent lab test is a SITE_ADMIN template.
  tenantId  String? @map("tenant_id")
  branchId  String? @map("branch_id")
  labTestId String  @map("lab_test_id")
  paramId   String  @map("param_id")

  method String?
  gender ReferenceGender @default(ALL)

  ageFrom     Int     @default(0) @map("age_from")
  ageFromUnit AgeUnit @default(YEARS) @map("age_from_unit")
  ageTo       Int     @default(999) @map("age_to")
  ageToUnit   AgeUnit @default(YEARS) @map("age_to_unit")

  lowerLimit              Decimal?     @map("lower_limit") @db.Decimal(10, 4)
  upperLimit              Decimal?     @map("upper_limit") @db.Decimal(10, 4)
  criticalMin             Decimal?     @map("critical_min") @db.Decimal(10, 4)
  criticalMax             Decimal?     @map("critical_max") @db.Decimal(10, 4)
  displayOfReferenceRange String?      @map("display_of_reference_range")
  abnormalFlagLogic       AbnormalFlag @default(BOLD_AND_RED) @map("abnormal_flag_logic")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([paramId])
  @@index([deletedAt])
  @@map("lab_test_reference_ranges")
}

/// A qualitative reference value for a result parameter (e.g. "Negative").
/// `paramId` is a logical ref to LabTestResultParam.
model LabTestReferenceValue {
  id        String  @id @default(uuid())
  // NULL when the parent lab test is a SITE_ADMIN template.
  tenantId  String? @map("tenant_id")
  branchId  String? @map("branch_id")
  labTestId String  @map("lab_test_id")
  paramId   String  @map("param_id")

  method String?
  gender ReferenceGender @default(ALL)

  ageFrom     Int     @default(0) @map("age_from")
  ageFromUnit AgeUnit @default(YEARS) @map("age_from_unit")
  ageTo       Int     @default(999) @map("age_to")
  ageToUnit   AgeUnit @default(YEARS) @map("age_to_unit")

  normalValueText         String       @map("normal_value_text")
  displayOfReferenceRange String?      @map("display_of_reference_range")
  abnormalFlagLogic       AbnormalFlag @default(BOLD_AND_RED) @map("abnormal_flag_logic")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([paramId])
  @@index([deletedAt])
  @@map("lab_test_reference_values")
}

/// A lab-panel configuration inside a master data (tenant-scoped + branch-level;
/// `branchId` denormalised from the parent master data, exactly like LabTest). A
/// panel groups several lab tests (via `LabPanelTest`) and carries its own
/// classification, applicability, report/turnaround settings, pricing, TAT, flags
/// and instructions. `panelName`/`panelCode` are unique per master data among
/// active rows (partial unique indexes in prisma/rls.sql). CHECK constraints
/// (price ordering, max-tests-removable rules) also live in prisma/rls.sql.
/// Cross-entity ids (department, category) are nullable logical references (no
/// Prisma relation), mirroring LabTest.
model LabPanel {
  id           String  @id @default(uuid())
  // NULL for SITE_ADMIN global templates; set for TENANT rows (CLAUDE.md §4.2).
  tenantId     String? @map("tenant_id")
  branchId     String? @map("branch_id")
  masterDataId String? @map("master_data_id")

  // Origin: TENANT (default, tenant-scoped) or SITE_ADMIN (global template).
  source DataSource @default(TENANT)

  // Identity
  bannerImage String? @map("banner_image")
  panelName   String  @map("panel_name")
  panelCode   String  @map("panel_code")

  // Classification (logical refs)
  categoryId   String? @map("category_id")
  departmentId String? @map("department_id")

  // Applicability + reporting
  applicableGender   ReferenceGender @default(ALL) @map("applicable_gender")
  applicableAgeGroup AgeGroup        @default(ALL) @map("applicable_age_group")
  reportType         ReportType      @default(COMBINED) @map("report_type")
  turnaroundPriority SamplePriority  @default(ROUTINE) @map("turnaround_priority")

  // Active/inactive status (distinct from soft delete; NULL deletedAt = not deleted)
  isActive Boolean @default(true) @map("is_active")

  // Pricing (integer minor units)
  priceMsrp       Int @default(0) @map("price_msrp")
  priceMinimum    Int @default(0) @map("price_minimum")
  priceMaximum    Int @default(0) @map("price_maximum")
  priceOriginal   Int @default(0) @map("price_original")
  franchisePrice  Int @default(0) @map("franchise_price")
  commissionPrice Int @default(0) @map("commission_price")

  // TAT (defaults to HOURS per the panel spec)
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @default(HOURS) @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @default(HOURS) @map("tat_max_unit")

  // Instructions
  panelInstructions String? @map("panel_instructions")

  // Flags
  isDisableDiscount     Boolean @default(false) @map("is_disable_discount")
  isEnableCms           Boolean @default(true) @map("is_enable_cms")
  isPreference          Boolean @default(false) @map("is_preference")
  isFastingRequired     Boolean @default(false) @map("is_fasting_required")
  isShowOnlineBooking   Boolean @default(true) @map("is_show_online_booking")
  isHomeCollection      Boolean @default(false) @map("is_home_collection")
  isAllowPartialBilling Boolean @default(false) @map("is_allow_partial_billing")

  // Max tests removable in a single order (0 = no limit). Only meaningful when
  // isAllowPartialBilling = true (enforced in service + CHECK in prisma/rls.sql).
  maxTestsRemovable Int @default(0) @map("max_tests_removable")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([masterDataId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([isActive])
  @@index([source])
  @@index([deletedAt])
  @@map("lab_panels")
}

/// A test included in a lab panel. Many per panel; `labTestId` is a logical ref to
/// an active LabTest in the same tenant (validated in LabPanelService). `isRemovable`
/// marks whether this specific test may be unchecked in an order (subject to the
/// panel's `maxTestsRemovable` + `isAllowPartialBilling`). Per-test price is read
/// from the referenced LabTest at billing time (not snapshotted here).
model LabPanelTest {
  id         String  @id @default(uuid())
  // NULL when the parent lab panel is a SITE_ADMIN template.
  tenantId   String? @map("tenant_id")
  branchId   String? @map("branch_id")
  labPanelId String  @map("lab_panel_id")
  labTestId  String  @map("lab_test_id")

  sortOrder   Int     @default(0) @map("sort_order")
  isRemovable Boolean @default(true) @map("is_removable")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labPanelId])
  @@index([labPanelId, sortOrder])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("lab_panel_tests")
}

/// A branch's operational Lab Test List entry — a materialized, independent
/// snapshot copied from a Master Data `LabTest` via the branch-lab-test import
/// (CLAUDE.md §4.6: tenant-scoped + branch-level). Parent scalar fields mirror
/// `LabTest`; the deep clinical sub-structure (samples, result params, reference
/// ranges/values) is snapshotted into `configSnapshot` JSON at import/sync time.
/// Edits here NEVER propagate back to Master Data. `sourceLabTestId` records the
/// Master Data test this copy came from (logical ref, no relation) so `sync` can
/// re-snapshot it. `testName`/`testCode` are unique per branch among active rows
/// (partial unique indexes in prisma/rls.sql). Classification ids are nullable
/// logical references (no Prisma relation), mirroring how LabPanel treats them.
model BranchLabTest {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  // Provenance (logical refs; no relation — the snapshot is independent).
  sourceLabTestId    String? @map("source_lab_test_id")
  sourceMasterDataId String? @map("source_master_data_id")

  // Identity
  testName        String  @map("test_name")
  testDisplayName String? @map("test_display_name")
  testCode        String  @map("test_code")
  aka             String?

  // Classification (logical refs)
  departmentId  String? @map("department_id")
  categoryId    String? @map("category_id")
  subCategoryId String? @map("sub_category_id")

  // Basic config
  processMethod      ProcessMethod  @default(SINGLE_STEP) @map("process_method")
  icdCode            String?        @map("icd_code")
  loincCode          String?        @map("loinc_code")
  clinicalTags       String[]       @map("clinical_tags")
  reportTemplateId   String?        @map("report_template_id")
  samplePriorityType SamplePriority @default(ROUTINE) @map("sample_priority_type")
  pdfSettingsId      String?        @map("pdf_settings_id")
  imageSettingsId    String?        @map("image_settings_id")
  isEnableCms        Boolean        @default(true) @map("is_enable_cms")
  approvalWorkflowId String?        @map("approval_workflow_id")

  // Pricing (integer minor units)
  priceMsrp            Int     @default(0) @map("price_msrp")
  priceMaximum         Int     @default(0) @map("price_maximum")
  priceMinimum         Int     @default(0) @map("price_minimum")
  priceOriginal        Int     @default(0) @map("price_original")
  franchisePrice       Int     @default(0) @map("franchise_price")
  emergencyPrice       Int     @default(0) @map("emergency_price")
  commissionPrice      Int     @default(0) @map("commission_price")
  discountCapPct       Int     @default(0) @map("discount_cap_pct")
  isAllowPriceOverride Boolean @default(false) @map("is_allow_price_override")
  isAllowDiscounts     Boolean @default(true) @map("is_allow_discounts")

  // TAT
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @map("tat_max_unit")

  // Schedule (times stored as "HH:mm" strings)
  scheduleDays DayOfWeek[] @map("schedule_days")
  scheduleFrom String?     @map("schedule_from")
  scheduleTo   String?     @map("schedule_to")

  // Processing time
  procTimeMinValue Int?     @map("proc_time_min_value")
  procTimeMinUnit  TatUnit? @map("proc_time_min_unit")
  procTimeMaxValue Int?     @map("proc_time_max_value")
  procTimeMaxUnit  TatUnit? @map("proc_time_max_unit")

  // Approval window
  approvalTimeFrom String? @map("approval_time_from")
  approvalTimeTo   String? @map("approval_time_to")

  // Flags
  isHideInOrderScreen Boolean @default(false) @map("is_hide_in_order_screen")
  isPreferenceTest    Boolean @default(false) @map("is_preference_test")
  isMandatoryTest     Boolean @default(false) @map("is_mandatory_test")

  // Mandatory-test classification (logical refs)
  mandatoryDeptId             String?             @map("mandatory_dept_id")
  mandatoryCatId              String?             @map("mandatory_cat_id")
  mandatorySubcatId           String?             @map("mandatory_subcat_id")
  isRepeatIntervalRestriction Boolean             @default(false) @map("is_repeat_interval_restriction")
  repeatIntervalValue         Int?                @map("repeat_interval_value")
  repeatIntervalUnit          RepeatIntervalUnit? @map("repeat_interval_unit")

  // Enable/disable in the branch list (distinct from soft delete).
  isActive Boolean @default(true) @map("is_active")

  // Variant model: rows sharing a `sourceLabTestId` form a group (one imported
  // original + its user duplicates). `isDuplicate` = false for the direct import
  // (sync refreshes these), true for a user-created copy (sync leaves these
  // alone). Exactly one row per group is `isDefault` (used for order creation).
  isDefault   Boolean @default(true) @map("is_default")
  isDuplicate Boolean @default(false) @map("is_duplicate")

  // Notes
  usefulFor               String? @map("useful_for")
  interpretationOfResults String? @map("interpretation_of_results")
  limitations             String?
  remarks                 String?
  references              String?

  // Point-in-time snapshot of the source test's children:
  // { samples: [...], resultParams: [{ ..., referenceRanges: [...], referenceValues: [...] }] }
  configSnapshot Json @default("{}") @map("config_snapshot")

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([sourceLabTestId])
  @@index([isActive])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("branch_lab_tests")
}

/// A branch's operational Lab Panel List entry — a materialized, independent
/// snapshot copied from a Master Data `LabPanel` via the branch-lab-panel import
/// (tenant-scoped + branch-level). Parent scalar fields mirror `LabPanel`; the
/// panel's member tests are held relationally in `BranchLabPanelTest` pointing at
/// this branch's `BranchLabTest` copies. `sourceLabPanelId` records the Master
/// Data panel this copy came from (logical ref) so `sync` can re-snapshot it.
/// `panelName`/`panelCode` are unique per branch among active rows (partial unique
/// indexes in prisma/rls.sql).
model BranchLabPanel {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  // Provenance (logical refs; no relation — the snapshot is independent).
  sourceLabPanelId   String? @map("source_lab_panel_id")
  sourceMasterDataId String? @map("source_master_data_id")

  // Identity
  bannerImage String? @map("banner_image")
  panelName   String  @map("panel_name")
  panelCode   String  @map("panel_code")

  // Classification (logical refs)
  categoryId   String? @map("category_id")
  departmentId String? @map("department_id")

  // Applicability + reporting
  applicableGender   ReferenceGender @default(ALL) @map("applicable_gender")
  applicableAgeGroup AgeGroup        @default(ALL) @map("applicable_age_group")
  reportType         ReportType      @default(COMBINED) @map("report_type")
  turnaroundPriority SamplePriority  @default(ROUTINE) @map("turnaround_priority")

  // Enable/disable in the branch list (distinct from soft delete).
  isActive Boolean @default(true) @map("is_active")

  // Variant model (mirrors BranchLabTest): rows sharing a `sourceLabPanelId` form
  // a group (one imported original + user duplicates). `isDuplicate` = false for
  // the direct import (sync refreshes), true for a user copy (sync skips). Exactly
  // one row per group is `isDefault` (used for order creation).
  isDefault   Boolean @default(true) @map("is_default")
  isDuplicate Boolean @default(false) @map("is_duplicate")

  // Pricing (integer minor units)
  priceMsrp       Int @default(0) @map("price_msrp")
  priceMinimum    Int @default(0) @map("price_minimum")
  priceMaximum    Int @default(0) @map("price_maximum")
  priceOriginal   Int @default(0) @map("price_original")
  franchisePrice  Int @default(0) @map("franchise_price")
  commissionPrice Int @default(0) @map("commission_price")

  // TAT (defaults to HOURS per the panel spec)
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @default(HOURS) @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @default(HOURS) @map("tat_max_unit")

  // Instructions
  panelInstructions String? @map("panel_instructions")

  // Flags
  isDisableDiscount     Boolean @default(false) @map("is_disable_discount")
  isEnableCms           Boolean @default(true) @map("is_enable_cms")
  isPreference          Boolean @default(false) @map("is_preference")
  isFastingRequired     Boolean @default(false) @map("is_fasting_required")
  isShowOnlineBooking   Boolean @default(true) @map("is_show_online_booking")
  isHomeCollection      Boolean @default(false) @map("is_home_collection")
  isAllowPartialBilling Boolean @default(false) @map("is_allow_partial_billing")

  maxTestsRemovable Int @default(0) @map("max_tests_removable")

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([sourceLabPanelId])
  @@index([isActive])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("branch_lab_panels")
}

/// A test included in a branch's Lab Panel List entry. `branchLabTestId` points at
/// a `BranchLabTest` copy in the same branch (not a Master Data test). Rebuilt on
/// sync to match the source panel's current composition. Unique per panel among
/// active rows (partial unique index in prisma/rls.sql).
model BranchLabPanelTest {
  id               String @id @default(uuid())
  tenantId         String @map("tenant_id")
  branchId         String @map("branch_id")
  branchLabPanelId String @map("branch_lab_panel_id")
  branchLabTestId  String @map("branch_lab_test_id")

  sortOrder   Int     @default(0) @map("sort_order")
  isRemovable Boolean @default(true) @map("is_removable")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([branchLabPanelId])
  @@index([branchLabPanelId, sortOrder])
  @@index([branchLabTestId])
  @@index([deletedAt])
  @@map("branch_lab_panel_tests")
}

/// A SiteAdmin-curated named group of SITE_ADMIN lab-test templates (e.g. "Full
/// Body Checkup"). Platform-level (CLAUDE.md §4.2) — no `tenantId`/`source` and
/// intentionally excluded from RLS, like siteadmin_users. `groupName` is unique
/// among active rows (partial unique index in prisma/rls.sql). The mapped lab
/// tests are managed via `TestGroupMapping`.
model TestGroup {
  id        String @id @default(uuid())
  groupName String @map("group_name")

  // Actor trail: the SiteAdmin who created/last-updated the group.
  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  mappings TestGroupMapping[]

  @@index([deletedAt])
  @@map("test_groups")
}

/// Junction: one row per (test group, SITE_ADMIN lab test) pair. `labTestId` is a
/// logical ref to an active SITE_ADMIN LabTest (validated in TestGroupService),
/// mirroring LabPanelTest. Platform-level (no tenant scoping); a lab test appears
/// at most once per group among active rows (partial unique index in
/// prisma/rls.sql).
model TestGroupMapping {
  id          String @id @default(uuid())
  testGroupId String @map("test_group_id")
  labTestId   String @map("lab_test_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  testGroup TestGroup @relation(fields: [testGroupId], references: [id])

  @@index([testGroupId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("test_group_mappings")
}

/// An external reference lab a tenant sends samples to. Tenant-scoped,
/// tenant-level (CLAUDE.md §4.6) — the center belongs to the business as a whole.
/// Carries a single selected lab test + lab panel (`labTestId`/`labPanelId`) and a
/// NABL-accreditation flag. `code` is
/// system-generated & immutable (OC-00001…, from Tenant.outsourceCenterCounter).
/// `outsource_center_name` + `code` are unique per tenant among active rows
/// (partial unique indexes in prisma/rls.sql). RLS policy in prisma/rls.sql.
model OutsourceCenter {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  code     String

  // Basic details
  name      String  @map("outsource_center_name")
  shortName String? @map("short_name")
  address   String?
  city      String
  state     String?
  pincode   String?

  // Legal & financial (all optional)
  gstNumber         String? @map("gst_number")
  panNumber         String? @map("pan_number")
  accountHolderName String? @map("account_holder_name")
  bankName          String? @map("bank_name")
  bankAccountNumber String? @map("bank_account_number")
  ifscCode          String? @map("ifsc_code")

  isActive         Boolean @default(true) @map("is_active")
  isNablAccredited Boolean @default(false) @map("is_nabl_accredited")

  // Single selected lab test / lab panel the center handles. Logical refs to a
  // LabTest / LabPanel (no Prisma relation, mirroring LabPanelTest.labTestId);
  // validated active + tenant-scoped in OutsourceCenterService.
  labTestId  String? @map("lab_test_id")
  labPanelId String? @map("lab_panel_id")

  contacts OutsourceCenterContact[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([labTestId])
  @@index([labPanelId])
  @@index([deletedAt])
  @@map("outsource_centers")
}

/// A contact person for an outsource center, one row per fixed role. Tenant-scoped,
/// tenant-level (inherits the center's tier; `tenantId` denormalised for RLS +
/// defence in depth). At most one active contact per role per center (partial
/// unique index in prisma/rls.sql). RLS policy in prisma/rls.sql.
model OutsourceCenterContact {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  outsourceCenterId String               @map("outsource_center_id")
  role              OutsourceContactRole

  name   String?
  mobile String?
  email  String?

  outsourceCenter OutsourceCenter @relation(fields: [outsourceCenterId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([outsourceCenterId])
  @@index([deletedAt])
  @@map("outsource_center_contacts")
}

/// An external referring panel (clinic/hospital/lab) that sends business to the
/// tenant. Tenant-scoped, tenant-level (CLAUDE.md §4.6) — it belongs to the business
/// as a whole. `code` is system-generated & immutable (RP-00001…, from
/// Tenant.referralPanelCounter). `referral_panel_name` + `code` are unique per tenant
/// among active rows, and the user-supplied `panel_code` is unique per tenant among
/// active non-null rows (partial unique indexes in prisma/rls.sql). Contact persons
/// are flat columns (one name/mobile/email per fixed role) rather than a child table.
/// Commission/bonus slabs are JSON arrays validated by DTOs (see
/// ReferralPanelService). `referralPanelSettingsId` is a nullable logical ref to a
/// not-yet-modelled settings template. Assigned lab tests/panels (the "lab test/panel
/// list") are child rows (ReferralPanelLabTest / ReferralPanelLabPanel). RLS policy in
/// prisma/rls.sql.
/// Reusable billing/communication settings template for the referral module,
/// keyed by `clientType` (CASH / PREPAID / POSTPAID). Referenced (optionally) by
/// ReferralPanel, ReferralDoctor, ExternalReferral and InternalReferral via their
/// nullable `referralPanelSettingsId`. Tenant-scoped, tenant-level (CLAUDE.md §4.6
/// — matches ReferralPanel); `branchId` is carried for future use but the service
/// scopes reads by tenant only. At most one default per (tenant, clientType) among
/// ACTIVE rows, and `settingName` unique per tenant among ACTIVE rows (partial
/// unique indexes in prisma/rls.sql). RLS policy in prisma/rls.sql.
model ReferralPanelSettings {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  settingName String                      @map("setting_name")
  clientType  ReferralClientType          @map("client_type")
  isDefault   Boolean                     @default(false) @map("is_default")
  status      ReferralPanelSettingsStatus @default(ACTIVE)

  // ── Communication ──
  isSendBillsToPatient   Boolean @default(false) @map("is_send_bills_to_patient")
  isSendBillsToB2b       Boolean @default(false) @map("is_send_bills_to_b2b")
  isSendBillsToDoctor    Boolean @default(false) @map("is_send_bills_to_doctor")
  isSendReportsToPatient Boolean @default(false) @map("is_send_reports_to_patient")
  isSendReportsToB2b     Boolean @default(false) @map("is_send_reports_to_b2b")
  isSendReportsToDoctor  Boolean @default(false) @map("is_send_reports_to_doctor")

  // ── Credit / invoicing (POSTPAID) ──
  creditLimitAmount           Decimal? @map("credit_limit_amount") @db.Decimal(12, 2)
  isRestrictOrderCreditLimit  Boolean  @default(false) @map("is_restrict_order_credit_limit")
  isRestrictReportCreditLimit Boolean  @default(false) @map("is_restrict_report_credit_limit")
  creditAllowedDays           Int?     @map("credit_allowed_days")
  isRestrictOrderCreditDays   Boolean  @default(false) @map("is_restrict_order_credit_days")
  isRestrictReportCreditDays  Boolean  @default(false) @map("is_restrict_report_credit_days")
  daysAfterInvoice            Int?     @map("days_after_invoice")
  isRestrictOrderPostInvoice  Boolean  @default(false) @map("is_restrict_order_post_invoice")
  isRestrictReportPostInvoice Boolean  @default(false) @map("is_restrict_report_post_invoice")
  isAutoInvoice               Boolean  @default(false) @map("is_auto_invoice")
  raiseInvoiceCreditLimit     Decimal? @map("raise_invoice_credit_limit") @db.Decimal(12, 2)
  invoiceFrequencyDays        Int?     @map("invoice_frequency_days")
  isOverlapMonthEndClose      Boolean  @default(false) @map("is_overlap_month_end_close")
  isAllowManualInvoice        Boolean  @default(false) @map("is_allow_manual_invoice")
  invoiceEmailTriggerHours    Int?     @map("invoice_email_trigger_hours")

  // ── Wallet / bonus (PREPAID) ──
  minWalletAdvance            Decimal?           @map("min_wallet_advance") @db.Decimal(12, 2)
  minAdvanceForBonus          Decimal?           @map("min_advance_for_bonus") @db.Decimal(12, 2)
  minWalletBalance            Decimal?           @map("min_wallet_balance") @db.Decimal(12, 2)
  isRestrictOrderAtMinBalance Boolean            @default(false) @map("is_restrict_order_at_min_balance")
  isReminderAt75Percent       Boolean            @default(false) @map("is_reminder_at_75_percent")
  isReminderAtMinBalance      Boolean            @default(false) @map("is_reminder_at_min_balance")
  bonusType                   ReferralBonusType? @map("bonus_type")
  bonusPercentage             Decimal?           @map("bonus_percentage") @db.Decimal(5, 2)
  bonusFixedAmount            Decimal?           @map("bonus_fixed_amount") @db.Decimal(12, 2)
  bonusExtraAmount            Decimal?           @map("bonus_extra_amount") @db.Decimal(12, 2)
  isAllowNegativeBalance      Boolean            @default(false) @map("is_allow_negative_balance")
  maxNegativeBalance          Decimal?           @map("max_negative_balance") @db.Decimal(12, 2)
  isRestrictOrderNegative     Boolean            @default(false) @map("is_restrict_order_negative")
  isRestrictReportNegative    Boolean            @default(false) @map("is_restrict_report_negative")

  // ── Payment ──
  isAllowOtherPaymentModes Boolean @default(false) @map("is_allow_other_payment_modes")

  // ── Back-relations (the four referral entities that reference this template) ──
  referralPanels    ReferralPanel[]
  referralDoctors   ReferralDoctor[]
  externalReferrals ExternalReferral[]
  internalReferrals InternalReferral[]

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([clientType])
  @@index([deletedAt])
  @@map("referral_panel_settings")
}

model ReferralPanel {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")
  code     String

  // ── Basic details ──
  name                    String                 @map("referral_panel_name")
  shortName               String?                @map("short_name")
  panelCode               String?                @map("panel_code")
  clientType              ReferralClientType     @map("client_type")
  referralPanelSettingsId String?                @map("referral_panel_settings_id")
  referralPanelSettings   ReferralPanelSettings? @relation(fields: [referralPanelSettingsId], references: [id])
  isActive                Boolean                @default(true) @map("is_active")

  // ── Address details ──
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String?
  state        String?
  pincode      String?
  gstNumber    String? @map("gst_number")
  panNumber    String? @map("pan_number")

  // ── Bank details ──
  accountHolderName String? @map("account_holder_name")
