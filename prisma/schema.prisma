/// A doctor in a tenant's registry — either a REPORTING doctor (signs/reports on
/// tests) or a CONSULTANT (sees patients). Tenant-scoped, tenant-level (CLAUDE.md
/// §4.6): the registry belongs to the business as a whole, not a single branch.
/// `registration_no` is unique per tenant among ACTIVE rows (partial unique index
/// in prisma/rls.sql). Classification links (`department`, `category`) are real
/// relations to active rows of the same tenant (ownership validated in
/// DoctorsService); `subCategory` is a free-text "super specialization" label per
/// spec. Signatory authority is captured by the `signatory*Ids` JSON arrays. RLS
/// policy in prisma/rls.sql.
model Doctor {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  doctorType DoctorType @map("doctor_type")

  // Branch scope (CLAUDE.md §4.5). Nullable column so legacy/tenant-level rows
  // can exist, but the create API requires it. Client-supplied — validated
  // against the caller's tenant in DoctorsService (never trusted from the body).
  branchId String? @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Identity
  salutation     Salutation?
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  dateOfBirth    DateTime?   @map("date_of_birth") @db.Date
  gender         Gender?
  phone          String
  alternatePhone String?     @map("alternate_phone")
  email          String?
  address        String?

  // Registration
  registrationNo      String    @map("registration_no")
  registrationCouncil String?   @map("registration_council")
  registrationExpiry  DateTime? @map("registration_expiry") @db.Date

  // Classification — "specialization" links to a category, "super specialization"
  // links to a sub-category. department/category/sub-category are active rows of
  // the same tenant (validated in DoctorsService).
  categoryId    String?      @map("category_id")
  category      Category?    @relation(fields: [categoryId], references: [id])
  subCategoryId String?      @map("sub_category_id")
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  departmentId  String?      @map("department_id")
  department    Department?  @relation(fields: [departmentId], references: [id])

  // Accreditation & signatory authority
  isNablAuthorized        Boolean @default(false) @map("is_nabl_authorized")
  isCapCertified          Boolean @default(false) @map("is_cap_certified")
  isIsoCertified          Boolean @default(false) @map("is_iso_certified")
  isReportSignatory       Boolean @default(false) @map("is_report_signatory")
  signatoryName           String? @map("signatory_name")
  signatoryDesignation    String? @map("signatory_designation")
  signatureImagePath      String? @map("signature_image_path")
  signatoryDepartmentIds  Json?   @map("signatory_department_ids")
  signatoryCategoryIds    Json?   @map("signatory_category_ids")
  signatorySubCategoryIds Json?   @map("signatory_sub_category_ids")

  // Banking
  accountHolderName String?           @map("account_holder_name")
  bankName          String?           @map("bank_name")
  accountNumber     String?           @map("account_number")
  ifscCode          String?           @map("ifsc_code")
  paymentMode       DoctorPaymentMode @default(BANK_TRANSFER) @map("payment_mode")

  // Charges
  consultationFee Decimal @default(0) @map("consultation_fee") @db.Decimal(10, 2)
  emergencyFee    Decimal @default(0) @map("emergency_fee") @db.Decimal(10, 2)
  followUpFee     Decimal @default(0) @map("follow_up_fee") @db.Decimal(10, 2)
  isAllowDiscount Boolean @default(false) @map("is_allow_discount")

  // Status & misc
  status      DoctorStatus @default(ACTIVE)
  joiningDate DateTime?    @map("joining_date") @db.Date
  remarks     String?

  // Children (managed via the parent in DoctorsService)
  qualifications DoctorQualification[]
  experiences    DoctorExperience[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([departmentId])
  @@index([status])
  @@index([deletedAt])
  @@map("doctors")
}

/// A qualification (degree) held by a doctor. Tenant-scoped; lifecycle is managed
/// via the parent doctor (replace-on-update; soft-deleted with the parent). The
/// `onDelete: Cascade` relation is a DB safety net only — the app soft-deletes.
model DoctorQualification {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  doctorId String @map("doctor_id")

  degree        String?
  institution   String?
  yearOfPassing Int?    @map("year_of_passing")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_qualifications")
}

/// A past/current work engagement of a doctor. `toDate` NULL means the role is
/// current. Tenant-scoped; managed via the parent doctor like DoctorQualification.
model DoctorExperience {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  doctorId String @map("doctor_id")

  organisation String?
  rolePosition String?   @map("role_position")
  fromDate     DateTime? @map("from_date") @db.Date
  toDate       DateTime? @map("to_date") @db.Date

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_experience")
}

/// An external referring doctor in a tenant's registry who sends business to the
/// lab and earns commission/incentives. Tenant-scoped, tenant-level (CLAUDE.md
/// §4.6): the registry belongs to the business as a whole, not a single branch.
/// Identity mirrors `Doctor`; the commission/TDS/payment/incentive block mirrors
/// `ReferralPanel` (conditional fields validated + normalised in
/// ReferralDoctorService; slabs stored as JSON). Classification links
/// (`department`, `category` = Specialty, `subCategory` = Super Specialty) are real
/// relations to active rows of the same tenant (validated in ReferralDoctorService).
/// Assigned lab tests/panels are child rows (`ReferralDoctorLabTest` /
/// `ReferralDoctorLabPanel`, replace-all on update). `fullName`/`age`/per-experience
/// `duration` are derived in the service, not stored. RLS policy in prisma/rls.sql.
model ReferralDoctor {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  // Personal details
  firstName     String    @map("first_name")
  middleName    String?   @map("middle_name")
  lastName      String?   @map("last_name")
  gender        Gender    @default(MALE)
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  mobileNumber  String    @map("mobile_number")
  email         String?
  aadhaarNumber String?   @map("aadhaar_number")
  panNumber     String?   @map("pan_number")

  // Professional details — classification links to active rows of the same tenant
  // (validated in ReferralDoctorService). category = Specialty, subCategory = Super
  // Specialty.
  departmentId  String?      @map("department_id")
  department    Department?  @relation(fields: [departmentId], references: [id])
  categoryId    String?      @map("category_id")
  category      Category?    @relation(fields: [categoryId], references: [id])
  subCategoryId String?      @map("sub_category_id")
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])

  medicalLicenseNumber  String?   @map("medical_license_number")
  registrationCouncil   String?   @map("registration_council")
  registrationValidTill DateTime? @map("registration_valid_till") @db.Date

  // Logical ref to a ReferralPanelSettings template in the tenant (validated in
  // ReferralDoctorService to belong to the caller's tenant).
  referralPanelSettingsId String?                @map("referral_panel_settings_id")
  referralPanelSettings   ReferralPanelSettings? @relation(fields: [referralPanelSettingsId], references: [id])

  // Commission & TDS (conditional fields normalised in the service; slabs as JSON
  // of { monthlyBusinessFrom, monthlyBusinessTo, commissionPct }).
  isCommissionApplicable Boolean               @default(false) @map("is_commission_applicable")
  commissionType         CommissionType?       @map("commission_type")
  commissionPctLabTest   Decimal?              @map("commission_pct_lab_test") @db.Decimal(5, 2)
  commissionPctLabPanel  Decimal?              @map("commission_pct_lab_panel") @db.Decimal(5, 2)
  commissionSlabs        Json                  @default("[]") @map("commission_slabs")
  fixedCommissionCycle   FixedCommissionCycle? @map("fixed_commission_cycle")
  fixedAmount            Decimal?              @map("fixed_amount") @db.Decimal(10, 2)
  isTdsApplicable        Boolean               @default(false) @map("is_tds_applicable")
  tds                    Int?                  @map("tds")

  // Payment & incentive (bonus slabs as JSON of
  // { monthlyBusinessFrom, monthlyBusinessTo, bonusPct }).
  paymentCycle               PaymentCycle        @default(NA) @map("payment_cycle")
  paymentMode                ReferralPaymentMode @default(BANK_TRANSFER) @map("payment_mode")
  monthlyTargetAmount        Int                 @default(0) @map("monthly_target_amount")
  isIncentiveBonusApplicable Boolean             @default(false) @map("is_incentive_bonus_applicable")
  bonusSlabs                 Json                @default("[]") @map("bonus_slabs")

  // Attachment & remarks (file stored as name + URL; upload handled elsewhere)
  fileName String? @map("file_name")
  fileUrl  String? @map("file_url")
  remarks  String?

  // Status
  status ReferralDoctorStatus @default(ACTIVE)

  // Children (managed via the parent in ReferralDoctorService)
  qualifications ReferralDoctorQualification[]
  experiences    ReferralDoctorExperience[]
  labTests       ReferralDoctorLabTest[]
  labPanels      ReferralDoctorLabPanel[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([referralPanelSettingsId])
  @@index([status])
  @@index([deletedAt])
  @@map("referral_doctors")
}

/// A qualification (degree) held by a referral doctor. Tenant-scoped; lifecycle is
/// managed via the parent (replace-on-update; soft-deleted with the parent). The
/// `onDelete: Cascade` relation is a DB safety net only — the app soft-deletes.
model ReferralDoctorQualification {
  id               String @id @default(uuid())
