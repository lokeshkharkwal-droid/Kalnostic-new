  fromDate     DateTime? @map("from_date") @db.Date
  toDate       DateTime? @map("to_date") @db.Date

  referralDoctor ReferralDoctor @relation(fields: [referralDoctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralDoctorId])
  @@index([deletedAt])
  @@map("referral_doctor_experience")
}

/// A lab test assigned to a referral doctor (the "lab test list" — one row per
