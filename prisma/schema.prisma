// Prisma schema for Kalnostics New.
//
// Conventions (CLAUDE.md §3 + §4):
//   - model = PascalCase singular; table = snake_case plural (@@map)
//   - columns = snake_case (@map)
//   - primary keys = Prisma-default UUID v4
//   - every model: created_at / updated_at / deleted_at (plain soft delete)
//
// Two tiers (CLAUDE.md §4.2):
//   - PLATFORM models (no tenant_id): Tenant, Person, PersonCredentials,
//     SiteAdminUser, RefreshToken, PersonTenantEnrollment
//   - TENANT-SCOPED models (tenant_id + RLS): Branch, UserBranchProfile,
//     UserProfilePermissionOverride, ReceptionistDoctorMapping,
//     TenantMainBranch, Schedule, Department, DepartmentPersonMapping
//
// RLS policies for tenant-scoped tables live in prisma/rls.sql (CLAUDE.md §4.3).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  GRACE_PERIOD // payment overdue, still operational
  SUSPENDED // fully blocked
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
  UNKNOWN
}

enum SiteAdminRole {
  CONTENT_ADMIN
  OPERATIONS_ADMIN
  FULL_ADMIN
  SUPER_OWNER
}

enum BranchType {
  DIAGNOSTIC
  RADIOLOGY
  OPD
  IPD
  PHARMACY
  INVENTORY
  BLOOD_BANK
  FRANCHISE
  COMBINED
  ASSISTANT
  ACCESSION
  TECHNICIAN
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ScheduleStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

/// The position a person holds within a department.
enum DepartmentPosition {
  HOD
  SPECIALIST
  CONSULTANT
  MANAGER
  TECHNICIAN
}

/// Whether a category stands alone or hangs off a department.
enum CategoryType {
  INDEPENDENT
  UNDER_DEPARTMENT
}

/// The position a person holds within a category (mirrors DepartmentPosition).
enum CategoryPosition {
  HOD
  SPECIALIST
  CONSULTANT
  MANAGER
  TECHNICIAN
}

/// Whether a sub-category stands alone, hangs off a department, or off a category.
enum SubCategoryType {
  INDEPENDENT
  UNDER_DEPARTMENT
  UNDER_CATEGORY
}

/// The position a person holds within a sub-category (mirrors CategoryPosition).
enum SubCategoryPosition {
  HOD
  SPECIALIST
  CONSULTANT
  MANAGER
  TECHNICIAN
}

enum ShiftName {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

/// Which functional area an audit event belongs to (the "Module" column).
enum AuditModule {
  USER
  BRANCH
  SCHEDULE
  TENANT
  DEPARTMENT
  CATEGORY
  SUB_CATEGORY
  MASTER_DATA
  LAB_TEST
  LAB_PANEL
  OUTSOURCE_CENTER
  DOCTOR
  AUTH
  SITEADMIN // reserved; not written to in this phase (business audit only)
}

/// Fixed contact-person roles for an outsource center (UPPERCASE per project
/// convention). All five are optional on a center.
enum OutsourceContactRole {
  DIRECTOR
  ACCESSION_PERSON
  REGISTRATION_PERSON
  LOGISTICS_PERSON
  ACCOUNTS_PERSON
}

/// The kind of operation an audit event records.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  OTHER
}

// ── Lab-test enums (UPPERCASE per project convention; values map to the raw
//    snake_case spec, e.g. SINGLE_STEP ↔ 'single_step') ──────────────────────────

/// Whether a test is processed in one step or several.
enum ProcessMethod {
  SINGLE_STEP
  MULTI_STEP
}

/// How urgently a sample/test is processed.
enum SamplePriority {
  ROUTINE
  URGENT
  STAT
}

/// Unit for turnaround / processing time windows.
enum TatUnit {
  MINUTES
  HOURS
  DAYS
}

/// Unit for the repeat-interval restriction between orders of a test.
enum RepeatIntervalUnit {
  HOURS
  DAYS
  MONTHS
  YEARS
}

/// Age-group applicability for a lab panel (CMS filtering + age-appropriate
/// package suggestions). Distinct from the per-range `AgeUnit` bounds on a test.
enum AgeGroup {
  ALL
  ADULT
  PEDIATRIC
  SENIOR
}

/// How a lab panel's results are reported. COMBINED merges every test result
/// into one report; SEPARATE generates an individual report per test.
enum ReportType {
  COMBINED
  SEPARATE
}

/// How a result parameter's value is produced/expressed.
enum ResultType {
  QUANTITATIVE
  QUALITATIVE
  CALCULATED
}

/// Whether a parameter is measured directly or computed from a formula.
enum ParameterType {
  MEASURED
  CALCULATED
}

/// Whether a parameter's result is entered by hand or pulled automatically.
enum ResultEntryMode {
  MANUAL
  AUTO
}

/// Rounding applied to a numeric result.
enum ResultRounding {
  NO_ROUNDING
  ONE_DECIMAL
  TWO_DECIMAL
  THREE_DECIMAL
  WHOLE_NUMBER
}

/// Gender applicability for a reference range/value. Distinct from the
/// person-level `Gender` (which lacks `ALL` and carries OTHER/PREFER_NOT_TO_SAY).
enum ReferenceGender {
  ALL
  MALE
  FEMALE
}

/// Unit for age bounds on a reference range/value.
enum AgeUnit {
  DAYS
  MONTHS
  YEARS
}

/// How an out-of-range result is visually flagged on the report.
enum AbnormalFlag {
  BOLD_AND_RED
  BOLD_ONLY
  ITALIC
  UNDERLINE
  COLOUR_HIGHLIGHT
}

/// Sample container type (tube/colour or receptacle).
enum ContainerType {
  EDTA_TUBE_PURPLE_TOP
  PLAIN_TUBE_RED_TOP
  FLUORIDE_TUBE_GREY_TOP
  URINE_CONTAINER
  STERILE_CONTAINER
}

// ── Doctor enums (UPPERCASE per project convention) ─────────────────────────────

/// Whether a doctor reports on tests (signs reports) or consults patients.
enum DoctorType {
  REPORTING
  CONSULTANT
}

/// Honorific prefix. Display labels ("Dr.", "Prof.") are resolved on the frontend.
enum Salutation {
  DR
  MR
  MRS
  MS
  PROF
}

/// How a doctor is paid out.
enum DoctorPaymentMode {
  BANK_TRANSFER
  CASH
  CHEQUE
}

/// Active/inactive lifecycle for a doctor record (distinct from soft delete;
/// NULL deletedAt = not deleted).
enum DoctorStatus {
  ACTIVE
  INACTIVE
}

// ── Platform-level models (NO tenant_id) ────────────────────────────────────────

/// One row per registered business. "Business info" = the fields here.
model Tenant {
  id   String @id @default(uuid())
  name String

  /// URL-safe subdomain slug ({slug}.kalnostics.com). Unique, immutable after create.
  slug         String  @unique
  customDomain String? @unique @map("custom_domain")

  email   String? // primary contact email (billing/notifications)
  phone   String?
  address Json? // registered business address

  // ── Subscription ──
  subscriptionStatus SubscriptionStatus @default(TRIALING) @map("subscription_status")
  subscriptionPlanId String?            @map("subscription_plan_id")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  subscriptionEndsAt DateTime?          @map("subscription_ends_at")
  gracePeriodEndsAt  DateTime?          @map("grace_period_ends_at")

  // ── Locale & branding (timezone/currency/date_format/language/logo/colors) ──
  settings Json?

  isActive               Boolean @default(true) @map("is_active")
  mrnCounter             Int     @default(0) @map("mrn_counter") // per-tenant sequential patient MRN
  mrnPrefix              String? @map("mrn_prefix")
  branchCounter          Int     @default(0) @map("branch_counter") // per-tenant sequential branch code
  departmentCounter      Int     @default(0) @map("department_counter") // per-tenant sequential department code
  categoryCounter        Int     @default(0) @map("category_counter") // per-tenant sequential category code
  subCategoryCounter     Int     @default(0) @map("sub_category_counter") // per-tenant sequential sub-category code
  outsourceCenterCounter Int     @default(0) @map("outsource_center_counter") // per-tenant sequential outsource-center code
  createdBy              String? @map("created_by") // SiteAdmin user id

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("tenants")
}

/// Platform-level identity for ALL humans (patients AND staff). No tenant_id.
model Person {
  id String @id @default(uuid())

  /// Globally-unique Medical Record Number across all businesses. Read-only after creation.
  platformMrn String @unique @map("platform_mrn")

  salutation  String?
  firstName   String      @map("first_name")
  lastName    String?     @map("last_name")
  dateOfBirth DateTime?   @map("date_of_birth") @db.Date
  gender      Gender?
  bloodGroup  BloodGroup? @map("blood_group")

  /// Phone/email are global de-duplication keys; locked after first use.
  phone String? @unique
  email String? @unique

  address  Json?
  photoUrl String? @map("photo_url")
  idType   String? @map("id_type")
  idNumber String? @map("id_number") // encrypted at rest (deferred)

  /// First business to register this person owns their basic details. NULL = self-registered.
  ownerTenantId String? @map("owner_tenant_id")

  isPatient Boolean @default(false) @map("is_patient")
  isStaff   Boolean @default(false) @map("is_staff")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([ownerTenantId])
  @@index([deletedAt])
  @@map("persons")
}

/// Login credentials — one row per person.
model PersonCredentials {
  id       String @id @default(uuid())
  personId String @unique @map("person_id")

  // Login identifiers (precedence: phone → email → system_username)
  phone                     String? @unique
  email                     String? @unique
  systemUsername            String? @unique @map("system_username")
  isSystemGeneratedUsername Boolean @default(false) @map("is_system_generated_username")

  passwordHash   String  @map("password_hash") // bcrypt cost 12
  isTempPassword Boolean @default(false) @map("is_temp_password")

  // Security
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("person_credentials")
}

/// SiteAdmin users — separate auth system, separate table, separate JWT.
model SiteAdminUser {
  id           String        @id @default(uuid())
  firstName    String        @map("first_name")
  lastName     String?       @map("last_name")
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         SiteAdminRole @default(CONTENT_ADMIN)
  isActive     Boolean       @default(true) @map("is_active")

  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  createdBy      String?   @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("siteadmin_users")
}

/// Refresh tokens — server-side, single-use rotation, SHA-256 hashed at rest.
model RefreshToken {
  id         String  @id @default(uuid())
  personId   String  @map("person_id")
  tokenHash  String  @unique @map("token_hash")
  branchId   String? @map("branch_id")
  profileKey String? @map("profile_key")
  issuedToIp String? @map("issued_to_ip")
  userAgent  String? @map("user_agent")

  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  isRevoked Boolean  @default(false) @map("is_revoked")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([personId])
  @@map("refresh_tokens")
}

/// Cross-business patient linkage (each business keeps its own tenant_mrn).
model PersonTenantEnrollment {
  id        String  @id @default(uuid())
  personId  String  @map("person_id")
  tenantId  String  @map("tenant_id")
  branchId  String  @map("branch_id")
  tenantMrn String? @map("tenant_mrn")

  enrolledAt DateTime @default(now()) @map("enrolled_at")
  enrolledBy String?  @map("enrolled_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([personId, tenantId])
  @@map("person_tenant_enrollments")
}

// ── Tenant-scoped models (tenant_id + RLS) ──────────────────────────────────────

/// A physical location belonging to a tenant.
model Branch {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  name       String
  branchType BranchType @map("branch_type")
  // System-generated, immutable. Per-tenant sequential code (e.g. "BR-00001")
  // derived from Tenant.branchCounter. Unique per tenant among active rows
  // (partial unique index in prisma/rls.sql); never client-supplied.
  code       String

  status          BranchStatus @default(ACTIVE)
  establishedDate DateTime?    @map("established_date")

  // Location
  addressLine String? @map("address_line")
  city        String?
  state       String?
  pincode     String?

  // Contact
  phone        String?
  email        String?
  managerName  String? @map("manager_name")
  managerPhone String? @map("manager_phone")
  labDirector  String? @map("lab_director")

  // Operations
  openingTime     String?     @map("opening_time") // "HH:mm" (24h, branch-local)
  closingTime     String?     @map("closing_time") // "HH:mm" (24h, branch-local)
  dailyCapacity   Int?        @map("daily_capacity") // max orders processable per day
  operationalDays DayOfWeek[] @map("operational_days")

  // Compliance / misc
  gstNo     String? @map("gst_no")
  licenseNo String? @map("license_no")
  remarks   String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([deletedAt])
  @@map("branches")
}

/// Assigns a person a profile (role) at a branch (or tenant-level when branch is null).
model UserBranchProfile {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  personId   String  @map("person_id")
  branchId   String? @map("branch_id") // null = tenant-level profile (e.g. business_admin)
  profileKey String  @map("profile_key")

  isDefault  Boolean   @default(false) @map("is_default")
  isActive   Boolean   @default(true) @map("is_active")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  assignedBy String?   @map("assigned_by")
  revokedAt  DateTime? @map("revoked_at")
  revokedBy  String?   @map("revoked_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([personId])
  @@index([branchId])
  @@map("user_branch_profiles")
}

/// Per-assignment permission overrides (allow/deny; inherit = no row).
model UserProfilePermissionOverride {
  id             String  @id @default(uuid())
  tenantId       String  @map("tenant_id")
  personId       String  @map("person_id")
  branchId       String? @map("branch_id")
  profileKey     String  @map("profile_key")
  permissionCode String  @map("permission_code")
  override       String // 'allow' | 'deny'

  setBy String? @map("set_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId, personId, profileKey])
  @@map("user_profile_permission_overrides")
}

/// Maps a receptionist to the doctors they handle at a branch.
model ReceptionistDoctorMapping {
  id                   String  @id @default(uuid())
  tenantId             String  @map("tenant_id")
  branchId             String  @map("branch_id")
  receptionistPersonId String  @map("receptionist_person_id")
  doctorPersonId       String  @map("doctor_person_id")
  assignedBy           String? @map("assigned_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId, branchId, receptionistPersonId])
  @@map("receptionist_doctor_mappings")
}

/// The single main branch per tenant (one row per tenant; changed via upsert).
/// Tenant-scoped: `tenant_id` is UNIQUE, so a tenant can have at most one main
/// branch at a time. RLS policy in prisma/rls.sql.
model TenantMainBranch {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  branchId String @map("branch_id")

  setBy String? @map("set_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([branchId])
  @@map("tenant_main_branch")
}

/// A working schedule (shift plan) for a branch. Tenant-scoped + branch-level.
///
/// `shifts` is stored as JSON (validated by the schedule DTOs):
///   - shifts: Array<{ shiftName: ShiftName, startTime, endTime,
///                      breakStartTime, breakEndTime, activeDays: DayOfWeek[] }>
///             (times "HH:mm", 24h, branch-local; activeDays = the days the
///              shift runs on)
///
/// At most one ACTIVE schedule per branch may cover any given date — enforced in
/// the service (see ScheduleService.create/update). NIGHT shifts may cross
/// midnight (endTime <= startTime); overlap checks are midnight-aware and only
/// flag shifts that overlap on a shared active day.
model Schedule {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  planName String         @map("plan_name")
  status   ScheduleStatus @default(DRAFT)

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date // null = open-ended (+∞)

  shifts Json

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("schedules")
}

/// A department within a tenant (business-wide; NOT branch-scoped — CLAUDE.md
/// §4.6 tenant-level tier). The `code` is system-generated and immutable:
/// `{INITIALS}-Dep-{n}`, where INITIALS are derived from the tenant name and `n`
/// is a per-tenant sequential counter (Tenant.departmentCounter), e.g.
/// `ABC-Dep-0`, `ABC-Dep-1`. Unique per tenant among active rows (partial unique
/// index in prisma/rls.sql). RLS policy in prisma/rls.sql.
model Department {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  name        String
  description String?
  code        String

  /// User-set short prefix for space-constrained dropdowns (2-6 chars, uppercase
  /// A-Z/0-9). Mandatory and editable. Unique per tenant among active rows
  /// (partial unique index in prisma/rls.sql).
  shortName String @map("short_name")

  isActive Boolean @default(true) @map("is_active")

  /// "Module mapping" — reuses the same enum as Branch.branchType, so the valid
  /// values stay identical to branch creation. A department may cover several.
  moduleMapping BranchType[] @map("module_mapping")

  personMappings DepartmentPersonMapping[]

  /// Categories that hang off this department (CategoryType.UNDER_DEPARTMENT).
  categories Category[]

  /// Sub-categories that hang off this department (SubCategoryType.UNDER_DEPARTMENT).
  subCategories SubCategory[]

  /// Doctors whose specialization links to this department (logical via relation).
  doctors Doctor[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([shortName])
  @@index([deletedAt])
  @@map("departments")
}

/// Links a Person (platform-level) to a Department with a position plus signing
/// authority and ordering metadata. Tenant-scoped (mirrors UserBranchProfile —
/// `person_id` is a logical FK to the platform `persons` table). `priority` is
/// validated in DepartmentService against the tenant's total mapping count.
model DepartmentPersonMapping {
  id           String             @id @default(uuid())
  tenantId     String             @map("tenant_id")
  departmentId String             @map("department_id")
  personId     String             @map("person_id")
  position     DepartmentPosition
  isSignatory  Boolean            @default(false) @map("is_signatory")
  priority     Int
  isDefault    Boolean            @default(false) @map("is_default")

  department Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([personId])
  @@index([deletedAt])
  @@map("department_person_mappings")
}

/// A category, the same shape as a Department plus a type dimension: INDEPENDENT
/// categories stand alone (department_id NULL); UNDER_DEPARTMENT categories link
/// to an active department of the same tenant (department_id set). The
/// type↔link invariant is enforced in CategoryService + a CHECK in
/// prisma/rls.sql (Prisma can't express conditional constraints).
///
/// Tenant-scoped, tenant-level (CLAUDE.md §4.6). `code` is system-generated &
/// immutable: `{INITIALS}-Cat-{n}`, INITIALS from the tenant name, `n` a 0-based
/// per-tenant sequence from Tenant.categoryCounter. Unique per tenant among
/// active rows (partial unique index in prisma/rls.sql). RLS policy in rls.sql.
model Category {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  name        String
  description String?
  code        String

  /// User-set short prefix for space-constrained dropdowns (2-6 chars, uppercase
  /// A-Z/0-9). Mandatory and editable. Unique within the parent department among
  /// active rows; INDEPENDENT categories are unique per tenant (partial unique
  /// indexes in prisma/rls.sql).
  shortName String @map("short_name")

  isActive     Boolean      @default(true) @map("is_active")
  categoryType CategoryType @map("category_type")

  /// INDEPENDENT → null; UNDER_DEPARTMENT → an active department of this tenant.
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  /// "Module mapping" — reuses the same enum as Branch.branchType, exactly like
  /// Department. A category may cover several.
  moduleMapping BranchType[] @map("module_mapping")

  personMappings CategoryPersonMapping[]

  /// Sub-categories that hang off this category (SubCategoryType.UNDER_CATEGORY).
  subCategories SubCategory[]

  /// Doctors whose specialization links to this category (logical via relation).
  doctors Doctor[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([shortName])
  @@index([deletedAt])
  @@map("categories")
}

/// Links a Person (platform-level) to a Category with a position plus signing
/// authority and ordering metadata. Tenant-scoped (mirrors
/// DepartmentPersonMapping — `person_id` is a logical FK to the platform
/// `persons` table). `priority` is validated in CategoryService against the
/// tenant's total mapping count.
model CategoryPersonMapping {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  categoryId  String           @map("category_id")
  personId    String           @map("person_id")
  position    CategoryPosition
  isSignatory Boolean          @default(false) @map("is_signatory")
  priority    Int
  isDefault   Boolean          @default(false) @map("is_default")

  category Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([categoryId])
  @@index([personId])
  @@index([deletedAt])
  @@map("category_person_mappings")
}

/// A sub-category, the same shape as a Category plus a third type option. Its
/// type dimension picks the parent: INDEPENDENT stands alone (both FKs NULL);
/// UNDER_DEPARTMENT links to an active department of the same tenant
/// (department_id set); UNDER_CATEGORY links to an active category of the same
/// tenant (category_id set). The type↔link invariant is enforced in
/// SubCategoryService + a CHECK in prisma/rls.sql (Prisma can't express
/// conditional constraints).
///
/// Tenant-scoped, tenant-level (CLAUDE.md §4.6). `code` is system-generated &
/// immutable: `{INITIALS}-SubCat-{n}`, INITIALS from the tenant name, `n` a
/// 0-based per-tenant sequence from Tenant.subCategoryCounter. Unique per tenant
/// among active rows (partial unique index in prisma/rls.sql). RLS in rls.sql.
model SubCategory {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  name        String
  description String?
  code        String

  /// User-set short prefix for space-constrained dropdowns (2-6 chars, uppercase
  /// A-Z/0-9). Mandatory and editable. Unique within the parent category
  /// (UNDER_CATEGORY) or parent department (UNDER_DEPARTMENT) among active rows;
  /// INDEPENDENT sub-categories are unique per tenant (partial unique indexes in
  /// prisma/rls.sql).
  shortName String @map("short_name")

  isActive        Boolean         @default(true) @map("is_active")
  subCategoryType SubCategoryType @map("sub_category_type")

  /// UNDER_DEPARTMENT → an active department of this tenant; else null.
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  /// UNDER_CATEGORY → an active category of this tenant; else null.
  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  /// "Module mapping" — reuses the same enum as Branch.branchType, exactly like
  /// Category. A sub-category may cover several.
  moduleMapping BranchType[] @map("module_mapping")

  personMappings SubCategoryPersonMapping[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([shortName])
  @@index([deletedAt])
  @@map("sub_categories")
}

/// Links a Person (platform-level) to a SubCategory with a position plus signing
/// authority and ordering metadata. Tenant-scoped (mirrors CategoryPersonMapping
/// — `person_id` is a logical FK to the platform `persons` table). `priority` is
/// validated in SubCategoryService against the tenant's total mapping count.
model SubCategoryPersonMapping {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  subCategoryId String              @map("sub_category_id")
  personId      String              @map("person_id")
  position      SubCategoryPosition
  isSignatory   Boolean             @default(false) @map("is_signatory")
  priority      Int
  isDefault     Boolean             @default(false) @map("is_default")

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([subCategoryId])
  @@index([personId])
  @@index([deletedAt])
  @@map("sub_category_person_mappings")
}

/// An audit-trail entry: who did what, in which module, from where, and when.
/// Tenant-scoped + branch-level (CLAUDE.md §4.6 default tier). Rows are written
/// by the global AuditInterceptor (from `@Audit(...)` route metadata) or by
/// AuditService.record directly; they are effectively append-only.
///
/// Actor fields are snapshotted from the business JWT at write time so the log
/// stays readable even if the person's profile later changes.
model AuditLog {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id") // null = tenant-level action

  module      AuditModule
  action      AuditAction @default(OTHER)
  description String // human-readable "what the user performed"

  actorPersonId  String  @map("actor_person_id") // the User
  actorRoleKey   String? @map("actor_role_key") // Role = active_profile_key
  actorRoleLabel String? @map("actor_role_label") // human-readable role label
  ipAddress      String? @map("ip_address") // caller IP

  resourceId String? @map("resource_id") // optional id of the affected resource
  metadata   Json? // optional extra structured detail

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([module])
  @@index([actorPersonId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("audit_logs")
}

/// A master-data container for a branch. Tenant-scoped + branch-level. A non-main
/// branch may have several; the main branch is capped at one (its auto-created
/// default). The first master data is auto-created on branch creation (named after
/// the branch). Updatable; rows belonging to the tenant's main branch cannot be
/// deleted. Name is unique per branch among active rows (partial unique index in
/// prisma/rls.sql). RLS policy in prisma/rls.sql.
model MasterData {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  branchId    String  @map("branch_id")
  name        String
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([deletedAt])
  @@map("master_data")
}

/// A lab-test configuration inside a master data (tenant-scoped + branch-level;
/// `branchId` denormalised from the parent master data). Covers basic details,
/// pricing, TAT/schedule, flags, and notes. Child rows (samples, result params,
/// reference ranges/values) hang off this via `labTestId`. `testName`/`testCode`
/// are unique per master data among active rows (partial unique indexes in
/// prisma/rls.sql). CHECK constraints (price ordering, conditional-required
/// fields) also live in prisma/rls.sql. Cross-entity ids (department, category,
/// report template, pdf/image settings, approval workflow, mandatory dept/cat) are
/// nullable logical references (no Prisma relation) until those modules exist.
model LabTest {
  id           String @id @default(uuid())
  tenantId     String @map("tenant_id")
  branchId     String @map("branch_id")
  masterDataId String @map("master_data_id")

  // Identity
  testName        String  @map("test_name")
  testDisplayName String? @map("test_display_name")
  testCode        String  @map("test_code")
  aka             String?

  // Classification (logical refs)
  departmentId  String? @map("department_id")
  categoryId    String? @map("category_id")
  subCategoryId String? @map("sub_category_id")

  // Basic config
  processMethod      ProcessMethod  @default(SINGLE_STEP) @map("process_method")
  icdCode            String?        @map("icd_code")
  loincCode          String?        @map("loinc_code")
  clinicalTags       String[]       @map("clinical_tags")
  reportTemplateId   String?        @map("report_template_id")
  samplePriorityType SamplePriority @default(ROUTINE) @map("sample_priority_type")
  pdfSettingsId      String?        @map("pdf_settings_id")
  imageSettingsId    String?        @map("image_settings_id")
  isEnableCms        Boolean        @default(true) @map("is_enable_cms")
  approvalWorkflowId String?        @map("approval_workflow_id")

  // Pricing (integer minor units)
  priceMsrp            Int     @default(0) @map("price_msrp")
  priceMaximum         Int     @default(0) @map("price_maximum")
  priceMinimum         Int     @default(0) @map("price_minimum")
  priceOriginal        Int     @default(0) @map("price_original")
  franchisePrice       Int     @default(0) @map("franchise_price")
  emergencyPrice       Int     @default(0) @map("emergency_price")
  discountCapPct       Int     @default(0) @map("discount_cap_pct")
  isAllowPriceOverride Boolean @default(false) @map("is_allow_price_override")
  isAllowDiscounts     Boolean @default(true) @map("is_allow_discounts")

  // TAT
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @map("tat_max_unit")

  // Schedule (times stored as "HH:mm" strings, like Branch.openingTime)
  scheduleDays DayOfWeek[] @map("schedule_days")
  scheduleFrom String?     @map("schedule_from")
  scheduleTo   String?     @map("schedule_to")

  // Processing time
  procTimeMinValue Int?     @map("proc_time_min_value")
  procTimeMinUnit  TatUnit? @map("proc_time_min_unit")
  procTimeMaxValue Int?     @map("proc_time_max_value")
  procTimeMaxUnit  TatUnit? @map("proc_time_max_unit")

  // Approval window
  approvalTimeFrom String? @map("approval_time_from")
  approvalTimeTo   String? @map("approval_time_to")

  // Flags
  isHideInOrderScreen         Boolean             @default(false) @map("is_hide_in_order_screen")
  isPreferenceTest            Boolean             @default(false) @map("is_preference_test")
  isMandatoryTest             Boolean             @default(false) @map("is_mandatory_test")
  mandatoryDeptId             String?             @map("mandatory_dept_id")
  mandatoryCatId              String?             @map("mandatory_cat_id")
  mandatorySubcatId           String?             @map("mandatory_subcat_id")
  isRepeatIntervalRestriction Boolean             @default(false) @map("is_repeat_interval_restriction")
  repeatIntervalValue         Int?                @map("repeat_interval_value")
  repeatIntervalUnit          RepeatIntervalUnit? @map("repeat_interval_unit")

  // Active/inactive status (distinct from soft delete; NULL deletedAt = not deleted)
  isActive Boolean @default(true) @map("is_active")

  // Notes
  usefulFor               String? @map("useful_for")
  interpretationOfResults String? @map("interpretation_of_results")
  limitations             String?
  remarks                 String?
  references              String?

  // Version control: JSON array of
  // { version, effectiveFrom, effectiveTo, modifiedBy, approvedBy } (no snapshot).
  versionHistory Json @default("[]") @map("version_history")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([masterDataId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("lab_test")
}

/// A sample requirement for a lab test. Many per test; at most one `isDefault`
/// per test (partial unique index in prisma/rls.sql). `sampleNameId` is a nullable
/// logical ref to the (not-yet-built) sample-types catalogue.
model LabTestSample {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  branchId  String @map("branch_id")
  labTestId String @map("lab_test_id")

  sampleNameId               String?        @map("sample_name_id")
  sampleType                 String?        @map("sample_type")
  containerType              ContainerType? @map("container_type")
  sampleSize                 String?        @map("sample_size")
  collectionMethod           String?        @map("collection_method")
  numberOfSamples            Int            @default(1) @map("number_of_samples")
  stability                  String?
  transportTemperature       String?        @map("transport_temperature")
  preservative               String?
  sampleHandlingInstructions String?        @map("sample_handling_instructions")
  isFastingRequired          Boolean        @default(false) @map("is_fasting_required")
  isLightProtection          Boolean        @default(false) @map("is_light_protection")
  isDefault                  Boolean        @default(false) @map("is_default")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("lab_test_samples")
}

/// A result parameter for a lab test. `parameterCode` is unique per test among
/// active rows (partial unique index in prisma/rls.sql). `reflexTestIds` is a list
/// of LabTest ids (logical refs). Settings/layout/icon ids are nullable logical refs.
model LabTestResultParam {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  branchId  String @map("branch_id")
  labTestId String @map("lab_test_id")

  // Group display
  groupName       String? @map("group_name")
  groupLayoutId   String? @map("group_layout_id")
  groupSettingsId String? @map("group_settings_id")

  // Parameter identity
  parameterName  String  @map("parameter_name")
  parameterCode  String  @map("parameter_code")
  method         String?
  attachFileUrl  String? @map("attach_file_url")
  iconSettingsId String? @map("icon_settings_id")
  reportingUnit  String? @map("reporting_unit")

  // Result behaviour
  resultType         ResultType      @map("result_type")
  parameterType      ParameterType   @default(MEASURED) @map("parameter_type")
  resultEntryMode    ResultEntryMode @default(MANUAL) @map("result_entry_mode")
  calculationFormula String?         @map("calculation_formula")
  resultRoundingType ResultRounding  @default(TWO_DECIMAL) @map("result_rounding_type")
  allowableUnits     String?         @map("allowable_units")
  decimalPlaces      Int             @default(2) @map("decimal_places")

  // Reflex tests (LabTest ids)
  reflexTestIds String[] @map("reflex_test_ids")

  // Meta
  notes     String?
  isNabl    Boolean @default(false) @map("is_nabl")
  isCap     Boolean @default(false) @map("is_cap")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([labTestId, sortOrder])
  @@index([deletedAt])
  @@map("lab_test_result_params")
}

/// A numeric reference range for a result parameter (`paramId` is a logical ref to
/// LabTestResultParam). CHECK constraints (lower≤upper, critical bounds,
/// age_from≤age_to) live in prisma/rls.sql.
model LabTestReferenceRange {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  branchId  String @map("branch_id")
  labTestId String @map("lab_test_id")
  paramId   String @map("param_id")

  method String?
  gender ReferenceGender @default(ALL)

  ageFrom     Int     @default(0) @map("age_from")
  ageFromUnit AgeUnit @default(YEARS) @map("age_from_unit")
  ageTo       Int     @default(999) @map("age_to")
  ageToUnit   AgeUnit @default(YEARS) @map("age_to_unit")

  lowerLimit              Decimal?     @map("lower_limit") @db.Decimal(10, 4)
  upperLimit              Decimal?     @map("upper_limit") @db.Decimal(10, 4)
  criticalMin             Decimal?     @map("critical_min") @db.Decimal(10, 4)
  criticalMax             Decimal?     @map("critical_max") @db.Decimal(10, 4)
  displayOfReferenceRange String?      @map("display_of_reference_range")
  abnormalFlagLogic       AbnormalFlag @default(BOLD_AND_RED) @map("abnormal_flag_logic")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([paramId])
  @@index([deletedAt])
  @@map("lab_test_reference_ranges")
}

/// A qualitative reference value for a result parameter (e.g. "Negative").
/// `paramId` is a logical ref to LabTestResultParam.
model LabTestReferenceValue {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  branchId  String @map("branch_id")
  labTestId String @map("lab_test_id")
  paramId   String @map("param_id")

  method String?
  gender ReferenceGender @default(ALL)

  ageFrom     Int     @default(0) @map("age_from")
  ageFromUnit AgeUnit @default(YEARS) @map("age_from_unit")
  ageTo       Int     @default(999) @map("age_to")
  ageToUnit   AgeUnit @default(YEARS) @map("age_to_unit")

  normalValueText         String       @map("normal_value_text")
  displayOfReferenceRange String?      @map("display_of_reference_range")
  abnormalFlagLogic       AbnormalFlag @default(BOLD_AND_RED) @map("abnormal_flag_logic")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([paramId])
  @@index([deletedAt])
  @@map("lab_test_reference_values")
}

/// A lab-panel configuration inside a master data (tenant-scoped + branch-level;
/// `branchId` denormalised from the parent master data, exactly like LabTest). A
/// panel groups several lab tests (via `LabPanelTest`) and carries its own
/// classification, applicability, report/turnaround settings, pricing, TAT, flags
/// and instructions. `panelName`/`panelCode` are unique per master data among
/// active rows (partial unique indexes in prisma/rls.sql). CHECK constraints
/// (price ordering, max-tests-removable rules) also live in prisma/rls.sql.
/// Cross-entity ids (department, category) are nullable logical references (no
/// Prisma relation), mirroring LabTest.
model LabPanel {
  id           String @id @default(uuid())
  tenantId     String @map("tenant_id")
  branchId     String @map("branch_id")
  masterDataId String @map("master_data_id")

  // Identity
  bannerImage String? @map("banner_image")
  panelName   String  @map("panel_name")
  panelCode   String  @map("panel_code")

  // Classification (logical refs)
  categoryId   String? @map("category_id")
  departmentId String? @map("department_id")

  // Applicability + reporting
  applicableGender   ReferenceGender @default(ALL) @map("applicable_gender")
  applicableAgeGroup AgeGroup        @default(ALL) @map("applicable_age_group")
  reportType         ReportType      @default(COMBINED) @map("report_type")
  turnaroundPriority SamplePriority  @default(ROUTINE) @map("turnaround_priority")

  // Active/inactive status (distinct from soft delete; NULL deletedAt = not deleted)
  isActive Boolean @default(true) @map("is_active")

  // Pricing (integer minor units)
  priceMsrp      Int @default(0) @map("price_msrp")
  priceMinimum   Int @default(0) @map("price_minimum")
  priceMaximum   Int @default(0) @map("price_maximum")
  priceOriginal  Int @default(0) @map("price_original")
  franchisePrice Int @default(0) @map("franchise_price")

  // TAT (defaults to HOURS per the panel spec)
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @default(HOURS) @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @default(HOURS) @map("tat_max_unit")

  // Instructions
  panelInstructions String? @map("panel_instructions")

  // Flags
  isDisableDiscount     Boolean @default(false) @map("is_disable_discount")
  isEnableCms           Boolean @default(true) @map("is_enable_cms")
  isPreference          Boolean @default(false) @map("is_preference")
  isFastingRequired     Boolean @default(false) @map("is_fasting_required")
  isShowOnlineBooking   Boolean @default(true) @map("is_show_online_booking")
  isHomeCollection      Boolean @default(false) @map("is_home_collection")
  isAllowPartialBilling Boolean @default(false) @map("is_allow_partial_billing")

  // Max tests removable in a single order (0 = no limit). Only meaningful when
  // isAllowPartialBilling = true (enforced in service + CHECK in prisma/rls.sql).
  maxTestsRemovable Int @default(0) @map("max_tests_removable")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([masterDataId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("lab_panels")
}

/// A test included in a lab panel. Many per panel; `labTestId` is a logical ref to
/// an active LabTest in the same tenant (validated in LabPanelService). `isRemovable`
/// marks whether this specific test may be unchecked in an order (subject to the
/// panel's `maxTestsRemovable` + `isAllowPartialBilling`). Per-test price is read
/// from the referenced LabTest at billing time (not snapshotted here).
model LabPanelTest {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  branchId   String @map("branch_id")
  labPanelId String @map("lab_panel_id")
  labTestId  String @map("lab_test_id")

  sortOrder   Int     @default(0) @map("sort_order")
  isRemovable Boolean @default(true) @map("is_removable")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labPanelId])
  @@index([labPanelId, sortOrder])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("lab_panel_tests")
}

/// An external reference lab a tenant sends samples to. Tenant-scoped,
/// tenant-level (CLAUDE.md §4.6) — the center belongs to the business as a whole
/// and is assigned to branches via `OutsourceCenterBranchAssignment`. `code` is
/// system-generated & immutable (OC-00001…, from Tenant.outsourceCenterCounter).
/// `outsource_center_name` + `code` are unique per tenant among active rows
/// (partial unique indexes in prisma/rls.sql). RLS policy in prisma/rls.sql.
model OutsourceCenter {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  code     String

  // Basic details
  name      String  @map("outsource_center_name")
  shortName String? @map("short_name")
  address   String?
  city      String
  state     String?
  pincode   String?

  // Legal & financial (all optional)
  gstNumber         String? @map("gst_number")
  panNumber         String? @map("pan_number")
  accountHolderName String? @map("account_holder_name")
  bankName          String? @map("bank_name")
  bankAccountNumber String? @map("bank_account_number")
  ifscCode          String? @map("ifsc_code")

  isActive Boolean @default(true) @map("is_active")

  contacts    OutsourceCenterContact[]
  assignments OutsourceCenterBranchAssignment[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([deletedAt])
  @@map("outsource_centers")
}

/// A contact person for an outsource center, one row per fixed role. Tenant-scoped,
/// tenant-level (inherits the center's tier; `tenantId` denormalised for RLS +
/// defence in depth). At most one active contact per role per center (partial
/// unique index in prisma/rls.sql). RLS policy in prisma/rls.sql.
model OutsourceCenterContact {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  outsourceCenterId String               @map("outsource_center_id")
  role              OutsourceContactRole

  name   String?
  mobile String?
  email  String?

  outsourceCenter OutsourceCenter @relation(fields: [outsourceCenterId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([outsourceCenterId])
  @@index([deletedAt])
  @@map("outsource_center_contacts")
}

/// Assigns an outsource center to a branch. The specific lab tests and lab panels
/// the outsource party may handle for that branch are stored as child rows
/// (`OutsourceCenterBranchTest` / `OutsourceCenterBranchPanel`). Tenant-scoped +
/// branch-level (CLAUDE.md §4.6); `branchId` is non-nullable because the row IS the
/// branch assignment. At least one test or panel must be selected per assigned
/// branch; this is enforced in OutsourceCenterService, not the DB. One active
/// assignment per (center, branch) (partial unique index in prisma/rls.sql). RLS
/// policy in prisma/rls.sql.
model OutsourceCenterBranchAssignment {
  id                String @id @default(uuid())
  tenantId          String @map("tenant_id")
  branchId          String @map("branch_id")
  outsourceCenterId String @map("outsource_center_id")

  outsourceCenter OutsourceCenter              @relation(fields: [outsourceCenterId], references: [id])
  tests           OutsourceCenterBranchTest[]
  panels          OutsourceCenterBranchPanel[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([outsourceCenterId])
  @@index([deletedAt])
  @@map("outsource_center_branch_assignments")
}

/// A single lab test the outsource center may handle for a branch (one row per
/// selected test on an assignment). `labTestId` is a logical ref to a LabTest on
/// that branch (no Prisma relation, mirroring LabPanelTest.labTestId); validated in
/// OutsourceCenterService to be an active test on the assignment's branch. One
/// active row per (assignment, test) (partial unique index in prisma/rls.sql). RLS
/// policy in prisma/rls.sql.
model OutsourceCenterBranchTest {
  id                String @id @default(uuid())
  tenantId          String @map("tenant_id")
  branchId          String @map("branch_id")
  outsourceCenterId String @map("outsource_center_id")
  assignmentId      String @map("assignment_id")
  labTestId         String @map("lab_test_id")

  assignment OutsourceCenterBranchAssignment @relation(fields: [assignmentId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([outsourceCenterId])
  @@index([assignmentId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("outsource_center_branch_tests")
}

/// A single lab panel the outsource center may handle for a branch (one row per
/// selected panel on an assignment). `labPanelId` is a logical ref to a LabPanel on
/// that branch (no Prisma relation); validated in OutsourceCenterService to be an
/// active panel on the assignment's branch. One active row per (assignment, panel)
/// (partial unique index in prisma/rls.sql). RLS policy in prisma/rls.sql.
model OutsourceCenterBranchPanel {
  id                String @id @default(uuid())
  tenantId          String @map("tenant_id")
  branchId          String @map("branch_id")
  outsourceCenterId String @map("outsource_center_id")
  assignmentId      String @map("assignment_id")
  labPanelId        String @map("lab_panel_id")

  assignment OutsourceCenterBranchAssignment @relation(fields: [assignmentId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([outsourceCenterId])
  @@index([assignmentId])
  @@index([labPanelId])
  @@index([deletedAt])
  @@map("outsource_center_branch_panels")
}

/// A doctor in a tenant's registry — either a REPORTING doctor (signs/reports on
/// tests) or a CONSULTANT (sees patients). Tenant-scoped, tenant-level (CLAUDE.md
/// §4.6): the registry belongs to the business as a whole, not a single branch.
/// `registration_no` is unique per tenant among ACTIVE rows (partial unique index
/// in prisma/rls.sql). Classification links (`department`, `category`) are real
/// relations to active rows of the same tenant (ownership validated in
/// DoctorsService); `subCategory` is a free-text "super specialization" label per
/// spec. Signatory authority is captured by the `signatory*Ids` JSON arrays. RLS
/// policy in prisma/rls.sql.
model Doctor {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  doctorType DoctorType @map("doctor_type")

  // Identity
  salutation     Salutation?
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  dateOfBirth    DateTime?   @map("date_of_birth") @db.Date
  gender         Gender?
  phone          String
  alternatePhone String?     @map("alternate_phone")
  email          String?
  address        String?

  // Registration
  registrationNo      String    @map("registration_no")
  registrationCouncil String?   @map("registration_council")
  registrationExpiry  DateTime? @map("registration_expiry") @db.Date

  // Classification — "specialization" links to a category, "super specialization"
  // is the free-text subCategory (spec). department/category are active rows of
  // the same tenant (validated in DoctorsService).
  categoryId   String?     @map("category_id")
  category     Category?   @relation(fields: [categoryId], references: [id])
  subCategory  String?     @map("sub_category")
  departmentId String?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  // Accreditation & signatory authority
  isNablAuthorized        Boolean @default(false) @map("is_nabl_authorized")
  isCapCertified          Boolean @default(false) @map("is_cap_certified")
  isIsoCertified          Boolean @default(false) @map("is_iso_certified")
  isReportSignatory       Boolean @default(false) @map("is_report_signatory")
  signatoryName           String? @map("signatory_name")
  signatoryDesignation    String? @map("signatory_designation")
  signatureImagePath      String? @map("signature_image_path")
  signatoryDepartmentIds  Json?   @map("signatory_department_ids")
  signatoryCategoryIds    Json?   @map("signatory_category_ids")
  signatorySubCategoryIds Json?   @map("signatory_sub_category_ids")

  // Fees
  consultationFee Decimal @default(0) @map("consultation_fee") @db.Decimal(10, 2)
  emergencyFee    Decimal @default(0) @map("emergency_fee") @db.Decimal(10, 2)
  followUpFee     Decimal @default(0) @map("follow_up_fee") @db.Decimal(10, 2)
  isAllowDiscount Boolean @default(false) @map("is_allow_discount")

  // Banking
  accountHolderName String?           @map("account_holder_name")
  bankName          String?           @map("bank_name")
  accountNumber     String?           @map("account_number")
  ifscCode          String?           @map("ifsc_code")
  paymentMode       DoctorPaymentMode @default(BANK_TRANSFER) @map("payment_mode")

  // Status & misc
  status      DoctorStatus @default(ACTIVE)
  joiningDate DateTime?    @map("joining_date") @db.Date
  remarks     String?

  // Children (managed via the parent in DoctorsService)
  qualifications DoctorQualification[]
  experiences    DoctorExperience[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@index([deletedAt])
  @@map("doctors")
}

/// A qualification (degree) held by a doctor. Tenant-scoped; lifecycle is managed
/// via the parent doctor (replace-on-update; soft-deleted with the parent). The
/// `onDelete: Cascade` relation is a DB safety net only — the app soft-deletes.
model DoctorQualification {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  doctorId String @map("doctor_id")

  degree        String?
  institution   String?
  yearOfPassing Int?    @map("year_of_passing")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_qualifications")
}

/// A past/current work engagement of a doctor. `toDate` NULL means the role is
/// current. Tenant-scoped; managed via the parent doctor like DoctorQualification.
model DoctorExperience {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  doctorId String @map("doctor_id")

  organisation String?
  rolePosition String?   @map("role_position")
  fromDate     DateTime? @map("from_date") @db.Date
  toDate       DateTime? @map("to_date") @db.Date

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_experience")
}
