  UNDER_DEPARTMENT
  UNDER_CATEGORY
}

/// The position a person holds within a sub-category (mirrors CategoryPosition).
enum SubCategoryPosition {
  HOD
  SPECIALIST
  CONSULTANT
  MANAGER
  TECHNICIAN
}

/// Which table a person-mapping's `person_id` resolves against. Shared by the
