// ── Doctor Schedule enums ─────────────────────────────────────────────────────

/// How a doctor consults for a schedule (a schedule may offer several modes).
enum ConsultationMode {
  IN_PERSON
  VIDEO
  PHONE
}

/// The kind of appointment a doctor schedule produces slots for.
enum ScheduleSlotType {
  NEW_CONSULTATION
  FOLLOW_UP
  OTHER
}

/// Lifecycle of a doctor schedule. ON_LEAVE surfaces on the Doctor List as the
/// doctor's current status; INACTIVE disables the schedule without deleting it.
enum DoctorScheduleStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

/// Recurrence pattern of a doctor schedule. DAILY = every day; WEEKLY/CUSTOM use
/// the schedule's selected `days`.
enum RecurrencePattern {
  DAILY
  WEEKLY
  CUSTOM
}

/// Stored coarse state of a generated slot. PAST (date/time elapsed) and
/// UNAVAILABLE (no slots configured that day) are derived at read time, not stored.
enum SlotStatus {
  AVAILABLE
  BOOKED
  FULL
}

// ── Phlebotomist Schedule enums ───────────────────────────────────────────────

/// Lifecycle of a phlebotomist schedule. INACTIVE disables the schedule (and its
/// future slots) without deleting it.
enum PhlebotomistScheduleStatus {
  ACTIVE
  INACTIVE
}

/// How a phlebotomist's visits are delivered for a schedule.
enum PhleboServiceType {
  HOME_COLLECTION
  IN_CENTER
}

/// Audience a support-information record targets: business-level or branch-level
/// screens. A descriptor tag on SupportInfo — not a scoping column.
enum SupportTenantType {
  BUSINESS
  BRANCH
}

/// Active/inactive lifecycle for a support-information record (distinct from soft
/// delete; NULL deletedAt = not deleted).
enum SupportStatus {
  ACTIVE
  INACTIVE
}

