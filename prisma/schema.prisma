  DOCTOR
  REFERRAL_PANEL
  REFERRAL_PANEL_SETTINGS
  REFERRAL_DOCTOR
  EXTERNAL_REFERRAL
  INTERNAL_REFERRAL
  MACHINE
  DOCUMENT
  TEMPLATE
  PDF_REPORT_TEMPLATE
  PATIENT
  MEDICAL_HISTORY
  ORDER
  RADIOLOGIST
  PHLEBOTOMIST
  RADIOLOGY_TECHNICIAN
  PAYMENT_DETAILS
