  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labTestId])
  @@index([paramId])
  @@index([deletedAt])
  @@map("lab_test_reference_values")
}

/// A lab-panel configuration inside a master data (tenant-scoped + branch-level;
/// `branchId` denormalised from the parent master data, exactly like LabTest). A
/// panel groups several lab tests (via `LabPanelTest`) and carries its own
/// classification, applicability, report/turnaround settings, pricing, TAT, flags
/// and instructions. `panelName`/`panelCode` are unique per master data among
/// active rows (partial unique indexes in prisma/rls.sql). CHECK constraints
/// (price ordering, max-tests-removable rules) also live in prisma/rls.sql.
/// Cross-entity ids (department, category) are nullable logical references (no
/// Prisma relation), mirroring LabTest.
model LabPanel {
  id           String  @id @default(uuid())
  // NULL for SITE_ADMIN global templates; set for TENANT rows (CLAUDE.md §4.2).
  tenantId     String? @map("tenant_id")
  branchId     String? @map("branch_id")
  masterDataId String? @map("master_data_id")

  // Origin: TENANT (default, tenant-scoped) or SITE_ADMIN (global template).
  source DataSource @default(TENANT)

  // Identity
  bannerImage String? @map("banner_image")
  panelName   String  @map("panel_name")
  panelCode   String  @map("panel_code")

  // Classification (logical refs)
  categoryId   String? @map("category_id")
  departmentId String? @map("department_id")

  // Applicability + reporting
  applicableGender   ReferenceGender @default(ALL) @map("applicable_gender")
  applicableAgeGroup AgeGroup        @default(ALL) @map("applicable_age_group")
  reportType         ReportType      @default(COMBINED) @map("report_type")
  turnaroundPriority SamplePriority  @default(ROUTINE) @map("turnaround_priority")

  // Active/inactive status (distinct from soft delete; NULL deletedAt = not deleted)
  isActive Boolean @default(true) @map("is_active")

  // Pricing (integer minor units)
  priceMsrp       Int  @default(0) @map("price_msrp")
  priceMinimum    Int  @default(0) @map("price_minimum")
  priceMaximum    Int  @default(0) @map("price_maximum")
  priceOriginal   Int  @default(0) @map("price_original")
  franchisePrice  Int  @default(0) @map("franchise_price")
  // Per-order commission for Fixed Amount / Order Wise referral commission
  // (doc §9.2). NULL = not set yet (shown as "—"), distinct from an actual ₹0.
  commissionPrice Int? @map("commission_price")

  // TAT (defaults to HOURS per the panel spec)
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @default(HOURS) @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @default(HOURS) @map("tat_max_unit")

  // Instructions
  panelInstructions String? @map("panel_instructions")

  // Flags
  isDisableDiscount     Boolean @default(false) @map("is_disable_discount")
  isEnableCms           Boolean @default(true) @map("is_enable_cms")
  isPreference          Boolean @default(false) @map("is_preference")
  isFastingRequired     Boolean @default(false) @map("is_fasting_required")
  isShowOnlineBooking   Boolean @default(true) @map("is_show_online_booking")
  isHomeCollection      Boolean @default(false) @map("is_home_collection")
  isAllowPartialBilling Boolean @default(false) @map("is_allow_partial_billing")

  // Max tests removable in a single order (0 = no limit). Only meaningful when
  // isAllowPartialBilling = true (enforced in service + CHECK in prisma/rls.sql).
  maxTestsRemovable Int @default(0) @map("max_tests_removable")

  // Order diagnostics sections that reference this panel.
  orderDiagnostics OrderDiagnostics[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([masterDataId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([isActive])
  @@index([source])
  @@index([deletedAt])
  @@map("lab_panels")
}

/// A test included in a lab panel. Many per panel; `labTestId` is a logical ref to
/// an active LabTest in the same tenant (validated in LabPanelService). `isRemovable`
/// marks whether this specific test may be unchecked in an order (subject to the
/// panel's `maxTestsRemovable` + `isAllowPartialBilling`). Per-test price is read
/// from the referenced LabTest at billing time (not snapshotted here).
model LabPanelTest {
  id         String  @id @default(uuid())
  // NULL when the parent lab panel is a SITE_ADMIN template.
  tenantId   String? @map("tenant_id")
  branchId   String? @map("branch_id")
  labPanelId String  @map("lab_panel_id")
  labTestId  String  @map("lab_test_id")

  sortOrder   Int     @default(0) @map("sort_order")
  isRemovable Boolean @default(true) @map("is_removable")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([labPanelId])
  @@index([labPanelId, sortOrder])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("lab_panel_tests")
}

/// A branch's operational Lab Test List entry — a materialized, independent
/// snapshot copied from a Master Data `LabTest` via the branch-lab-test import
/// (CLAUDE.md §4.6: tenant-scoped + branch-level). Parent scalar fields mirror
/// `LabTest`; the deep clinical sub-structure (samples, result params, reference
/// ranges/values) is snapshotted into `configSnapshot` JSON at import/sync time.
/// Edits here NEVER propagate back to Master Data. `sourceLabTestId` records the
/// Master Data test this copy came from (logical ref, no relation) so `sync` can
/// re-snapshot it. `testName`/`testCode` are unique per branch among active rows
/// (partial unique indexes in prisma/rls.sql). Classification ids are nullable
/// logical references (no Prisma relation), mirroring how LabPanel treats them.
model BranchLabTest {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  // Provenance (logical refs; no relation — the snapshot is independent).
  sourceLabTestId    String? @map("source_lab_test_id")
  sourceMasterDataId String? @map("source_master_data_id")

  // Identity
  testName        String  @map("test_name")
  testDisplayName String? @map("test_display_name")
  testCode        String  @map("test_code")
  aka             String?

  // Classification (logical refs)
  departmentId  String? @map("department_id")
  categoryId    String? @map("category_id")
  subCategoryId String? @map("sub_category_id")

  // Basic config
  processMethod      ProcessMethod  @default(SINGLE_STEP) @map("process_method")
  icdCode            String?        @map("icd_code")
  loincCode          String?        @map("loinc_code")
  clinicalTags       String[]       @map("clinical_tags")
  reportTemplateId   String?        @map("report_template_id")
  samplePriorityType SamplePriority @default(ROUTINE) @map("sample_priority_type")
  pdfSettingsId      String?        @map("pdf_settings_id")
  imageSettingsId    String?        @map("image_settings_id")
  isEnableCms        Boolean        @default(true) @map("is_enable_cms")
  approvalWorkflowId String?        @map("approval_workflow_id")

  // Pricing (integer minor units)
  priceMsrp            Int     @default(0) @map("price_msrp")
  priceMaximum         Int     @default(0) @map("price_maximum")
  priceMinimum         Int     @default(0) @map("price_minimum")
  priceOriginal        Int     @default(0) @map("price_original")
  franchisePrice       Int     @default(0) @map("franchise_price")
  emergencyPrice       Int     @default(0) @map("emergency_price")
  // Per-order commission for Fixed Amount / Order Wise referral commission
  // (doc §9.2). NULL = not set yet (shown as "—"), distinct from an actual ₹0.
  commissionPrice      Int?    @map("commission_price")
  discountCapPct       Int     @default(0) @map("discount_cap_pct")
  isAllowPriceOverride Boolean @default(false) @map("is_allow_price_override")
  isAllowDiscounts     Boolean @default(true) @map("is_allow_discounts")

  // TAT
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @map("tat_max_unit")

  // Schedule (times stored as "HH:mm" strings)
  scheduleDays DayOfWeek[] @map("schedule_days")
  scheduleFrom String?     @map("schedule_from")
  scheduleTo   String?     @map("schedule_to")

  // Processing time
  procTimeMinValue Int?     @map("proc_time_min_value")
  procTimeMinUnit  TatUnit? @map("proc_time_min_unit")
  procTimeMaxValue Int?     @map("proc_time_max_value")
  procTimeMaxUnit  TatUnit? @map("proc_time_max_unit")

  // Approval window
  approvalTimeFrom String? @map("approval_time_from")
  approvalTimeTo   String? @map("approval_time_to")

  // Flags
  isHideInOrderScreen Boolean @default(false) @map("is_hide_in_order_screen")
  isPreferenceTest    Boolean @default(false) @map("is_preference_test")
  isMandatoryTest     Boolean @default(false) @map("is_mandatory_test")

  // Mandatory-test classification (logical refs)
  mandatoryDeptId             String?             @map("mandatory_dept_id")
  mandatoryCatId              String?             @map("mandatory_cat_id")
  mandatorySubcatId           String?             @map("mandatory_subcat_id")
  isRepeatIntervalRestriction Boolean             @default(false) @map("is_repeat_interval_restriction")
  repeatIntervalValue         Int?                @map("repeat_interval_value")
  repeatIntervalUnit          RepeatIntervalUnit? @map("repeat_interval_unit")

  // Enable/disable in the branch list (distinct from soft delete).
  isActive Boolean @default(true) @map("is_active")

  // Variant model: rows sharing a `sourceLabTestId` form a group (one imported
  // original + its user duplicates). `isDuplicate` = false for the direct import
  // (sync refreshes these), true for a user-created copy (sync leaves these
  // alone). Exactly one row per group is `isDefault` (used for order creation).
  isDefault   Boolean @default(true) @map("is_default")
  isDuplicate Boolean @default(false) @map("is_duplicate")

  // Notes
  usefulFor               String? @map("useful_for")
  interpretationOfResults String? @map("interpretation_of_results")
  limitations             String?
  remarks                 String?
  references              String?

  // Point-in-time snapshot of the source test's children:
  // { samples: [...], resultParams: [{ ..., referenceRanges: [...], referenceValues: [...] }] }
  configSnapshot Json @default("{}") @map("config_snapshot")

  // Order items that reference this branch lab test.
  orderItems OrderItem[]

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([sourceLabTestId])
  @@index([isActive])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("branch_lab_tests")
}

/// A branch's operational Lab Panel List entry — a materialized, independent
/// snapshot copied from a Master Data `LabPanel` via the branch-lab-panel import
/// (tenant-scoped + branch-level). Parent scalar fields mirror `LabPanel`; the
/// panel's member tests are held relationally in `BranchLabPanelTest` pointing at
/// this branch's `BranchLabTest` copies. `sourceLabPanelId` records the Master
/// Data panel this copy came from (logical ref) so `sync` can re-snapshot it.
/// `panelName`/`panelCode` are unique per branch among active rows (partial unique
/// indexes in prisma/rls.sql).
model BranchLabPanel {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  // Provenance (logical refs; no relation — the snapshot is independent).
  sourceLabPanelId   String? @map("source_lab_panel_id")
  sourceMasterDataId String? @map("source_master_data_id")

  // Identity
  bannerImage String? @map("banner_image")
  panelName   String  @map("panel_name")
  panelCode   String  @map("panel_code")

  // Classification (logical refs)
  categoryId   String? @map("category_id")
  departmentId String? @map("department_id")

  // Applicability + reporting
  applicableGender   ReferenceGender @default(ALL) @map("applicable_gender")
  applicableAgeGroup AgeGroup        @default(ALL) @map("applicable_age_group")
  reportType         ReportType      @default(COMBINED) @map("report_type")
  turnaroundPriority SamplePriority  @default(ROUTINE) @map("turnaround_priority")

  // Enable/disable in the branch list (distinct from soft delete).
  isActive Boolean @default(true) @map("is_active")

  // Variant model (mirrors BranchLabTest): rows sharing a `sourceLabPanelId` form
  // a group (one imported original + user duplicates). `isDuplicate` = false for
  // the direct import (sync refreshes), true for a user copy (sync skips). Exactly
  // one row per group is `isDefault` (used for order creation).
  isDefault   Boolean @default(true) @map("is_default")
  isDuplicate Boolean @default(false) @map("is_duplicate")

  // Pricing (integer minor units)
  priceMsrp       Int  @default(0) @map("price_msrp")
  priceMinimum    Int  @default(0) @map("price_minimum")
  priceMaximum    Int  @default(0) @map("price_maximum")
  priceOriginal   Int  @default(0) @map("price_original")
  franchisePrice  Int  @default(0) @map("franchise_price")
  // Per-order commission for Fixed Amount / Order Wise referral commission
  // (doc §9.2). NULL = not set yet (shown as "—"), distinct from an actual ₹0.
  commissionPrice Int? @map("commission_price")

  // TAT (defaults to HOURS per the panel spec)
  tatMinValue Int?     @map("tat_min_value")
  tatMinUnit  TatUnit? @default(HOURS) @map("tat_min_unit")
  tatMaxValue Int?     @map("tat_max_value")
  tatMaxUnit  TatUnit? @default(HOURS) @map("tat_max_unit")

  // Instructions
  panelInstructions String? @map("panel_instructions")

  // Flags
  isDisableDiscount     Boolean @default(false) @map("is_disable_discount")
  isEnableCms           Boolean @default(true) @map("is_enable_cms")
  isPreference          Boolean @default(false) @map("is_preference")
  isFastingRequired     Boolean @default(false) @map("is_fasting_required")
  isShowOnlineBooking   Boolean @default(true) @map("is_show_online_booking")
  isHomeCollection      Boolean @default(false) @map("is_home_collection")
  isAllowPartialBilling Boolean @default(false) @map("is_allow_partial_billing")

  maxTestsRemovable Int @default(0) @map("max_tests_removable")

  // Order items that reference this branch lab panel.
  orderItems OrderItem[]

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([sourceLabPanelId])
  @@index([isActive])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("branch_lab_panels")
}

/// A test included in a branch's Lab Panel List entry. `branchLabTestId` points at
/// a `BranchLabTest` copy in the same branch (not a Master Data test). Rebuilt on
/// sync to match the source panel's current composition. Unique per panel among
/// active rows (partial unique index in prisma/rls.sql).
model BranchLabPanelTest {
  id               String @id @default(uuid())
  tenantId         String @map("tenant_id")
  branchId         String @map("branch_id")
  branchLabPanelId String @map("branch_lab_panel_id")
  branchLabTestId  String @map("branch_lab_test_id")

  sortOrder   Int     @default(0) @map("sort_order")
  isRemovable Boolean @default(true) @map("is_removable")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([branchLabPanelId])
  @@index([branchLabPanelId, sortOrder])
  @@index([branchLabTestId])
  @@index([deletedAt])
  @@map("branch_lab_panel_tests")
}

/// A SiteAdmin-curated named group of SITE_ADMIN lab-test templates (e.g. "Full
/// Body Checkup"). Platform-level (CLAUDE.md §4.2) — no `tenantId`/`source` and
/// intentionally excluded from RLS, like siteadmin_users. `groupName` is unique
/// among active rows (partial unique index in prisma/rls.sql). The mapped lab
/// tests are managed via `TestGroupMapping`.
model TestGroup {
  id        String @id @default(uuid())
  groupName String @map("group_name")

  // Actor trail: the SiteAdmin who created/last-updated the group.
  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  mappings TestGroupMapping[]

  @@index([deletedAt])
  @@map("test_groups")
}

/// Junction: one row per (test group, SITE_ADMIN lab test) pair. `labTestId` is a
/// logical ref to an active SITE_ADMIN LabTest (validated in TestGroupService),
/// mirroring LabPanelTest. Platform-level (no tenant scoping); a lab test appears
/// at most once per group among active rows (partial unique index in
/// prisma/rls.sql).
model TestGroupMapping {
  id          String @id @default(uuid())
  testGroupId String @map("test_group_id")
  labTestId   String @map("lab_test_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  testGroup TestGroup @relation(fields: [testGroupId], references: [id])

  @@index([testGroupId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("test_group_mappings")
}

/// A lab equipment master (SiteAdmin only). Platform-level (CLAUDE.md §4.2) — a
/// global catalogue entry above the tenant boundary, so NO tenant scoping and no
/// RLS (like `test_groups`). Carries an optional adapter `code`, a description,
/// and three rich-text HTML documents (setup / lab-config / adopter). `name` is
/// unique among active rows (partial unique index in prisma/rls.sql). The lab
/// tests an equipment processes are mapped many-to-many via `EquipmentLabTest`.
model Equipment {
  id          String  @id @default(uuid())
  name        String  @map("name")
  code        String? @map("code")
  description String? @map("description")

  // Rich-text HTML documents (@db.Text — can exceed the varchar default).
  setupDocument     String? @map("setup_document") @db.Text
  labConfigDocument String? @map("labconfig_document") @db.Text
  adopterDocument   String? @map("adopter_document") @db.Text

  // Actor trail: the SiteAdmin who created/last-updated the equipment.
  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  mappings EquipmentLabTest[]

  @@index([deletedAt])
  @@map("equipment")
}

/// Junction: one row per (equipment, SITE_ADMIN lab test) pair. `labTestId` is a
/// logical ref to an active SITE_ADMIN LabTest (validated in EquipmentService),
/// mirroring TestGroupMapping. Platform-level (no tenant scoping); a lab test
/// appears at most once per equipment among active rows (partial unique index in
/// prisma/rls.sql).
model EquipmentLabTest {
  id          String @id @default(uuid())
  equipmentId String @map("equipment_id")
  labTestId   String @map("lab_test_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("equipment_lab_tests")
}

/// An external reference lab a tenant sends samples to. Tenant-scoped,
/// tenant-level (CLAUDE.md §4.6) — the center belongs to the business as a whole.
/// Carries a single selected lab test + lab panel (`labTestId`/`labPanelId`) and a
/// NABL-accreditation flag. `code` is
/// system-generated & immutable (OC-00001…, from Tenant.outsourceCenterCounter).
/// `outsource_center_name` + `code` are unique per tenant among active rows
/// (partial unique indexes in prisma/rls.sql). RLS policy in prisma/rls.sql.
model OutsourceCenter {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  code     String

  // Basic details
  name      String  @map("outsource_center_name")
  shortName String? @map("short_name")
  address   String?
  city      String
  state     String?
  pincode   String?

  // Legal & financial (all optional)
  gstNumber         String? @map("gst_number")
  panNumber         String? @map("pan_number")
  accountHolderName String? @map("account_holder_name")
  bankName          String? @map("bank_name")
  bankAccountNumber String? @map("bank_account_number")
  ifscCode          String? @map("ifsc_code")

  isActive         Boolean @default(true) @map("is_active")
  isNablAccredited Boolean @default(false) @map("is_nabl_accredited")

  // Single selected lab test / lab panel the center handles. Logical refs to a
  // LabTest / LabPanel (no Prisma relation, mirroring LabPanelTest.labTestId);
  // validated active + tenant-scoped in OutsourceCenterService.
  labTestId  String? @map("lab_test_id")
  labPanelId String? @map("lab_panel_id")

  contacts OutsourceCenterContact[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([labTestId])
  @@index([labPanelId])
  @@index([deletedAt])
  @@map("outsource_centers")
}

/// A contact person for an outsource center, one row per fixed role. Tenant-scoped,
/// tenant-level (inherits the center's tier; `tenantId` denormalised for RLS +
/// defence in depth). At most one active contact per role per center (partial
/// unique index in prisma/rls.sql). RLS policy in prisma/rls.sql.
model OutsourceCenterContact {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  outsourceCenterId String               @map("outsource_center_id")
  role              OutsourceContactRole

  name   String?
  mobile String?
  email  String?

  outsourceCenter OutsourceCenter @relation(fields: [outsourceCenterId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([outsourceCenterId])
  @@index([deletedAt])
  @@map("outsource_center_contacts")
}

/// An external referring panel (clinic/hospital/lab) that sends business to the
/// tenant. Tenant-scoped, tenant-level (CLAUDE.md §4.6) — it belongs to the business
/// as a whole. `code` is system-generated & immutable (RP-00001…, from
/// Tenant.referralPanelCounter). `referral_panel_name` + `code` are unique per tenant
/// among active rows, and the user-supplied `panel_code` is unique per tenant among
/// active non-null rows (partial unique indexes in prisma/rls.sql). Contact persons
/// are flat columns (one name/mobile/email per fixed role) rather than a child table.
/// Commission/bonus slabs are JSON arrays validated by DTOs (see
/// ReferralPanelService). `referralPanelSettingsId` is a nullable logical ref to a
/// not-yet-modelled settings template. Assigned lab tests/panels (the "lab test/panel
/// list") are child rows (ReferralPanelLabTest / ReferralPanelLabPanel). RLS policy in
/// prisma/rls.sql.
/// Reusable billing/communication settings template for the referral module,
/// keyed by `clientType` (CASH / PREPAID / POSTPAID). Referenced (optionally) by
/// ReferralPanel, ReferralDoctor, ExternalReferral and InternalReferral via their
/// nullable `referralPanelSettingsId`. Tenant-scoped, tenant-level (CLAUDE.md §4.6
/// — matches ReferralPanel); `branchId` is carried for future use but the service
/// scopes reads by tenant only. At most one default per (tenant, clientType) among
/// ACTIVE rows, and `settingName` unique per tenant among ACTIVE rows (partial
/// unique indexes in prisma/rls.sql). RLS policy in prisma/rls.sql.
model ReferralPanelSettings {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  settingName String                      @map("setting_name")
  clientType  ReferralClientType          @map("client_type")
  isDefault   Boolean                     @default(false) @map("is_default")
  status      ReferralPanelSettingsStatus @default(ACTIVE)

  // ── Communication ──
  isSendBillsToPatient   Boolean @default(false) @map("is_send_bills_to_patient")
  isSendBillsToB2b       Boolean @default(false) @map("is_send_bills_to_b2b")
  isSendBillsToDoctor    Boolean @default(false) @map("is_send_bills_to_doctor")
  isSendReportsToPatient Boolean @default(false) @map("is_send_reports_to_patient")
  isSendReportsToB2b     Boolean @default(false) @map("is_send_reports_to_b2b")
  isSendReportsToDoctor  Boolean @default(false) @map("is_send_reports_to_doctor")

  // ── Credit / invoicing (POSTPAID) ──
  creditLimitAmount           Decimal? @map("credit_limit_amount") @db.Decimal(12, 2)
  isRestrictOrderCreditLimit  Boolean  @default(false) @map("is_restrict_order_credit_limit")
  isRestrictReportCreditLimit Boolean  @default(false) @map("is_restrict_report_credit_limit")
  creditAllowedDays           Int?     @map("credit_allowed_days")
  isRestrictOrderCreditDays   Boolean  @default(false) @map("is_restrict_order_credit_days")
  isRestrictReportCreditDays  Boolean  @default(false) @map("is_restrict_report_credit_days")
  daysAfterInvoice            Int?     @map("days_after_invoice")
  isRestrictOrderPostInvoice  Boolean  @default(false) @map("is_restrict_order_post_invoice")
  isRestrictReportPostInvoice Boolean  @default(false) @map("is_restrict_report_post_invoice")
  isAutoInvoice               Boolean  @default(false) @map("is_auto_invoice")
  isRaiseInvoiceOnCreditLimit Boolean  @default(false) @map("is_raise_invoice_on_credit_limit")
  invoiceFrequencyDays        Int?     @map("invoice_frequency_days")
  isOverlapMonthEndClose      Boolean  @default(false) @map("is_overlap_month_end_close")
  isAllowManualInvoice        Boolean  @default(false) @map("is_allow_manual_invoice")
  invoiceEmailTriggerHours    Int?     @map("invoice_email_trigger_hours")

  // ── Wallet / bonus (PREPAID) ──
  minWalletAdvance            Decimal?           @map("min_wallet_advance") @db.Decimal(12, 2)
  minAdvanceForBonus          Decimal?           @map("min_advance_for_bonus") @db.Decimal(12, 2)
  minWalletBalance            Decimal?           @map("min_wallet_balance") @db.Decimal(12, 2)
  isRestrictOrderAtMinBalance Boolean            @default(false) @map("is_restrict_order_at_min_balance")
  isReminderAt75Percent       Boolean            @default(false) @map("is_reminder_at_75_percent")
  isReminderAtMinBalance      Boolean            @default(false) @map("is_reminder_at_min_balance")
  bonusType                   ReferralBonusType? @map("bonus_type")
  bonusPercentage             Decimal?           @map("bonus_percentage") @db.Decimal(5, 2)
  bonusFixedAmount            Decimal?           @map("bonus_fixed_amount") @db.Decimal(12, 2)
  bonusExtraAmount            Decimal?           @map("bonus_extra_amount") @db.Decimal(12, 2)
  isAllowNegativeBalance      Boolean            @default(false) @map("is_allow_negative_balance")
  maxNegativeBalance          Decimal?           @map("max_negative_balance") @db.Decimal(12, 2)
  isRestrictOrderNegative     Boolean            @default(false) @map("is_restrict_order_negative")
  isRestrictReportNegative    Boolean            @default(false) @map("is_restrict_report_negative")

  // ── Payment ──
  isAllowOtherPaymentModes Boolean @default(false) @map("is_allow_other_payment_modes")

  // ── Back-relations (the four referral entities that reference this template) ──
  referralPanels    ReferralPanel[]
  referralDoctors   ReferralDoctor[]
  externalReferrals ExternalReferral[]
  internalReferrals InternalReferral[]

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([clientType])
  @@index([deletedAt])
  @@map("referral_panel_settings")
}

model ReferralPanel {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")
  code     String

  // ── Basic details ──
  name                    String                 @map("referral_panel_name")
  shortName               String?                @map("short_name")
  panelCode               String?                @map("panel_code")
  clientType              ReferralClientType     @map("client_type")
  referralPanelSettingsId String?                @map("referral_panel_settings_id")
  referralPanelSettings   ReferralPanelSettings? @relation(fields: [referralPanelSettingsId], references: [id])
  isActive                Boolean                @default(true) @map("is_active")

  // ── Address details ──
  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String?
  state        String?
  pincode      String?
  gstNumber    String? @map("gst_number")
  panNumber    String? @map("pan_number")

  // ── Bank details ──
  accountHolderName String? @map("account_holder_name")
  bankName          String? @map("bank_name")
  accountNumber     String? @map("account_number")
  ifscCode          String? @map("ifsc_code")

  // ── Contact persons (flat, one trio per fixed role) ──
  directorName             String? @map("director_name")
  directorMobile           String? @map("director_mobile")
  directorEmail            String? @map("director_email")
  accessionPersonName      String? @map("accession_person_name")
  accessionPersonMobile    String? @map("accession_person_mobile")
  accessionPersonEmail     String? @map("accession_person_email")
  registrationPersonName   String? @map("registration_person_name")
  registrationPersonMobile String? @map("registration_person_mobile")
  registrationPersonEmail  String? @map("registration_person_email")
  logisticsPersonName      String? @map("logistics_person_name")
  logisticsPersonMobile    String? @map("logistics_person_mobile")
  logisticsPersonEmail     String? @map("logistics_person_email")
  accountsPersonName       String? @map("accounts_person_name")
  accountsPersonMobile     String? @map("accounts_person_mobile")
  accountsPersonEmail      String? @map("accounts_person_email")

  // ── Commission & TDS ──
  isCommissionApplicable Boolean               @default(false) @map("is_commission_applicable")
  commissionType         CommissionType?       @map("commission_type")
  commissionPctLabTest   Decimal?              @map("commission_pct_lab_test") @db.Decimal(5, 2)
  commissionPctLabPanel  Decimal?              @map("commission_pct_lab_panel") @db.Decimal(5, 2)
  commissionSlabs        Json                  @default("[]") @map("commission_slabs")
  fixedCommissionCycle   FixedCommissionCycle? @map("fixed_commission_cycle")
  fixedAmount            Decimal?              @map("fixed_amount") @db.Decimal(10, 2)
  isTdsApplicable        Boolean               @default(false) @map("is_tds_applicable")
  tds                    Int?                  @map("tds")

  // ── Payment & incentive ──
  paymentCycle               PaymentCycle        @default(NA) @map("payment_cycle")
  paymentMode                ReferralPaymentMode @default(BANK_TRANSFER) @map("payment_mode")
  monthlyTargetAmount        Int                 @default(0) @map("monthly_target_amount")
  isIncentiveBonusApplicable Boolean             @default(false) @map("is_incentive_bonus_applicable")
  bonusSlabs                 Json                @default("[]") @map("bonus_slabs")

  // ── Attachment & remarks ──
  fileName String? @map("file_name")
  fileUrl  String? @map("file_url")
  remarks  String?

  labTests  ReferralPanelLabTest[]
  labPanels ReferralPanelLabPanel[]

  /// Orders billed to this referral (B2B) panel.
  orders Order[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([referralPanelSettingsId])
  @@index([deletedAt])
  @@map("referral_panels")
}

/// A lab test assigned to a referral panel (the "lab test list" — one row per
/// assigned test). `labTestId` is a logical ref to a LabTest in the tenant (no Prisma
/// relation, mirroring OutsourceCenterBranchTest.labTestId); validated in
/// ReferralPanelService to be an active test in the tenant. One active row per
/// (panel, test) (partial unique index in prisma/rls.sql). RLS policy in
/// prisma/rls.sql.
model ReferralPanelLabTest {
  id              String @id @default(uuid())
  tenantId        String @map("tenant_id")
  referralPanelId String @map("referral_panel_id")
  labTestId       String @map("lab_test_id")

  referralPanel ReferralPanel @relation(fields: [referralPanelId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralPanelId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("referral_panel_lab_tests")
}

/// A lab panel assigned to a referral panel (the "lab panel list" — one row per
/// assigned panel). `labPanelId` is a logical ref to a LabPanel in the tenant (no
/// Prisma relation); validated in ReferralPanelService to be an active panel in the
/// tenant. One active row per (panel, lab-panel) (partial unique index in
/// prisma/rls.sql). RLS policy in prisma/rls.sql.
model ReferralPanelLabPanel {
  id              String @id @default(uuid())
  tenantId        String @map("tenant_id")
  referralPanelId String @map("referral_panel_id")
  labPanelId      String @map("lab_panel_id")

  referralPanel ReferralPanel @relation(fields: [referralPanelId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralPanelId])
  @@index([labPanelId])
  @@index([deletedAt])
  @@map("referral_panel_lab_panels")
}

/// A doctor in a tenant's registry — either a REPORTING doctor (signs/reports on
/// tests) or a CONSULTANT (sees patients). Tenant-scoped, tenant-level (CLAUDE.md
/// §4.6): the registry belongs to the business as a whole, not a single branch.
/// `registration_no` is unique per tenant among ACTIVE rows (partial unique index
/// in prisma/rls.sql). Classification links (`department`, `category`) are real
/// relations to active rows of the same tenant (ownership validated in
/// DoctorsService); `subCategory` is a free-text "super specialization" label per
/// spec. Signatory authority is captured by the `signatory*Ids` JSON arrays. RLS
/// policy in prisma/rls.sql.
model Doctor {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  doctorType DoctorType @map("doctor_type")

  // Branch scope (CLAUDE.md §4.5). Nullable column so legacy/tenant-level rows
  // can exist, but the create API requires it. Client-supplied — validated
  // against the caller's tenant in DoctorsService (never trusted from the body).
  branchId String? @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Identity
  salutation     Salutation?
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  dateOfBirth    DateTime?   @map("date_of_birth") @db.Date
  gender         Gender?
  phone          String
  alternatePhone String?     @map("alternate_phone")
  email          String?
  address        String?

  // Registration
  registrationNo      String    @map("registration_no")
  registrationCouncil String?   @map("registration_council")
  registrationExpiry  DateTime? @map("registration_expiry") @db.Date

  // Classification — "specialization" links to a category, "super specialization"
  // links to a sub-category. department/category/sub-category are active rows of
  // the same tenant (validated in DoctorsService).
  categoryId    String?      @map("category_id")
  category      Category?    @relation(fields: [categoryId], references: [id])
  subCategoryId String?      @map("sub_category_id")
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  departmentId  String?      @map("department_id")
  department    Department?  @relation(fields: [departmentId], references: [id])

  // Accreditation & signatory authority
  isNablAuthorized        Boolean @default(false) @map("is_nabl_authorized")
  isCapCertified          Boolean @default(false) @map("is_cap_certified")
  isIsoCertified          Boolean @default(false) @map("is_iso_certified")
  isReportSignatory       Boolean @default(false) @map("is_report_signatory")
  signatoryName           String? @map("signatory_name")
  signatoryDesignation    String? @map("signatory_designation")
  signatureImagePath      String? @map("signature_image_path")
  signatoryDepartmentIds  Json?   @map("signatory_department_ids")
  signatoryCategoryIds    Json?   @map("signatory_category_ids")
  signatorySubCategoryIds Json?   @map("signatory_sub_category_ids")

  // Banking
  accountHolderName String?           @map("account_holder_name")
  bankName          String?           @map("bank_name")
  accountNumber     String?           @map("account_number")
  ifscCode          String?           @map("ifsc_code")
  paymentMode       DoctorPaymentMode @default(BANK_TRANSFER) @map("payment_mode")

  // Charges
  consultationFee Decimal @default(0) @map("consultation_fee") @db.Decimal(10, 2)
  emergencyFee    Decimal @default(0) @map("emergency_fee") @db.Decimal(10, 2)
  followUpFee     Decimal @default(0) @map("follow_up_fee") @db.Decimal(10, 2)
  isAllowDiscount Boolean @default(false) @map("is_allow_discount")

  // Status & misc
  status      DoctorStatus @default(ACTIVE)
  joiningDate DateTime?    @map("joining_date") @db.Date
  remarks     String?

  // Average rating (0.0–5.0), surfaced on the Doctor Schedule calendar header.
  // Nullable — unset until a rating source populates it.
  rating Decimal? @map("rating") @db.Decimal(2, 1)

  // Children (managed via the parent in DoctorsService)
  qualifications DoctorQualification[]
  experiences    DoctorExperience[]

  // OPD order sections that name this doctor as the consultant.
  orderOpds OrderOpd[]

  // Doctor Schedule module: recurring schedule configs and generated slots.
  doctorSchedules DoctorSchedule[]
  doctorSlots     DoctorSlot[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([departmentId])
  @@index([status])
  @@index([deletedAt])
  @@map("doctors")
}

/// A qualification (degree) held by a doctor. Tenant-scoped; lifecycle is managed
/// via the parent doctor (replace-on-update; soft-deleted with the parent). The
/// `onDelete: Cascade` relation is a DB safety net only — the app soft-deletes.
model DoctorQualification {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  doctorId String @map("doctor_id")

  degree        String?
  institution   String?
  yearOfPassing Int?    @map("year_of_passing")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_qualifications")
}

/// A past/current work engagement of a doctor. `toDate` NULL means the role is
/// current. Tenant-scoped; managed via the parent doctor like DoctorQualification.
model DoctorExperience {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  doctorId String @map("doctor_id")

  organisation String?
  rolePosition String?   @map("role_position")
  fromDate     DateTime? @map("from_date") @db.Date
  toDate       DateTime? @map("to_date") @db.Date

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([doctorId])
  @@index([deletedAt])
  @@map("doctor_experience")
}

// ── Doctor Schedule ─────────────────────────────────────────────────────────────

/// A doctor's recurring availability configuration at a branch (the "Configure
/// Doctor Schedule" form). Tenant-scoped + branch-level (CLAUDE.md §4.5–4.7):
/// `tenantId`/`branchId` come from the request context, the `doctorId` is
/// validated against the caller's tenant. Working-window times are 24h `HH:mm`
/// branch-local strings; `breakStart`/`breakEnd` are optional. Slot generation
/// derives `DoctorSlot` rows from this config, honouring `days` (weekly
/// recurrence), `holidays` (skipped dates), and `overrides` (one-off windows).
/// At most one ACTIVE schedule per (tenant, doctor, branch) — enforced by a
/// partial unique index in prisma/rls.sql. RLS policy in prisma/rls.sql.
model DoctorSchedule {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  doctorId String @map("doctor_id")
  doctor   Doctor @relation(fields: [doctorId], references: [id])

  consultationMode ConsultationMode[]   @map("consultation_mode")
  slotType         ScheduleSlotType     @map("slot_type")
  status           DoctorScheduleStatus @default(ACTIVE)

  startTime  String  @map("start_time")
  endTime    String  @map("end_time")
  breakStart String? @map("break_start")
  breakEnd   String? @map("break_end")

  durationMinutes     Int @map("duration_minutes")
  slotIntervalMinutes Int @map("slot_interval_minutes")
  maxPatientsPerSlot  Int @map("max_patients_per_slot")
  bufferMinutes       Int @default(0) @map("buffer_minutes")

  recurrencePattern RecurrencePattern @map("recurrence_pattern")

  days      DoctorScheduleDay[]
  holidays  DoctorScheduleHoliday[]
  overrides DoctorScheduleOverride[]
  slots     DoctorSlot[]

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([doctorId])
  @@index([status])
  @@index([deletedAt])
  @@map("doctor_schedules")
}

/// A weekly-recurrence day of a schedule (WEEKLY/CUSTOM patterns). One row per
/// active day. Cascades with its parent schedule. Tenant-scoped.
model DoctorScheduleDay {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  scheduleId String         @map("schedule_id")
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek @map("day_of_week")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([scheduleId, dayOfWeek])
  @@index([tenantId])
  @@index([scheduleId])
  @@map("doctor_schedule_days")
}

/// A holiday/exception date on which a schedule generates no slots. Tenant-scoped;
/// cascades with its parent schedule.
model DoctorScheduleHoliday {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  scheduleId String         @map("schedule_id")
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  holidayDate DateTime @map("holiday_date") @db.Date
  remarks     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([scheduleId])
  @@map("doctor_schedule_holidays")
}

/// A one-off override of a schedule for a specific date. `startTime`/`endTime`
/// NULL means the doctor is off that date (no slots); otherwise the override
/// window replaces the recurring window. Tenant-scoped; cascades with its parent.
model DoctorScheduleOverride {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  scheduleId String         @map("schedule_id")
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  overrideDate DateTime @map("override_date") @db.Date
  startTime    String?  @map("start_time")
  endTime      String?  @map("end_time")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([scheduleId])
  @@map("doctor_schedule_overrides")
}

/// A concrete appointment slot generated from a `DoctorSchedule`. Times are 24h
/// `HH:mm`. `bookedPatients` is a counter mutated atomically by reserve/release;
/// `status` is the stored coarse state (AVAILABLE/BOOKED/FULL) — PAST/UNAVAILABLE
/// are derived at read time. Tenant-scoped + branch-level. One slot per
/// (schedule, date, start time), enforced by a partial unique index in
/// prisma/rls.sql so regeneration upserts rather than duplicates.
model DoctorSlot {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  doctorId String @map("doctor_id")
  doctor   Doctor @relation(fields: [doctorId], references: [id])

  scheduleId String         @map("schedule_id")
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  slotDate  DateTime @map("slot_date") @db.Date
  startTime String   @map("start_time")
  endTime   String   @map("end_time")

  maxPatients    Int        @map("max_patients")
  bookedPatients Int        @default(0) @map("booked_patients")
  status         SlotStatus @default(AVAILABLE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([doctorId, slotDate])
  @@index([scheduleId])
  @@index([deletedAt])
  @@map("doctor_slots")
}

/// A tenant's service area / zone (the phlebotomist "Area / Zone" master).
/// Tenant-scoped + branch-level (CLAUDE.md §4.5–4.7): a zone belongs to a branch.
/// Referenced by phlebotomist schedules (many-to-many via
/// `PhlebotomistScheduleZone`). RLS policy in prisma/rls.sql.
model ServiceZone {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  name     String
  code     String?
  isActive Boolean @default(true) @map("is_active")

  scheduleLinks PhlebotomistScheduleZone[]

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("service_zones")
}

/// A phlebotomist's recurring availability configuration at a branch (the
/// "Configure Phlebotomist Schedule" form). Tenant-scoped + branch-level
/// (CLAUDE.md §4.5–4.7): `tenantId`/`branchId` come from the request context, the
/// `phlebotomistId` (a staff Person holding the `phlebotomist` role at the branch)
/// is validated against the caller's tenant/branch. Working-window times are 24h
/// `HH:mm` branch-local strings. Slot generation derives `PhlebotomistSlot` rows,
/// honouring `days` (weekly recurrence), `zones` (service areas), `holidays`
/// (skipped dates), and `overrides` (one-off windows). At most one ACTIVE schedule
/// per (tenant, phlebotomist, branch) — enforced by a partial unique index in
/// prisma/rls.sql. RLS policy in prisma/rls.sql.
model PhlebotomistSchedule {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  phlebotomistId String @map("phlebotomist_id")
  phlebotomist   Person @relation("PhlebotomistScheduleStaff", fields: [phlebotomistId], references: [id])

  serviceType PhleboServiceType          @map("service_type")
  status      PhlebotomistScheduleStatus @default(ACTIVE)

  startTime String @map("start_time")
  endTime   String @map("end_time")

  intervalMinutes     Int @map("interval_minutes")
  travelBufferMinutes Int @default(0) @map("travel_buffer_minutes")
  maxVisitsPerDay     Int @map("max_visits_per_day")
  slotCapacity        Int @map("slot_capacity")

  recurrencePattern RecurrencePattern @map("recurrence_pattern")

  days      PhlebotomistScheduleDay[]
  zones     PhlebotomistScheduleZone[]
  holidays  PhlebotomistScheduleHoliday[]
  overrides PhlebotomistScheduleOverride[]
  slots     PhlebotomistSlot[]

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([phlebotomistId])
  @@index([status])
  @@index([deletedAt])
  @@map("phlebotomist_schedules")
}

/// A weekly-recurrence day of a phlebotomist schedule (WEEKLY/CUSTOM patterns).
/// One row per active day. Cascades with its parent schedule. Tenant-scoped.
model PhlebotomistScheduleDay {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  scheduleId String               @map("schedule_id")
  schedule   PhlebotomistSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek @map("day_of_week")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([scheduleId, dayOfWeek])
  @@index([tenantId])
  @@index([scheduleId])
  @@map("phlebotomist_schedule_days")
}

/// A service area assigned to a phlebotomist schedule (a phlebotomist can serve
/// multiple areas). Join between a schedule and a `ServiceZone`. Cascades with its
/// parent schedule. Tenant-scoped.
model PhlebotomistScheduleZone {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  scheduleId String               @map("schedule_id")
  schedule   PhlebotomistSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  zoneId String      @map("zone_id")
  zone   ServiceZone @relation(fields: [zoneId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([scheduleId, zoneId])
  @@index([tenantId])
  @@index([scheduleId])
  @@index([zoneId])
  @@map("phlebotomist_schedule_zones")
}

/// A holiday/exception date on which a phlebotomist schedule generates no slots.
/// Tenant-scoped; cascades with its parent schedule.
model PhlebotomistScheduleHoliday {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  scheduleId String               @map("schedule_id")
  schedule   PhlebotomistSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  holidayDate DateTime @map("holiday_date") @db.Date
  remarks     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([scheduleId])
  @@map("phlebotomist_schedule_holidays")
}

/// A one-off override of a phlebotomist schedule for a specific date.
/// `startTime`/`endTime` NULL means the phlebotomist is off that date (no slots);
/// otherwise the override window replaces the recurring window. An override for a
/// Sunday is the only way slots are generated on a Sunday. Tenant-scoped; cascades
/// with its parent schedule.
model PhlebotomistScheduleOverride {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  scheduleId String               @map("schedule_id")
  schedule   PhlebotomistSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  overrideDate DateTime @map("override_date") @db.Date
  startTime    String?  @map("start_time")
  endTime      String?  @map("end_time")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([scheduleId])
  @@map("phlebotomist_schedule_overrides")
}

/// A concrete visit slot generated from a `PhlebotomistSchedule`. Times are 24h
/// `HH:mm`. `bookedCount` is a **maintained reservation counter** (the atomic
/// concurrency gate for home-visit booking): it is incremented/decremented as
/// orders are created / rescheduled / cancelled / deleted (see
/// `SlotReservationService`) and periodically reconciled from `OrderDiagnostics`
/// (the business source of truth) via `reconcileBookedCounts`. `status` is the
/// stored coarse state (AVAILABLE); PAST, FULL, BOOKED, OFF-DUTY and UNAVAILABLE
/// are derived. Tenant-scoped + branch-level. One slot per (schedule, date, start
/// time), enforced by a partial unique index in prisma/rls.sql so regeneration
/// upserts rather than duplicates.
model PhlebotomistSlot {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  phlebotomistId String @map("phlebotomist_id")
  phlebotomist   Person @relation("PhlebotomistSlotStaff", fields: [phlebotomistId], references: [id])

  scheduleId String               @map("schedule_id")
  schedule   PhlebotomistSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  slotDate  DateTime @map("slot_date") @db.Date
  startTime String   @map("start_time")
  endTime   String   @map("end_time")

  slotCapacity Int        @map("slot_capacity")
  /// Live count of active (non-cancelled) home-visit bookings occupying this slot.
  /// Guarded by a conditional atomic update (`bookedCount < slotCapacity`) so
  /// concurrent bookings cannot exceed capacity. Reconciled from OrderDiagnostics.
  bookedCount  Int        @default(0) @map("booked_count")
  status       SlotStatus @default(AVAILABLE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([phlebotomistId, slotDate])
  @@index([scheduleId])
  @@index([deletedAt])
  @@map("phlebotomist_slots")
}

/// Per-day reservation load for a phlebotomist at a branch — the atomic gate for
/// the schedule's `maxVisitsPerDay` cap (a per-slot counter cannot guard a
/// cross-slot daily total). `bookedCount` is incremented/decremented alongside
/// `PhlebotomistSlot.bookedCount` by `SlotReservationService` and reconciled from
/// `OrderDiagnostics`. `branchId` is required (home visits are always
/// branch-level) so the uniqueness key is well-defined (Postgres treats NULLs as
/// distinct). Tenant-scoped + branch-level. RLS policy in prisma/rls.sql.
model PhlebotomistDayLoad {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  branchId String @map("branch_id")

  phlebotomistId String @map("phlebotomist_id")

  loadDate    DateTime @map("load_date") @db.Date
  bookedCount Int      @default(0) @map("booked_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, phlebotomistId, branchId, loadDate])
  @@index([tenantId])
  @@index([branchId])
  @@index([phlebotomistId, loadDate])
  @@map("phlebotomist_day_loads")
}

/// An external referring doctor in a tenant's registry who sends business to the
/// lab and earns commission/incentives. Tenant-scoped, tenant-level (CLAUDE.md
/// §4.6): the registry belongs to the business as a whole, not a single branch.
/// Identity mirrors `Doctor`; the commission/TDS/payment/incentive block mirrors
/// `ReferralPanel` (conditional fields validated + normalised in
/// ReferralDoctorService; slabs stored as JSON). Classification links
/// (`department`, `category` = Specialty, `subCategory` = Super Specialty) are real
/// relations to active rows of the same tenant (validated in ReferralDoctorService).
/// Assigned lab tests/panels are child rows (`ReferralDoctorLabTest` /
/// `ReferralDoctorLabPanel`, replace-all on update). `fullName`/`age`/per-experience
/// `duration` are derived in the service, not stored. RLS policy in prisma/rls.sql.
model ReferralDoctor {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  // Personal details
  firstName     String    @map("first_name")
  middleName    String?   @map("middle_name")
  lastName      String?   @map("last_name")
  gender        Gender    @default(MALE)
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  mobileNumber  String    @map("mobile_number")
  email         String?
  aadhaarNumber String?   @map("aadhaar_number")
  panNumber     String?   @map("pan_number")

  // Practice/location details (captured on quick-add; Branch Admin fills the rest)
  hospitalName String? @map("hospital_name")
  city         String?
  state        String?
  pincode      String?

  // Professional details — classification links to active rows of the same tenant
  // (validated in ReferralDoctorService). category = Specialty, subCategory = Super
  // Specialty.
  departmentId  String?      @map("department_id")
  department    Department?  @relation(fields: [departmentId], references: [id])
  categoryId    String?      @map("category_id")
  category      Category?    @relation(fields: [categoryId], references: [id])
  subCategoryId String?      @map("sub_category_id")
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])

  medicalLicenseNumber  String?   @map("medical_license_number")
  registrationCouncil   String?   @map("registration_council")
  registrationValidTill DateTime? @map("registration_valid_till") @db.Date

  // Logical ref to a ReferralPanelSettings template in the tenant (validated in
  // ReferralDoctorService to belong to the caller's tenant).
  referralPanelSettingsId String?                @map("referral_panel_settings_id")
  referralPanelSettings   ReferralPanelSettings? @relation(fields: [referralPanelSettingsId], references: [id])

  // Commission & TDS (conditional fields normalised in the service; slabs as JSON
  // of { monthlyBusinessFrom, monthlyBusinessTo, commissionPct }).
  isCommissionApplicable Boolean               @default(false) @map("is_commission_applicable")
  commissionType         CommissionType?       @map("commission_type")
  commissionPctLabTest   Decimal?              @map("commission_pct_lab_test") @db.Decimal(5, 2)
  commissionPctLabPanel  Decimal?              @map("commission_pct_lab_panel") @db.Decimal(5, 2)
  commissionSlabs        Json                  @default("[]") @map("commission_slabs")
  fixedCommissionCycle   FixedCommissionCycle? @map("fixed_commission_cycle")
  fixedAmount            Decimal?              @map("fixed_amount") @db.Decimal(10, 2)
  isTdsApplicable        Boolean               @default(false) @map("is_tds_applicable")
  tds                    Int?                  @map("tds")

  // Payment & incentive (bonus slabs as JSON of
  // { monthlyBusinessFrom, monthlyBusinessTo, bonusPct }).
  paymentCycle               PaymentCycle        @default(NA) @map("payment_cycle")
  paymentMode                ReferralPaymentMode @default(BANK_TRANSFER) @map("payment_mode")
  monthlyTargetAmount        Int                 @default(0) @map("monthly_target_amount")
  isIncentiveBonusApplicable Boolean             @default(false) @map("is_incentive_bonus_applicable")
  bonusSlabs                 Json                @default("[]") @map("bonus_slabs")

  // Attachment & remarks (file stored as name + URL; upload handled elsewhere)
  fileName String? @map("file_name")
  fileUrl  String? @map("file_url")
  remarks  String?

  // Status
  status ReferralDoctorStatus @default(ACTIVE)

  // Children (managed via the parent in ReferralDoctorService)
  qualifications ReferralDoctorQualification[]
  experiences    ReferralDoctorExperience[]
  labTests       ReferralDoctorLabTest[]
  labPanels      ReferralDoctorLabPanel[]

  /// Orders that name this doctor as the referring doctor.
  orders Order[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([referralPanelSettingsId])
  @@index([status])
  @@index([deletedAt])
  @@map("referral_doctors")
}

/// A qualification (degree) held by a referral doctor. Tenant-scoped; lifecycle is
/// managed via the parent (replace-on-update; soft-deleted with the parent). The
/// `onDelete: Cascade` relation is a DB safety net only — the app soft-deletes.
model ReferralDoctorQualification {
  id               String @id @default(uuid())
  tenantId         String @map("tenant_id")
  referralDoctorId String @map("referral_doctor_id")

  qualificationType String? @map("qualification_type")
  degreeName        String? @map("degree_name")
  institutionName   String? @map("institution_name")
  yearOfCompletion  Int?    @map("year_of_completion")
  percentageGrade   String? @map("percentage_grade")

  referralDoctor ReferralDoctor @relation(fields: [referralDoctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralDoctorId])
  @@index([deletedAt])
  @@map("referral_doctor_qualifications")
}

/// A past/current work engagement of a referral doctor. `toDate` NULL means the
/// role is current (Duration is derived in the service, not stored). Tenant-scoped;
/// managed via the parent like ReferralDoctorQualification.
model ReferralDoctorExperience {
  id               String @id @default(uuid())
  tenantId         String @map("tenant_id")
  referralDoctorId String @map("referral_doctor_id")

  position     String?
  organisation String?
  fromDate     DateTime? @map("from_date") @db.Date
  toDate       DateTime? @map("to_date") @db.Date

  referralDoctor ReferralDoctor @relation(fields: [referralDoctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralDoctorId])
  @@index([deletedAt])
  @@map("referral_doctor_experience")
}

/// A lab test assigned to a referral doctor (the "lab test list" — one row per
/// assigned test). `labTestId` is a logical ref to a LabTest in the tenant (no
/// Prisma relation, mirroring ReferralPanelLabTest); validated in
/// ReferralDoctorService to be an active test in the tenant. One active row per
/// (referral doctor, test) (partial unique index in prisma/rls.sql).
model ReferralDoctorLabTest {
  id               String @id @default(uuid())
  tenantId         String @map("tenant_id")
  referralDoctorId String @map("referral_doctor_id")
  labTestId        String @map("lab_test_id")

  referralDoctor ReferralDoctor @relation(fields: [referralDoctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralDoctorId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("referral_doctor_lab_tests")
}

/// A lab panel assigned to a referral doctor (the "lab panel list" — one row per
/// assigned panel). `labPanelId` is a logical ref to a LabPanel in the tenant (no
/// Prisma relation); validated in ReferralDoctorService to be an active panel in
/// the tenant. One active row per (referral doctor, lab-panel) (partial unique
/// index in prisma/rls.sql).
model ReferralDoctorLabPanel {
  id               String @id @default(uuid())
  tenantId         String @map("tenant_id")
  referralDoctorId String @map("referral_doctor_id")
  labPanelId       String @map("lab_panel_id")

  referralDoctor ReferralDoctor @relation(fields: [referralDoctorId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralDoctorId])
  @@index([labPanelId])
  @@index([deletedAt])
  @@map("referral_doctor_lab_panels")
}

/// A business's registry of external referral partners (people/organisations that
/// refer work to the lab). Tenant-scoped, tenant-level (CLAUDE.md §4.6) — the
/// registry belongs to the business as a whole, not a branch. Commission/incentive
/// config is conditional and normalised in ExternalReferralService (slabs stored as
/// JSON). Assigned lab tests/panels are managed via the parent (replace-on-update).
/// The attachment is stored as name + URL; the upload itself is handled elsewhere.
model ExternalReferral {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
