  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([referralDoctorId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("referral_doctor_lab_tests")
