  externalReferral ExternalReferral @relation(fields: [externalReferralId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([externalReferralId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("external_referral_lab_tests")
}

/// A lab panel assigned to an external referral (the "lab panel list" — one row per
/// assigned panel). `labPanelId` is a logical ref to a LabPanel in the tenant (no
/// Prisma relation); validated in ExternalReferralService to be an active panel in
/// the tenant. One active row per (external referral, lab-panel) (partial unique index
/// in prisma/rls.sql).
model ExternalReferralLabPanel {
  id                 String @id @default(uuid())
  tenantId           String @map("tenant_id")
  externalReferralId String @map("external_referral_id")
  labPanelId         String @map("lab_panel_id")

  externalReferral ExternalReferral @relation(fields: [externalReferralId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([externalReferralId])
  @@index([labPanelId])
  @@index([deletedAt])
  @@map("external_referral_lab_panels")
}

/// An internal referral: an employee of the business who refers lab work and may
/// earn commission/incentive, optionally settled through payroll. Tenant-scoped,
/// tenant-level (CLAUDE.md §4.6): the registry belongs to the business as a whole,
/// not a branch. `employeeId` is an OPTIONAL logical ref to a Person (no Prisma
/// relation, mirroring the lab-list refs); when present it is validated in
/// InternalReferralService to be an active staff member of the caller's tenant.
/// First/last/full name, mobile, and email are stored independently (the frontend
/// may pre-fill them from the linked employee). `fullName` is a plain stored string.
model InternalReferral {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  branchId String? @map("branch_id")

  // Employee details (employeeId = optional logical ref to persons.id)
  employeeId   String?   @map("employee_id")
  firstName    String    @map("first_name")
  lastName     String?   @map("last_name")
  fullName     String?   @map("full_name")
  department   String?
  designation  String?
  joiningDate  DateTime? @map("joining_date") @db.Date
  mobileNumber String?   @map("mobile_number")
  email        String?

  // Location details (captured on quick-add; Branch Admin fills the rest)
  city    String?
  state   String?
  pincode String?

  // Logical ref to a ReferralPanelSettings template in the tenant (validated in
  // InternalReferralService to belong to the caller's tenant).
  referralPanelSettingsId String?                @map("referral_panel_settings_id")
  referralPanelSettings   ReferralPanelSettings? @relation(fields: [referralPanelSettingsId], references: [id])

  // Commission & TDS (conditional fields normalised in the service; slabs as JSON
  // of { monthlyBusinessFrom, monthlyBusinessTo, commissionPct }).
  isCommissionApplicable Boolean               @default(false) @map("is_commission_applicable")
  commissionType         CommissionType?       @map("commission_type")
  commissionPctLabTest   Decimal?              @map("commission_pct_lab_test") @db.Decimal(5, 2)
  commissionPctLabPanel  Decimal?              @map("commission_pct_lab_panel") @db.Decimal(5, 2)
  commissionSlabs        Json                  @default("[]") @map("commission_slabs")
  fixedCommissionCycle   FixedCommissionCycle? @map("fixed_commission_cycle")
  fixedAmount            Decimal?              @map("fixed_amount") @db.Decimal(10, 2)
  isTdsApplicable        Boolean               @default(false) @map("is_tds_applicable")
  tds                    Int?                  @map("tds")

  // Payroll & payment (unique to internal referrals; bonus slabs as JSON of
  // { monthlyBusinessFrom, monthlyBusinessTo, bonusPct }).
  isIncludedInPayroll        Boolean             @default(false) @map("is_included_in_payroll")
  paymentCycle               PaymentCycle        @default(MONTHLY) @map("payment_cycle")
  paymentMode                ReferralPaymentMode @default(BANK_TRANSFER) @map("payment_mode")
  commissionMode             CommissionMode      @default(INCLUDED_IN_SALARY) @map("commission_mode")
  monthlyTargetAmount        Int                 @default(0) @map("monthly_target_amount")
  isIncentiveBonusApplicable Boolean             @default(false) @map("is_incentive_bonus_applicable")
  bonusSlabs                 Json                @default("[]") @map("bonus_slabs")

  // Attachment & remarks (file stored as name + URL; upload handled elsewhere)
  fileName String? @map("file_name")
  fileUrl  String? @map("file_url")
  remarks  String?

  // Status
  status InternalReferralStatus @default(ACTIVE)

  // Children (managed via the parent in InternalReferralService)
  labTests  InternalReferralLabTest[]
  labPanels InternalReferralLabPanel[]

  // Orders that name this internal referral (back-relation).
  orders Order[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([branchId])
  @@index([employeeId])
  @@index([referralPanelSettingsId])
  @@index([status])
  @@index([deletedAt])
  @@map("internal_referrals")
}

/// A lab test assigned to an internal referral (the "lab test list" — one row per
/// assigned test). `labTestId` is a logical ref to a LabTest in the tenant (no Prisma
/// relation, mirroring ExternalReferralLabTest); validated in InternalReferralService
/// to be an active test in the tenant. One active row per (internal referral, test)
/// (partial unique index in prisma/rls.sql).
model InternalReferralLabTest {
  id                 String @id @default(uuid())
  tenantId           String @map("tenant_id")
  internalReferralId String @map("internal_referral_id")
  labTestId          String @map("lab_test_id")

  internalReferral InternalReferral @relation(fields: [internalReferralId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([internalReferralId])
  @@index([labTestId])
  @@index([deletedAt])
  @@map("internal_referral_lab_tests")
}

/// A lab panel assigned to an internal referral (the "lab panel list" — one row per
/// assigned panel). `labPanelId` is a logical ref to a LabPanel in the tenant (no
/// Prisma relation); validated in InternalReferralService to be an active panel in
/// the tenant. One active row per (internal referral, lab-panel) (partial unique index
/// in prisma/rls.sql).
model InternalReferralLabPanel {
  id                 String @id @default(uuid())
  tenantId           String @map("tenant_id")
  internalReferralId String @map("internal_referral_id")
  labPanelId         String @map("lab_panel_id")

