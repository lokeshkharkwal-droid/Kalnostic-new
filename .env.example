# Copy this file to `.env` and fill in real values. Never commit `.env`.
# These vars are validated at boot by src/config/env.validation.ts.

# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL connection string used by Prisma)
# For RLS to actually enforce, this role must NOT be a superuser, the table
# owner, or have BYPASSRLS. Use a dedicated least-privilege app role.
DATABASE_URL=postgresql://user:password@localhost:5432/kalnostics?schema=public

# Auth (JWT_SECRET must be at least 32 characters)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=1h

# At-rest field encryption (AES-256-GCM) for sensitive data such as Aadhaar.
# Must be 32 bytes as 64 hex chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Optional (the app boots without it) but REQUIRED to store Aadhaar numbers.
ENCRYPTION_KEY=

# Profile-photo uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=2097152

# Audit log retention (days). Rows older than this are hard-deleted by the
# daily purge job in AuditService. Default 90 (~3 months).
AUDIT_RETENTION_DAYS=90

# PDF generation (Puppeteer). In development, Puppeteer downloads and uses its
# own bundled Chromium — leave these unset. In Docker/production, install a
# system Chromium and point Puppeteer at it to avoid the download:
#   PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
#   PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=

# Row-Level Security. Leave false until: (1) prisma/rls.sql is applied, (2)
# DATABASE_URL uses a non-owner/non-superuser role, and (3) all tenant-scoped
# multi-statement writes use PrismaService.withTenant. Then set to true to make
# Postgres RLS the real tenant-isolation backstop.
RLS_ENABLED=false
